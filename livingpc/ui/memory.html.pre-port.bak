<!DOCTYPE html>
<html><head><meta charset="utf-8"><style>
  :root {
    --bg0:#040906; --line:rgba(112,214,158,.28); --line2:rgba(112,214,158,.14);
    --fg:#edf5f0; --muted:#a3c2ab; --cyan:#53e7c0; --green:#2fe3a0;
    --red:#ff6b8a; --amber:#ffd166; --grey:#5b648c;
    --card:rgba(7,20,14,.44); --card2:rgba(5,15,11,.56);
    --glass-strong:rgba(5,15,11,.72); --shadow:rgba(0,0,0,.38);
  }
  html,body { margin:0; height:100%; font-family:'Segoe UI',Helvetica,Arial,sans-serif;
    background-color:var(--bg0);
    background-image:
      radial-gradient(120% 82% at 50% 0%, rgba(7,27,17,.38) 0%, rgba(4,15,10,.58) 56%, rgba(3,8,6,.78) 100%),
      url("assets/backgrounds/forest-ruins-main.jpg");
    background-size: cover, cover;
    background-position: center, center 28%;
    background-repeat: no-repeat, no-repeat;
    background-attachment: fixed, fixed;
    color:var(--fg); overflow:hidden; }
  ::-webkit-scrollbar { width:8px; } ::-webkit-scrollbar-thumb { background:#274a35; border-radius:4px; }
  ::-webkit-scrollbar-track { background:transparent; }

  /* Shared form treatment prevents native white controls from breaking the forest palette. */
  input:not([type="checkbox"]), textarea, select {
    box-sizing:border-box; font:inherit; font-size:13px; color:var(--fg);
    background-color:var(--glass-strong);
    background-image:linear-gradient(180deg,rgba(8,24,16,.7),rgba(4,14,10,.78));
    border:1px solid var(--line); border-radius:11px; padding:9px 12px; outline:none;
    box-shadow:0 4px 14px rgba(0,0,0,.18); transition:border-color .15s,box-shadow .15s,background .15s;
    color-scheme:dark;
  }
  input:not([type="checkbox"]):hover, textarea:hover, select:hover {
    border-color:rgba(112,214,158,.42); background-image:linear-gradient(180deg,rgba(10,29,19,.75),rgba(5,17,12,.82));
  }
  input:not([type="checkbox"]):focus, textarea:focus, select:focus {
    border-color:var(--green); box-shadow:0 0 0 2px rgba(47,227,160,.1),0 0 14px rgba(47,227,160,.2);
  }
  input::placeholder, textarea::placeholder { color:rgba(180,207,187,.64); }
  input:disabled, textarea:disabled, select:disabled { opacity:.5; cursor:default; }
  textarea { field-sizing:content; min-height:64px; max-height:60vh; overflow-y:auto;
    line-height:1.5; resize:none; }

  /* Ambient light motes drifting over the background, behind the app content. */
  #motes { position:fixed; inset:0; z-index:1; pointer-events:none; overflow:hidden; }
  #motes span { position:absolute; bottom:-10px; display:block; border-radius:50%;
    background:radial-gradient(circle, rgba(255,244,214,.95) 0%, rgba(255,223,150,.55) 45%, rgba(255,223,150,0) 75%);
    box-shadow:0 0 6px 1px rgba(255,224,160,.5);
    animation: mote-rise linear infinite; }
  @keyframes mote-rise {
    0%   { transform:translate(0,0) scale(.7); opacity:0; }
    8%   { opacity:.85; }
    50%  { transform:translate(var(--drift,12px), -52vh) scale(1); }
    92%  { opacity:.6; }
    100% { transform:translate(calc(var(--drift,12px) * 2), -108vh) scale(.6); opacity:0; }
  }

  #app { position:relative; z-index:2; display:grid; grid-template-columns:176px minmax(0,1fr);
    grid-template-rows:auto 1fr; height:100vh; }
  header { grid-column:1; grid-row:1; display:flex; flex-direction:column; align-items:flex-start;
    gap:4px; padding:22px 14px 8px; }
  header .logo { font-size:19px; font-weight:600; color:var(--green);
    text-shadow:0 0 14px rgba(47,227,160,.42); letter-spacing:.3px; }
  header .sub { display:none; }
  header .header-refresh { position:fixed; left:14px; bottom:18px; z-index:35; margin-left:0;
    width:34px; height:34px; padding:0; border-radius:999px;
    display:grid; place-items:center; font-size:16px; line-height:1; }
  header .header-refresh.spinning { animation:header-refresh-spin .6s linear; }
  @keyframes header-refresh-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
  header .settings-cog { position:fixed; left:58px; bottom:18px; z-index:35;
    width:34px; height:34px; padding:0; border-radius:999px;
    display:grid; place-items:center; font-size:17px; line-height:1; }
  header .backend { display:none; }

  nav { grid-column:1; grid-row:2; display:flex; flex-direction:column; gap:8px;
    padding:8px 14px 74px; align-items:stretch; flex-wrap:nowrap; }
  nav .tab { font-size:13px; letter-spacing:.4px; padding:7px 20px; border-radius:20px;
    cursor:pointer; color:#d9e9df; background:rgba(7,21,14,.52); border:1px solid var(--line);
    transition:all .18s ease; user-select:none; text-align:center; }
  nav .tab:hover { background:rgba(15,39,25,.68); border-color:rgba(112,214,158,.46); }
  nav .tab.active { color:#032118; font-weight:700; background:linear-gradient(90deg,#2fe3a0,#53e7c0);
    border-color:transparent; box-shadow:0 0 16px rgba(47,227,160,.3); }
  .nav-group { position:relative; }
  .nav-group summary { list-style:none; }
  .nav-group summary::-webkit-details-marker { display:none; }
  .group-label { font-size:13px; letter-spacing:.4px; padding:7px 20px; border-radius:20px;
    cursor:pointer; color:#d9e9df; background:rgba(7,21,14,.52); border:1px solid var(--line);
    transition:all .18s ease; user-select:none; }
  .group-label::after { content:'▾'; margin-left:8px; color:var(--muted); font-size:10px; }
  .nav-group[open] .group-label,.nav-group.active .group-label {
    border-color:rgba(112,214,158,.58); background:rgba(15,39,25,.74); color:var(--cyan);
  }
  .nav-menu { position:absolute; top:0; left:calc(100% + 8px); min-width:190px; padding:8px;
    border:1px solid var(--line); border-radius:14px; background:rgba(4,15,10,.96);
    box-shadow:0 14px 38px rgba(0,0,0,.45); z-index:30; display:grid; gap:6px; }
  .nav-menu .tab { display:block; border-radius:10px; padding:8px 12px; white-space:nowrap; }
  .nav-menu .tab.active { color:#032118; }

  .view { grid-column:2; grid-row:1 / span 2; min-height:0; overflow-y:auto;
    padding:22px 22px 22px 0; display:none; }
  .view.active { display:block; }
  .view > * { max-width:none; margin-left:0; margin-right:0; box-sizing:border-box; }
  .view > .hint { max-width:none; margin-left:0; margin-right:0; }

  .toolbar { display:flex; align-items:center; gap:10px; margin:6px 0 12px; flex-wrap:wrap; }
  button { font-family:inherit; cursor:pointer; border-radius:12px; font-size:13px;
    padding:8px 18px; border:1px solid var(--line); background:rgba(5,15,11,.76);
    color:#d9e9df; transition:all .15s ease; box-shadow:0 3px 12px rgba(0,0,0,.18); }
  button:hover { border-color:rgba(112,214,158,.58); background:rgba(16,39,26,.88); }
  button:disabled { opacity:.45; cursor:default; }
  button.accent { background:linear-gradient(90deg,#2fe3a0,#53e7c0); color:#032118;
    font-weight:700; border:none; box-shadow:0 0 14px rgba(47,227,160,.26); }
  button.accent:hover { box-shadow:0 0 22px rgba(47,227,160,.42); }
  #inf-status { font-size:12px; color:var(--cyan); }
  .hint { font-size:12.5px; color:var(--muted); line-height:1.55; margin-top:0; margin-bottom:14px; max-width:980px; }

  .card { background:linear-gradient(135deg,rgba(8,24,16,.5),rgba(4,13,10,.36));
    border:1px solid var(--line); border-radius:16px; padding:16px 18px 14px; margin-bottom:14px;
    box-shadow:0 8px 24px var(--shadow),inset 0 1px 0 rgba(220,255,232,.025);
    -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); animation:rise .25s ease; }
  @keyframes rise { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }
  .card .theme { font-size:10px; letter-spacing:2.2px; text-transform:uppercase;
    color:var(--cyan); margin-bottom:6px; }
  .card .statement { font-size:15.5px; font-weight:600; line-height:1.45; }
  .card .meta { display:flex; align-items:center; gap:10px; margin:9px 0 12px;
    font-size:11.5px; color:var(--muted); flex-wrap:wrap; }
  .chip { border:1px solid var(--line2); border-radius:20px; padding:2px 10px; }
  .confbar { width:110px; height:5px; border-radius:3px; background:rgba(112,214,158,.15);
    overflow:hidden; }
  .confbar i { display:block; height:100%; border-radius:3px;
    background:linear-gradient(90deg,#2fe3a0,#53e7c0); }

  /* Self dashboard */
  .self-grid { display:grid; grid-template-columns:minmax(250px,300px) minmax(360px,1fr) minmax(290px,360px);
    gap:18px; align-items:start; }
  .self-panel { background:linear-gradient(135deg,rgba(8,24,16,.62),rgba(4,13,10,.48));
    border:1px solid var(--line); border-radius:16px; padding:14px; box-shadow:0 8px 24px var(--shadow);
    -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); }
  .self-identity-card { padding:12px; }
  .self-identity-summary { padding:2px 0 0; }
  .self-identity-summary h3 { margin:0 0 8px; font-size:13px; color:var(--green);
    letter-spacing:1.6px; text-transform:uppercase; }
  .self-rank { display:flex; justify-content:space-between; align-items:center; color:var(--green);
    font-size:12px; letter-spacing:1px; text-transform:uppercase; font-weight:700; }
  .self-portrait { height:420px; margin:10px 0 12px; border-radius:4px; overflow:hidden;
    border:1px solid rgba(112,214,158,.28); background-image:
      linear-gradient(180deg,rgba(217,255,221,.18),rgba(2,10,6,.12)),
      var(--portrait-image,url("assets/backgrounds/forest-ruins-main.jpg"));
    background-size:cover; background-position:center; position:relative;
    box-shadow:inset 0 -60px 80px rgba(2,8,5,.55); isolation:isolate; }
  .self-portrait::before { content:''; position:absolute; inset:0; z-index:1;
    background:radial-gradient(circle at 62% 2%,rgba(197,255,184,.2),transparent 34%),
      linear-gradient(180deg,transparent 48%,rgba(2,8,5,.18)); pointer-events:none; }
  .self-portrait-edit { position:absolute; z-index:11; top:10px; right:10px; width:34px; height:34px;
    padding:0; display:flex; align-items:center; justify-content:center; border-radius:999px;
    opacity:0; transform:translateY(-3px); background:rgba(2,12,8,.72);
    border:1px solid rgba(179,255,203,.42); color:var(--cyan);
    box-shadow:0 6px 18px rgba(0,0,0,.34); }
  .self-portrait:hover .self-portrait-edit,.self-portrait.customizing .self-portrait-edit,
  .self-portrait-edit:focus { opacity:1; transform:none; }
  .self-portrait-edit:hover { background:rgba(47,227,160,.22); }
  .self-portrait-sparkle { position:absolute; z-index:8; inset:auto 18px 14px auto;
    color:rgba(237,245,240,.72); font-size:38px; text-shadow:0 0 18px rgba(83,231,192,.65);
    pointer-events:none; }
  .self-customizer { position:absolute; z-index:12; top:52px; right:10px; width:min(245px,calc(100% - 20px));
    border:1px solid rgba(112,214,158,.34); border-radius:13px; padding:11px;
    background:rgba(3,13,8,.9); box-shadow:0 12px 32px rgba(0,0,0,.5);
    -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); display:none; }
  .self-customizer.open { display:block; animation:rise .18s ease; }
  .self-customizer label { display:block; color:var(--muted); font-size:11px; margin:8px 0 3px; }
  .self-customizer select { width:100%; box-sizing:border-box; background:var(--card2);
    border:1px solid var(--line); color:var(--fg); border-radius:9px; padding:7px 9px;
    font:inherit; font-size:12px; }
  .self-customizer .hint { margin:8px 0 0; font-size:11px; line-height:1.35; }
  .portrait-rays,.portrait-motes,.portrait-wind,.portrait-droplets,.portrait-aurora {
    position:absolute; inset:0; pointer-events:none; opacity:0; z-index:2; }
  .portrait-fx-canvas { position:absolute; inset:0; z-index:7; width:100%; height:100%;
    pointer-events:none; opacity:.9; mix-blend-mode:screen; }
  .self-portrait.anim-still .portrait-fx-canvas { opacity:0; }
  .self-portrait.anim-sunshafts .portrait-rays,
  .self-portrait.anim-living .portrait-rays { inset:-18% -26%; opacity:.86;
    background:linear-gradient(106deg,transparent 0 36%,rgba(177,255,219,.14) 41%,
      rgba(83,231,192,.32) 45%,transparent 51%,transparent 58%,rgba(224,255,187,.2) 62%,
      transparent 69%);
    mix-blend-mode:screen; transform-origin:62% 0%; animation:portrait-rays 7.5s ease-in-out infinite alternate; }
  .self-portrait.anim-motes .portrait-motes,
  .self-portrait.anim-fireflies .portrait-motes,
  .self-portrait.anim-living .portrait-motes { opacity:.75; z-index:3;
    background-image:radial-gradient(circle,rgba(239,255,209,.75) 0 1px,transparent 2px),
      radial-gradient(circle,rgba(83,231,192,.5) 0 1px,transparent 2px),
      radial-gradient(circle,rgba(255,255,255,.42) 0 1px,transparent 2px);
    background-size:72px 84px,96px 110px,140px 130px;
    background-position:10px 80px,42px 18px,120px 40px;
    mix-blend-mode:screen; animation:portrait-motes 13s linear infinite; }
  .self-portrait.anim-breeze .portrait-wind,
  .self-portrait.anim-living .portrait-wind { opacity:.42; z-index:4;
    background:repeating-linear-gradient(168deg,transparent 0 24px,rgba(164,255,213,.12) 25px,
      transparent 34px);
    filter:blur(1px); mix-blend-mode:screen; animation:portrait-wind 6.5s ease-in-out infinite; }
  .self-portrait.anim-rain .portrait-droplets,
  .self-portrait.anim-living .portrait-droplets { opacity:.58; z-index:5;
    background:radial-gradient(circle at 21% 84%,rgba(222,255,231,.5) 0 1px,transparent 3px),
      radial-gradient(circle at 38% 78%,rgba(83,231,192,.42) 0 1px,transparent 3px),
      radial-gradient(circle at 72% 88%,rgba(222,255,231,.38) 0 1px,transparent 3px),
      radial-gradient(circle at 83% 70%,rgba(83,231,192,.36) 0 1px,transparent 3px);
    filter:drop-shadow(0 0 4px rgba(83,231,192,.45)); animation:portrait-droplets 5.2s ease-in-out infinite alternate; }
  .self-portrait.anim-dreamlight .portrait-aurora { opacity:.58; z-index:3;
    background:radial-gradient(ellipse at 24% 18%,rgba(70,255,190,.22),transparent 42%),
      radial-gradient(ellipse at 76% 12%,rgba(190,255,130,.16),transparent 48%),
      linear-gradient(112deg,transparent 20%,rgba(83,231,192,.14) 43%,transparent 66%);
    filter:blur(9px); mix-blend-mode:screen; animation:portrait-aurora 8s ease-in-out infinite alternate; }
  @keyframes portrait-rays { from{ transform:translateX(-12px) rotate(-3deg); filter:brightness(.9); }
    to{ transform:translateX(18px) rotate(2deg); filter:brightness(1.18); } }
  @keyframes portrait-motes { from{ background-position:10px 90px,42px 28px,120px 60px; }
    to{ background-position:38px -90px,20px -120px,98px -80px; } }
  @keyframes portrait-wind { 0%,100%{ transform:translateX(-18px); opacity:.22; }
    50%{ transform:translateX(20px); opacity:.42; } }
  @keyframes portrait-droplets { from{ transform:translateY(0); opacity:.38; }
    to{ transform:translateY(-5px); opacity:.72; } }
  @keyframes portrait-aurora { from{ transform:translateX(-10px) scale(1); filter:blur(12px) hue-rotate(0deg); }
    to{ transform:translateX(12px) scale(1.04); filter:blur(7px) hue-rotate(18deg); } }
  @media (prefers-reduced-motion:reduce) {
    .self-portrait .portrait-rays,.self-portrait .portrait-motes,.self-portrait .portrait-wind,
    .self-portrait .portrait-droplets,.self-portrait .portrait-aurora { animation:none; opacity:.28; }
    .portrait-fx-canvas { display:none; }
  }
  .self-bar-card { background:rgba(255,255,255,.055); border-radius:10px; padding:11px; margin:10px 0; }
  .self-bar-head { display:flex; justify-content:space-between; gap:8px; color:var(--fg); font-size:12.5px; margin-bottom:8px; }
  .self-blocks { display:flex; gap:2px; }
  .self-blocks i { display:block; width:10px; height:9px; border-radius:1px; background:rgba(255,255,255,.16); }
  .self-blocks i.on { background:linear-gradient(180deg,#53e7c0,#1aa86f); box-shadow:0 0 7px rgba(47,227,160,.32); }
  .self-stats { margin-top:16px; border-top:1px solid var(--line2); padding-top:8px; }
  .self-stat-row { display:grid; grid-template-columns:1fr 48px 70px; gap:8px; align-items:center;
    padding:7px 0; border-bottom:1px solid var(--line2); font-size:12.5px; }
  .self-stat-row:last-child { border-bottom:none; }
  .self-stat-row .metric-progress { height:4px; }
  .self-title-card { display:flex; align-items:center; justify-content:center; min-height:42px;
    font-size:22px; font-style:italic; font-weight:800; color:var(--green); letter-spacing:.4px; }
  .self-scenarios { margin-top:12px; }
  .self-scenario-row { padding:6px 0 6px 22px; color:var(--muted); font-size:13px; }
  .self-scenario-row::before { content:'▸'; margin-left:-18px; margin-right:7px; color:var(--fg); }
  .self-trend { height:230px; display:flex; align-items:center; justify-content:center; }
  .self-trend svg { width:100%; height:210px; }
  .self-quest-card { border:1px solid rgba(112,214,158,.32); border-radius:10px; padding:10px 12px;
    background:rgba(179,255,203,.14); box-shadow:0 0 0 2px rgba(179,255,203,.12) inset; margin:10px 0; }
  .self-quest-card b { color:#b8ffd4; font-size:22px; }
  .self-task { display:flex; gap:8px; align-items:flex-start; padding:6px 0; color:var(--muted); font-size:13px; }
  .self-task input { margin-top:2px; accent-color:var(--green); }
  .self-task.done { text-decoration:line-through; opacity:.62; }
  .self-pursuits { margin-top:28px; }
  .self-pursuit-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; }
  .self-pursuit { min-height:150px; display:flex; flex-direction:column; justify-content:flex-end;
    background:linear-gradient(180deg,rgba(10,35,22,.15),rgba(4,12,8,.9)),
      url("assets/backgrounds/forest-ruins-main.jpg"); background-size:cover; background-position:center;
    border:1px solid var(--line); border-radius:12px; overflow:hidden; box-shadow:0 8px 20px rgba(0,0,0,.35); }
  .self-pursuit-body { padding:12px; background:linear-gradient(180deg,rgba(5,15,11,.1),rgba(5,15,11,.92)); }
  .self-pursuit-title { font-weight:700; margin-bottom:7px; }
  .self-pursuit-meta { display:flex; align-items:center; gap:8px; color:var(--muted); font-size:12px; }
  .command-tools { display:none; }
  .command-center-shell { display:grid;
    grid-template-columns:minmax(260px,320px) minmax(460px,1fr) minmax(270px,330px);
    gap:18px; align-items:start; overflow:visible; padding-bottom:36px; }
  .command-center-shell.no-sidebar { grid-template-columns:minmax(260px,320px) minmax(0,1fr); }
  .command-portrait-col { overflow:visible;
    display:flex; flex-direction:column; gap:16px; padding-right:8px; box-sizing:border-box; }
  .command-chat-col { display:flex; flex-direction:column; gap:16px;
    overflow:visible; padding-right:0; box-sizing:border-box; }
  .command-chat-panel,.command-side { background:linear-gradient(135deg,rgba(8,24,16,.68),rgba(4,13,10,.54));
    border:1px solid var(--line); border-radius:18px; box-shadow:0 16px 44px rgba(0,0,0,.32); }
  .command-chat-panel { flex:0 0 auto; height:max(860px,calc(100vh - 44px)); min-height:760px;
    display:grid; grid-template-columns:200px minmax(0,1fr); overflow:hidden; }
  .cc-chat-list { min-width:0; border-right:1px solid var(--line2); padding:14px; overflow:auto; }
  .cc-chat-list-head { display:flex; justify-content:space-between; align-items:center; gap:6px; margin-bottom:12px; }
  .cc-chat-list-head b { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
    color:var(--green); letter-spacing:1.2px; text-transform:uppercase; font-size:10.5px; }
  .cc-chat-list-toggle { flex:0 0 auto; background:none; border:none; box-shadow:none; padding:2px 4px;
    color:var(--muted); font-size:14px; }
  .cc-chat-list-toggle:hover { color:var(--green); background:none; }
  .cc-new-chat-btn { flex:0 0 auto; width:26px; height:26px; padding:0; border-radius:999px;
    display:grid; place-items:center; font-size:16px; line-height:1; }
  .cc-ctx-menu { position:fixed; z-index:60; min-width:150px; padding:6px; border-radius:12px;
    border:1px solid var(--line); background:rgba(4,15,10,.97); box-shadow:0 14px 38px rgba(0,0,0,.45); }
  .cc-ctx-item { display:block; width:100%; text-align:left; padding:8px 11px; border-radius:8px;
    background:none; border:none; box-shadow:none; color:#d9e9df; font-size:13px; }
  .cc-ctx-item:hover { background:rgba(255,255,255,.08); }
  .cc-ctx-item.danger { color:var(--red); }
  .cc-ctx-item.danger:hover { background:rgba(255,107,138,.12); }
  .command-chat-panel.chat-list-collapsed { grid-template-columns:40px minmax(0,1fr); }
  .command-chat-panel.chat-list-collapsed .cc-chat-list-head { justify-content:center; padding:0; }
  .command-chat-panel.chat-list-collapsed .cc-chat-list-head b,
  .command-chat-panel.chat-list-collapsed #cc-new-chat,
  .command-chat-panel.chat-list-collapsed #cc-chat-list,
  .command-chat-panel.chat-list-collapsed #cc-delete-chat { display:none; }
  .command-chat-panel.chat-list-collapsed .cc-chat-list { padding:14px 4px; }
  .cc-chat-item { width:100%; text-align:left; margin:5px 0; padding:10px 12px; border-radius:11px;
    color:var(--muted); background:rgba(255,255,255,.035); border:1px solid transparent; }
  .cc-chat-item.active { color:#032118; background:linear-gradient(90deg,#2fe3a0,#53e7c0); font-weight:800; }
  .cc-chat-main { display:flex; flex-direction:column; min-width:0; min-height:0; }
  .cc-chat-head { padding:20px 24px; border-bottom:1px solid var(--line2);
    display:flex; align-items:flex-start; gap:12px; }
  .cc-chat-head-text { flex:1; min-width:0; }
  .cc-chat-head h2 { margin:0; font-size:20px; }
  .cc-chat-head p { margin:7px 0 0; color:var(--muted); font-size:13px; line-height:1.5; }
  .cc-fullscreen-btn { flex:0 0 auto; width:34px; height:34px; padding:0; margin-top:2px;
    border-radius:10px; display:grid; place-items:center; font-size:16px; line-height:1;
    background:rgba(255,255,255,.05); border:1px solid var(--line2); color:var(--muted); }
  .cc-fullscreen-btn:hover { color:var(--green); border-color:rgba(112,214,158,.5); background:rgba(255,255,255,.1); }
  body.chat-fullscreen header, body.chat-fullscreen nav,
  body.chat-fullscreen .command-portrait-col, body.chat-fullscreen .command-side,
  body.chat-fullscreen .command-investigations-panel { display:none !important; }
  body.chat-fullscreen .view.active { padding:0; }
  body.chat-fullscreen .view > * { max-width:none; }
  body.chat-fullscreen .command-center-shell { grid-template-columns:1fr; max-height:100vh; gap:0; }
  body.chat-fullscreen .command-chat-col { max-height:100vh; padding-right:0; gap:0; }
  body.chat-fullscreen .command-chat-panel { height:100vh; min-height:0; border-radius:0; border:none; }
  .cc-log { flex:1; min-height:300px; overflow:auto; padding:22px 24px; display:flex; flex-direction:column; gap:16px;
    user-select:text; }
  .cc-message { max-width:82%; padding:14px 17px; border:1px solid var(--line2); border-radius:16px;
    background:rgba(255,255,255,.045); line-height:1.6; font-size:14px; white-space:pre-wrap; overflow-wrap:anywhere;
    user-select:text; cursor:text; }
  .cc-message.user { align-self:flex-end; background:rgba(47,227,160,.12); border-color:rgba(83,231,192,.32); }
  .cc-message.assistant { align-self:flex-start; }
  .cc-empty { margin:auto; max-width:520px; text-align:center; color:var(--muted); line-height:1.65; }
  .cc-compose { border-top:1px solid var(--line2); padding:18px 24px 20px; }
  .cc-attachments { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:10px; }
  .cc-proposal { margin:0 24px 16px; padding:12px 14px; border:1px solid rgba(255,255,255,0.18);
    border-radius:12px; background:rgba(255,255,255,0.04); display:flex; align-items:center;
    justify-content:space-between; gap:12px; font-size:13px; }
  .cc-proposal-text { flex:1; }
  .cc-proposal button { flex-shrink:0; }
  .cc-chip { display:inline-flex; align-items:center; gap:6px; border:1px solid var(--line2);
    border-radius:999px; padding:5px 9px; color:var(--muted); font-size:12px; background:rgba(255,255,255,.04); }
  .cc-chip button { border:none; background:none; padding:0; color:var(--red); }
  .cc-compose-input-wrap { position:relative; }
  .cc-compose-input-wrap textarea { width:100%; min-height:92px; box-sizing:border-box; resize:vertical;
    padding:13px 48px; border-radius:13px; font-size:14px; }
  .cc-icon-btn { position:absolute; bottom:10px; width:32px; height:32px; padding:0;
    border-radius:999px; display:grid; place-items:center; font-size:15px; line-height:1;
    box-shadow:none; z-index:2; }
  .cc-attach-btn { left:10px; background:rgba(255,255,255,.06); border:1px solid var(--line2);
    color:var(--muted); font-size:19px; }
  .cc-attach-btn:hover { color:var(--green); border-color:rgba(112,214,158,.5); background:rgba(255,255,255,.1); }
  .cc-send-btn { right:10px; background:linear-gradient(90deg,#2fe3a0,#53e7c0); border:none;
    color:#032118; box-shadow:0 0 10px rgba(47,227,160,.28); }
  .cc-send-btn:hover { box-shadow:0 0 16px rgba(47,227,160,.46); }
  .cc-send-btn:disabled { opacity:.5; }
  .command-side { padding:16px; }
  .command-widget { border:1px solid var(--line2); border-radius:14px; padding:12px;
    background:rgba(255,255,255,.035); margin-bottom:12px; }
  .command-widget h3 { margin:0 0 8px; font-size:13px; color:var(--green); letter-spacing:1.6px; text-transform:uppercase; }
  .command-section-divider { display:flex; align-items:center; gap:10px; margin:2px 4px 12px;
    color:var(--green); font-size:12px; letter-spacing:1.8px; text-transform:uppercase; font-weight:700; }
  .command-section-divider::after { content:''; flex:1; height:1px; background:var(--line2); }
  .command-investigations-panel { flex:0 0 auto; padding:2px 2px 4px; }
  .self-investigation-card { cursor:pointer; }
  .self-pursuit { transition:transform .15s ease, box-shadow .15s ease; }
  .self-investigation-card:hover { transform:translateY(-2px); box-shadow:0 12px 26px rgba(0,0,0,.4); }
  .self-collapse-extra[hidden] { display:none; }
  .self-collapse-toggle { display:inline-block; background:none; border:none; box-shadow:none;
    padding:6px 0 0; margin:0; color:var(--cyan); font-size:11.5px; text-decoration:underline dotted; }
  .self-collapse-toggle:hover { color:var(--green); background:none; }
  .calibration-section { margin:10px 0 4px; font-size:10.5px; letter-spacing:1px; text-transform:uppercase;
    color:var(--muted); }
  .calibration-section:first-child { margin-top:0; }
  .calibration-row { font-size:12.5px; padding:3px 0; display:flex; align-items:center; gap:7px; }
  .calibration-row .cal-mark { flex-shrink:0; width:14px; text-align:center; }
  .calibration-row.done { color:var(--fg); }
  .calibration-row.done .cal-mark { color:var(--green); }
  .calibration-row.remaining { color:var(--muted); }
  .calibration-row.skipped { color:var(--muted); font-style:italic; }
  .calibration-row[data-cal-key] { cursor:pointer; border-radius:6px; padding:4px 6px;
    margin:0 -6px; transition:background .12s ease; }
  .calibration-row[data-cal-key]:hover { background:rgba(255,255,255,.06); }
  .calibration-row.active { background:rgba(83,231,192,.14); color:var(--cyan); }
  .calibration-row.active .cal-mark { color:var(--cyan); }
  body.profile-launch .personal-only, body.profile-launch [data-personal-only="true"] { display:none !important; }
  body.profile-launch #view-goals .admin-only, body.profile-launch #goal-add-overgoal,
  body.profile-launch #goal-backfill-origin, body.profile-launch #goal-view-list,
  body.profile-launch #goal-open-map { display:none !important; }
  @media(max-width:1080px){
    #app{display:flex;flex-direction:column}
    header{display:flex;flex-direction:row;align-items:baseline;padding:17px 22px 11px}
    header .sub{display:none}
    header .header-refresh{position:static;margin-left:auto}
    header .settings-cog{position:static}
    nav{display:flex;flex-direction:row;gap:8px;padding:0 22px 12px;align-items:center;flex-wrap:wrap}
    nav .tab{text-align:left}
    .nav-menu{top:calc(100% + 6px);left:0}
    .view{flex:1;padding:4px 22px 22px}
    .command-center-shell{grid-template-columns:1fr;max-height:none}
    .command-chat-panel{grid-template-columns:1fr;min-height:620px;height:auto}
    .cc-chat-list{border-right:none;border-bottom:1px solid var(--line2);max-height:150px}
    .command-side{max-height:none}
    .command-portrait-col{max-height:none}
    .command-portrait-col .self-portrait{height:260px}
    .command-chat-col{max-height:none}
  }
  .soul-calibration-drawer { width:min(640px,92vw); }
  .soul-calibration-field { margin:12px 0; }
  .soul-calibration-field label { display:block; color:var(--cyan); font-size:10px;
    letter-spacing:1.4px; text-transform:uppercase; margin-bottom:5px; }
  .soul-calibration-field textarea { width:100%; min-height:86px; }
  .soul-calibration-prompt { font-size:16px; font-weight:600; line-height:1.4; margin-bottom:10px; }
  .soul-facts { margin-top:12px; padding-top:10px; border-top:1px solid var(--line2); }
  .soul-fact { padding:7px 0; border-bottom:1px solid rgba(112,214,158,.08);
    font-size:12px; line-height:1.45; }
  .soul-fact b { color:var(--green); }
  .self-empty { color:var(--muted); line-height:1.6; text-align:center; padding:28px 12px; }
  @media(max-width:1080px){ .self-grid{grid-template-columns:1fr}.self-portrait{height:260px} }

  .actions { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
  .actions .yes  { background:rgba(47,227,160,.14); border-color:rgba(47,227,160,.5); color:var(--green); }
  .actions .yes:hover  { background:rgba(47,227,160,.28); }
  .actions .kind { background:rgba(255,209,102,.12); border-color:rgba(255,209,102,.45); color:var(--amber); }
  .actions .kind:hover { background:rgba(255,209,102,.26); }
  .actions .no   { background:rgba(255,107,138,.12); border-color:rgba(255,107,138,.45); color:var(--red); }
  .actions .no:hover   { background:rgba(255,107,138,.26); }
  .actions .skip { color:var(--muted); }
  .actions .rewrite { margin-left:auto; font-size:12px; color:var(--muted);
    background:none; border:none; text-decoration:underline dotted; padding:6px 2px; }
  .editor { display:none; margin-top:10px; }
  .editor.open { display:block; }
  .editor textarea { width:100%; box-sizing:border-box; min-height:52px; resize:vertical;
    background:var(--card2); color:var(--fg); border:1px solid var(--line);
    border-radius:10px; padding:9px 11px; font:inherit; font-size:13px; outline:none; }
  .editor textarea:focus { border-color:var(--green); box-shadow:0 0 10px rgba(47,227,160,.2); }
  .editor .row { display:flex; justify-content:flex-end; margin-top:8px; }
  .empty { color:var(--muted); font-size:13px; line-height:1.6; padding:26px 8px; text-align:center; }

  /* No / Kind-of feedback dialogue */
  .feedback { display:none; margin-top:12px; border-top:1px dashed var(--line2);
    padding-top:12px; }
  .feedback.open { display:block; }
  .feedback .fb-head { font-size:11px; letter-spacing:1.6px; text-transform:uppercase;
    color:var(--amber); margin-bottom:8px; }
  .feedback .fb-q { font-size:13px; color:var(--fg); line-height:1.55;
    padding:4px 0 4px 14px; position:relative; }
  .feedback .fb-q::before { content:'?'; position:absolute; left:0; color:var(--cyan); }
  .feedback textarea { width:100%; box-sizing:border-box; min-height:74px; resize:vertical;
    margin-top:8px; background:var(--card2); color:var(--fg); border:1px solid var(--line);
    border-radius:10px; padding:9px 11px; font:inherit; font-size:13px; outline:none; }
  .feedback textarea:focus { border-color:var(--green); box-shadow:0 0 10px rgba(47,227,160,.2); }
  .feedback .fb-hint { font-size:11px; color:var(--muted); margin-top:4px; }
  .feedback .row { display:flex; gap:8px; justify-content:flex-end; margin-top:10px; }
  .feedback .thinking { font-size:12.5px; color:var(--muted); padding:6px 0; }

  /* Inference investigations: persistent, bounded conversations. */
  .investigate-box { margin:0 0 18px; padding:16px; border:1px solid var(--line);
    border-radius:14px; background:linear-gradient(135deg,rgba(11,37,27,.92),rgba(4,18,13,.92)); }
  .investigate-box .title { color:var(--green); font-size:13px; font-weight:700;
    letter-spacing:.4px; margin-bottom:5px; }
  .investigate-box .hint { margin:0 0 10px; }
  .investigate-row { display:flex; gap:9px; align-items:stretch; }
  .investigate-row textarea { flex:1; min-height:48px; resize:vertical; background:var(--card2);
    color:var(--fg); border:1px solid var(--line); border-radius:10px; padding:10px 12px;
    font:inherit; outline:none; }
  .investigate-row textarea:focus { border-color:var(--green); }
  .inquiry-resume { display:flex; flex-wrap:wrap; gap:7px; margin-top:10px; }
  .inquiry-drawer { display:none; position:fixed; z-index:80; right:0; top:0; bottom:0;
    width:min(560px,94vw); background:rgba(4,18,13,.98); border-left:1px solid var(--line);
    box-shadow:-18px 0 50px rgba(0,0,0,.55); padding:20px; box-sizing:border-box;
    overflow:auto; }
  .inquiry-drawer.open { display:block; }
  .inquiry-head { display:flex; justify-content:space-between; gap:12px; align-items:flex-start;
    border-bottom:1px solid var(--line2); padding-bottom:13px; margin-bottom:14px; }
  .inquiry-kind { font-size:10px; color:var(--cyan); text-transform:uppercase;
    letter-spacing:1.5px; }
  .inquiry-prompt { font-size:16px; color:var(--fg); margin-top:5px; line-height:1.45; }
  .inquiry-messages { display:flex; flex-direction:column; gap:10px; margin:12px 0; }
  .inquiry-msg { max-width:88%; padding:10px 12px; border-radius:12px; line-height:1.55;
    font-size:13px; white-space:pre-wrap; }
  .inquiry-msg.assistant { align-self:flex-start; background:rgba(30,87,61,.34);
    border:1px solid var(--line2); }
  .inquiry-msg.user { align-self:flex-end; background:rgba(47,227,160,.13);
    border:1px solid rgba(47,227,160,.25); }
  .inquiry-draft { border:1px solid var(--line); border-radius:12px; padding:12px;
    background:rgba(7,28,19,.72); margin:14px 0; }
  .inquiry-draft label { display:block; color:var(--muted); font-size:10px;
    text-transform:uppercase; letter-spacing:1.4px; margin-bottom:7px; }
  .inquiry-draft textarea, .inquiry-reply { width:100%; box-sizing:border-box; min-height:72px;
    resize:vertical; background:var(--card2); color:var(--fg); border:1px solid var(--line);
    border-radius:10px; padding:10px 11px; font:inherit; outline:none; }
  .inquiry-confidence { color:var(--muted); font-size:11px; margin-top:6px; }
  .inquiry-send, .inquiry-decisions { display:flex; flex-wrap:wrap; gap:8px;
    justify-content:flex-end; margin-top:9px; }

  h2.section { font-size:12px; letter-spacing:1.8px; text-transform:uppercase;
    color:var(--muted); margin:26px 0 10px; display:flex; align-items:center; gap:10px; }
  h2.section::after { content:''; flex:1; height:1px; background:var(--line2); }
  h2.section .accent-word { color:var(--cyan); }

  .forming-row { display:flex; align-items:center; gap:14px; padding:9px 6px;
    font-size:13px; background:rgba(4,15,10,.25); border-radius:9px; margin:5px 0; }
  .forming-row .theme-name { width:200px; color:var(--fg); overflow:hidden;
    text-overflow:ellipsis; white-space:nowrap; }
  .forming-row .track { flex:1; height:7px; border-radius:4px;
    background:rgba(112,214,158,.14); overflow:hidden; position:relative; }
  .forming-row .fill { height:100%; border-radius:4px;
    background:linear-gradient(90deg,#5b7b68,#53e7c0); transition:width .5s ease;
    box-shadow:0 0 8px rgba(83,231,192,.35); }
  .forming-row .pct { width:46px; text-align:right; color:var(--muted); font-size:12px; }
  .forming-row .ev { width:78px; text-align:right; color:var(--muted); font-size:11.5px; }

  .belief { display:flex; align-items:baseline; gap:10px; padding:9px 6px;
    font-size:13.5px; line-height:1.5; background:rgba(4,15,10,.25); border-radius:9px; margin:5px 0; }
  .belief .star { color:var(--amber); text-shadow:0 0 10px rgba(255,209,102,.6);
    width:18px; flex:none; }
  .belief .conf { margin-left:auto; color:var(--muted); font-size:12px; flex:none; }
  .belief.core .text { color:#fff; }

  /* clarify */
  .clar-value { font-size:13.5px; color:var(--muted); line-height:1.55; padding:9px 12px;
    background:var(--card2); border-radius:10px; margin-bottom:12px; }
  .clar-question { font-size:15.5px; font-weight:600; line-height:1.45; margin-bottom:10px; }
  .clar-question::before { content:'? '; color:var(--cyan); }
  .hedge-chip { color:var(--amber); border-color:rgba(255,209,102,.4); }
  .resolved-row { display:flex; align-items:flex-start; gap:10px; padding:9px 6px;
    font-size:13px; line-height:1.5; background:rgba(4,15,10,.3); border-radius:9px; margin:5px 0; }
  .resolved-row .rr-body { flex:1; min-width:0; white-space:pre-wrap; overflow-wrap:anywhere; }
  .resolved-row .rr-q { color:var(--fg); }
  .resolved-row .rr-a { color:var(--muted); margin-top:2px; }
  .resolved-row .rr-tag { flex:none; font-size:10.5px; letter-spacing:1px; text-transform:uppercase;
    border-radius:20px; padding:2px 10px; border:1px solid var(--line2); color:var(--muted); }
  .resolved-row .rr-tag.answered { color:var(--green); border-color:rgba(47,227,160,.45); }
  .resolved-row .rr-tag.auto { color:var(--cyan); border-color:rgba(83,231,192,.4); }
  .clar-select { width:15px; height:15px; margin-right:2px; accent-color:var(--cyan); cursor:pointer; }

  /* curiosity */
  .cur-head { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:8px; }
  .cur-label { font-size:15.5px; font-weight:700; }
  .cur-directive { font-size:12.5px; color:var(--muted); line-height:1.5; margin:2px 0 14px; }
  .cur-attachments { display:flex; gap:6px; flex-wrap:wrap; margin:0 0 12px; }
  .cur-attach-chip { border:1px solid rgba(83,231,192,.28); border-radius:20px;
    padding:3px 9px; color:var(--muted); font-size:11px; background:rgba(83,231,192,.05); }
  .cur-attach-chip.soul { color:var(--cyan); }
  .cur-star { cursor:pointer; color:var(--grey); font-size:16px; user-select:none; }
  .cur-star.on { color:var(--amber); text-shadow:0 0 10px rgba(255,209,102,.6); }
  .cur-status-chip { font-size:10.5px; letter-spacing:1px; text-transform:uppercase;
    border:1px solid var(--line2); border-radius:20px; padding:2px 10px; color:var(--muted); }
  .cur-status-chip.paused { color:var(--amber); border-color:rgba(255,209,102,.4); }
  .cur-item { background:linear-gradient(135deg,rgba(4,16,10,.72),rgba(6,22,14,.48));
    border:1px solid rgba(112,214,158,.14); border-radius:14px; padding:12px 13px; margin-bottom:12px; }
  .cur-item .cur-text { font-size:14px; line-height:1.45; margin-bottom:6px; font-weight:700; }
  .cur-conf { font-size:11px; color:var(--muted); }
  .cur-loop-panel { border:1px solid rgba(83,231,192,.28); border-radius:12px;
    padding:13px 14px; margin:12px 0; background:linear-gradient(135deg,rgba(83,231,192,.08),rgba(5,18,11,.58)); }
  .cur-loop-panel pre { margin:8px 0 10px; white-space:pre-wrap; overflow-wrap:anywhere;
    font:12px/1.55 Consolas,monospace; color:#dcebe2; border:1px solid rgba(83,231,192,.12);
    border-radius:10px; padding:10px; background:rgba(2,10,6,.34); }
  .cur-loop-load { height:6px; border-radius:4px; overflow:hidden;
    background:rgba(112,214,158,.12); margin:10px 0 4px; }
  .cur-loop-load i { display:block; height:100%; width:0;
    background:linear-gradient(90deg,#2fe3a0,#53e7c0); animation:cur-loop-fill 1s ease forwards; }
  @keyframes cur-loop-fill { to { width:100%; } }
  .cur-answer-tools,.goal-answer-tools { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
    gap:7px; margin-top:8px; }
  .cur-answer-tools label,.goal-answer-tools label { color:var(--muted); font-size:11px; display:grid; gap:4px; }
  .cur-answer-tools select,.goal-answer-tools select { padding:6px 8px; font-size:12px; }
  .choice-pills { display:flex; flex-wrap:wrap; gap:7px; margin:7px 0 4px; }
  .choice-pills button { padding:6px 10px; border-radius:999px; font-size:12px; }
  .choice-pills button.active { border-color:var(--green); color:var(--cyan); background:rgba(47,227,160,.12); }
  .quick-type { font-size:10px; letter-spacing:1.2px; text-transform:uppercase; color:var(--cyan);
    margin-bottom:3px; }
  .cur-sub { font-size:10px; letter-spacing:1.6px; text-transform:uppercase;
    color:var(--cyan); margin:14px 0 8px; }
  .cur-switcher { border:1px solid var(--line); border-radius:14px; padding:10px 12px;
    margin:14px 0 0; background:rgba(5,18,11,.38); }
  .cur-board-tools { display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:10px; }
  .cur-board-search { flex:1; min-width:220px; max-width:420px; }
  .cur-board-filters { display:flex; gap:6px; flex-wrap:wrap; }
  .cur-filter { padding:6px 10px; border-radius:999px; font-size:12px; }
  .cur-filter.active { color:#032118; font-weight:700; background:linear-gradient(90deg,#2fe3a0,#53e7c0);
    border-color:transparent; box-shadow:0 0 12px rgba(47,227,160,.22); }
  .cur-board-count { color:var(--muted); font-size:11.5px; margin-left:auto; }
  .cur-show-more { display:block; margin:10px auto 0; padding:6px 12px; border-radius:999px; font-size:12px; }
  .cur-switch-head { display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:8px; }
  .cur-switch-head select { min-width:220px; max-width:420px; background:var(--card2);
    border:1px solid var(--line); border-radius:9px; color:var(--fg); padding:7px 10px;
    font:inherit; font-size:12.5px; }
  .cur-tabs { display:flex; gap:6px; flex-wrap:wrap; }
  .cur-tab { border-radius:20px; padding:6px 10px; font-size:12px; }
  .cur-tab.active { color:var(--cyan); border-color:rgba(83,231,192,.55);
    background:rgba(83,231,192,.1); }
  .cur-card-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
    gap:10px; }
  .cur-card-tile { cursor:pointer; text-align:left; background:linear-gradient(135deg,
    rgba(8,24,16,.5),rgba(4,13,10,.36)); border:1px solid var(--line); border-radius:14px;
    padding:12px 14px; transition:border-color .15s ease,box-shadow .15s ease;
    background-size:cover; background-position:center; overflow:hidden; }
  .cur-card-tile:hover { border-color:rgba(83,231,192,.4); }
  .cur-card-tile.active { border-color:rgba(83,231,192,.65); background:rgba(83,231,192,.08);
    box-shadow:0 0 0 1px rgba(83,231,192,.3) inset; }
  .cur-card-tile.paused { opacity:.72; }
  .cur-card-tile-head { display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
  .cur-card-star { color:var(--amber); font-size:13px; }
  .cur-card-label { font-size:14px; font-weight:700; }
  .cur-card-tile-meta { margin-top:6px; font-size:11.5px; color:var(--muted); }
  .resolved-row .rr-tag.tried { color:var(--green); border-color:rgba(47,227,160,.45); }
  .resolved-row .rr-tag.nh-light { color:var(--amber); border-color:rgba(255,209,102,.45); }
  .resolved-row .rr-tag.nh-heavy { color:var(--red); border-color:rgba(255,107,138,.45); }
  .metric-panel { border:1px solid rgba(112,214,158,.18); border-radius:12px;
    padding:12px; margin:12px 0 16px; background:rgba(7,27,17,.55); }
  .metric-collapsible summary { cursor:pointer; list-style:none; }
  .metric-collapsible summary::-webkit-details-marker { display:none; }
  .metric-summary { display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
  .metric-summary-title { color:var(--cyan); font-size:10px; letter-spacing:1.6px;
    text-transform:uppercase; }
  .metric-summary-title::before { content:'▸'; color:var(--muted); margin-right:7px; }
  .metric-collapsible[open] .metric-summary-title::before { content:'▾'; color:var(--cyan); }
  .metric-summary-stats { display:flex; gap:8px; flex-wrap:wrap; color:var(--muted); font-size:11px; }
  .metric-summary-stats span { border:1px solid var(--line2); border-radius:20px; padding:2px 8px; }
  .metric-body { margin-top:12px; }
  .metric-top { display:grid; grid-template-columns:repeat(4,minmax(90px,1fr)); gap:8px; }
  .metric-stat { padding:9px; border-radius:9px; background:rgba(112,214,158,.07); }
  .metric-stat b { display:block; color:var(--cyan); font-size:17px; }
  .metric-stat span { color:var(--muted); font-size:10px; text-transform:uppercase; letter-spacing:1px; }
  .metric-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:8px 14px; }
  .metric-field { display:grid; grid-template-columns:1fr 92px minmax(90px,auto); gap:6px 8px; align-items:center;
    font-size:12px; color:var(--muted); }
  .metric-field select { width:92px; padding:6px 8px; }
  .metric-rating { color:var(--green); font-size:11px; white-space:nowrap; }
  .metric-edit { display:grid; grid-template-columns:minmax(110px,1fr) 190px 2fr; gap:7px;
    margin:7px 0; align-items:center; }
  .metric-importance-wrap { display:flex; align-items:center; gap:7px; }
  .metric-importance-wrap select { width:82px; padding:6px 8px; }
  .metric-importance-label { color:var(--muted); font-size:10.5px; min-width:62px; }
  .metric-edit input, .metric-note { background:var(--card2); border:1px solid var(--line);
    color:var(--fg); border-radius:8px; padding:7px; font:inherit; font-size:12px; }
  .metric-progress { height:5px; border-radius:4px; background:rgba(255,255,255,.1); overflow:hidden; }
  .metric-progress i { display:block; height:100%; background:var(--green); }
  .metric-log { color:var(--muted); font-size:11px; margin-top:8px; }
  .metric-preview { display:block; width:100%; max-width:900px; margin:12px auto 4px;
    border:1px solid var(--line); border-radius:12px; box-shadow:0 8px 24px rgba(0,0,0,.3); }
  .metric-publish { display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-top:10px; }
  .metric-bars { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:8px 14px; margin:10px 0; }
  .metric-bar-row { padding:8px 10px; border-radius:9px; background:rgba(3,15,9,.34); }
  .metric-bar-head { display:flex; justify-content:space-between; gap:8px; font-size:11px; color:var(--muted); }

  /* goals */
  #view-goals > .toolbar,#view-goals > .hint,#view-goals > .goal-ai-overview,
  #view-goals > .goal-layout,#view-goals > .growth-map-main,#view-goals > .goal-list-view {
    width:100%; max-width:none; margin-left:0; margin-right:0; }
  .goal-layout { display:grid; grid-template-columns:minmax(280px,360px) minmax(0,1fr);
    gap:16px; min-height:calc(100vh - 86px); align-items:start; }
  .goal-list-view[hidden],.growth-map-main[hidden] { display:none !important; }
  .growth-view-toggle { margin-left:auto; display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
  .growth-view-toggle button.active { border-color:var(--green); background:rgba(47,227,160,.14);
    color:var(--cyan); box-shadow:0 0 14px rgba(47,227,160,.12); }
  .goal-pane { border:1px solid var(--line); border-radius:14px; background:rgba(5,18,11,.42);
    padding:12px; min-width:0; overflow:visible; }
  #goal-tree { position:sticky; top:0; max-height:calc(100vh - 86px); overflow:auto; }
  .goal-tree-row { display:flex; align-items:center; gap:6px; padding:7px 8px; border-radius:8px;
    cursor:pointer; font-size:13px; margin:2px 0; }
  .goal-tree-row:hover,.goal-tree-row.selected { background:rgba(83,231,192,.1); }
  .goal-tree-row .twist { width:18px; height:20px; color:var(--muted); display:inline-flex;
    align-items:center; justify-content:center; border-radius:5px; }
  .goal-tree-row .twist.has-children:hover { color:var(--cyan); background:rgba(83,231,192,.09); }
  .goal-tree-row .goal-icon { color:var(--cyan); width:17px; }
  .goal-tree-row.collapsed .goal-title::after { content:' …'; color:var(--muted); }
  .goal-tree-row.completed .goal-title { text-decoration:line-through; opacity:.65; }
  .goal-tree-row.paused { opacity:.55; }
  .goal-detail input,.goal-detail textarea,.goal-detail select,.planner-draft {
    width:100%; box-sizing:border-box; background:var(--card2); border:1px solid var(--line);
    color:var(--fg); border-radius:9px; padding:8px 10px; font:inherit; margin-top:5px; }
  .goal-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .goal-field { color:var(--muted); font-size:11px; }
  .goal-progress { margin:12px 0; }
  .goal-progress-head { display:flex; justify-content:space-between; font-size:12px; color:var(--muted); }
  .planner-drawer { position:fixed; right:0; top:0; bottom:0; width:min(520px,88vw); z-index:45;
    background:#07130d; border-left:1px solid var(--line); box-shadow:-14px 0 40px rgba(0,0,0,.5);
    padding:22px; overflow:auto; display:none; }
  .planner-drawer.open { display:block; }
  .soul-calibration-drawer { left:50%; right:auto; top:5vh; bottom:5vh; width:min(920px,92vw);
    transform:translateX(-50%); border:1px solid var(--line); border-radius:20px;
    box-shadow:0 24px 80px rgba(0,0,0,.62); }
  .planner-msg { padding:9px 11px; border-radius:10px; margin:8px 0; white-space:pre-wrap; line-height:1.5; }
  .planner-msg.assistant { background:rgba(83,231,192,.08); }
  .planner-msg.user { background:rgba(255,255,255,.06); margin-left:28px; }
  .goal-chip { display:inline-block; font-size:10px; padding:2px 8px; border:1px solid var(--line2);
    border-radius:20px; color:var(--muted); margin:2px; }
  .goal-add-wrap { position:relative; display:inline-block; }
  .goal-add-menu { position:absolute; top:calc(100% + 4px); left:0; z-index:6; display:none; min-width:140px;
    background:rgba(5,20,12,.97); border:1px solid var(--line2); border-radius:10px; padding:4px; }
  .goal-add-menu.open { display:block; }
  .goal-add-menu button { display:block; width:100%; text-align:left; background:none; border:none;
    color:var(--fg); padding:7px 10px; border-radius:7px; cursor:pointer; font-size:12px; }
  .goal-add-menu button:hover { background:rgba(83,231,192,.12); color:var(--cyan); }
  .goal-rollup-chip { cursor:pointer; margin:2px 4px 2px 0; transition:color .15s,border-color .15s; }
  .goal-rollup-chip:hover { color:var(--cyan); border-color:var(--cyan); }
  .goal-focus-leaf span[data-open] { cursor:pointer; }
  .goal-focus-leaf span[data-open]:hover b { text-decoration:underline; color:var(--cyan); }
  .goal-ai-overview { display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:8px;
    margin:10px 0 14px; }
  .goal-ai-stat { padding:9px 11px; border:1px solid var(--line2); border-radius:10px;
    background:rgba(83,231,192,.045); }
  .goal-ai-stat.actionable { cursor:pointer; transition:border-color .15s,background .15s,transform .15s; }
  .goal-ai-stat.actionable:hover,.goal-ai-stat.actionable:focus { outline:none;
    border-color:var(--green); background:rgba(83,231,192,.1); transform:translateY(-1px); }
  .goal-ai-stat.actionable::after { content:'open next →'; display:block; color:var(--cyan);
    font-size:9px; margin-top:5px; text-transform:uppercase; letter-spacing:.7px; }
  .goal-ai-stat b { display:block; color:var(--cyan); font-size:17px; }
  .goal-ai-stat span { color:var(--muted); font-size:10px; text-transform:uppercase; }
  .agent-panel { margin-top:14px; border-top:1px solid var(--line); padding-top:12px; }
  .health-chip { font-size:10px; letter-spacing:1px; text-transform:uppercase; border-radius:20px;
    padding:3px 9px; border:1px solid var(--line2); }
  .health-chip.on-track { color:var(--green); border-color:rgba(47,227,160,.45); }
  .health-chip.needs-attention { color:var(--amber); border-color:rgba(255,209,102,.45); }
  .health-chip.blocked { color:var(--red); border-color:rgba(255,107,138,.5); }
  .agent-brief { line-height:1.55; padding:10px; background:rgba(4,16,10,.5); border-radius:10px; }
  .agent-proposal { border:1px solid rgba(255,209,102,.25); border-radius:10px;
    padding:10px; margin:8px 0; background:rgba(255,209,102,.04); }
  .agent-proposal pre { max-width:100%; margin:10px 0; white-space:pre-wrap;
    overflow-wrap:anywhere; word-break:break-word; color:var(--fg); }
  .agent-question textarea { width:100%; box-sizing:border-box; margin-top:7px; }
  .goal-next-action { border:1px solid rgba(47,227,160,.38); border-radius:14px; padding:12px 13px;
    margin:10px 0 12px; background:linear-gradient(135deg,rgba(47,227,160,.12),rgba(4,18,11,.58));
    box-shadow:0 0 22px rgba(47,227,160,.08); }
  .goal-next-action b { display:block; color:var(--cyan); text-transform:uppercase;
    letter-spacing:1.4px; font-size:10px; margin-bottom:5px; }
  .goal-next-action span { display:block; color:var(--fg); line-height:1.45; overflow-wrap:anywhere; }
  .growth-map-overlay { position:fixed; inset:0; z-index:50; display:none; padding:24px;
    background:rgba(1,7,4,.78); }
  .growth-map-overlay.open { display:block; }
  .growth-map-shell { width:min(1260px,96vw); max-height:92vh; overflow:auto; margin:0 auto;
    border:1px solid var(--line); border-radius:20px; background:rgba(3,13,8,.9);
    box-shadow:0 24px 80px rgba(0,0,0,.62); padding:18px; }
  .growth-map-head { position:sticky; top:0; z-index:2; background:rgba(3,13,8,.94);
    padding-bottom:10px; border-bottom:1px solid var(--line); }
  .growth-map-summary { display:grid; grid-template-columns:minmax(0,1.5fr) minmax(240px,.8fr);
    gap:12px; margin:12px 0; }
  .growth-map-summary-card { border:1px solid var(--line2); border-radius:14px;
    background:rgba(5,22,14,.52); padding:12px 14px; min-width:0; }
  .growth-map-summary-card b { display:block; color:var(--cyan); font-size:15px; margin-bottom:5px; }
  .growth-map-summary-card span { color:var(--muted); line-height:1.5; }
  .growth-map-main .growth-map-summary { margin-top:2px; }
  .growth-map-workspace { display:grid; grid-template-columns:minmax(0,1.45fr) minmax(320px,.7fr);
    gap:14px; align-items:start; min-height:calc(100vh - 126px); }
  .growth-map-stage { min-width:0; }
  .growth-map-main .growth-map-tree { min-height:max(720px,calc(100vh - 126px)); }
  .growth-map-main .growth-constellation-svg { height:max(720px,calc(100vh - 126px)); min-height:720px; }
  .goal-focus-panel { position:sticky; top:8px; max-height:calc(100vh - 52px); overflow:auto; }
  .goal-focus-panel .cur-head { align-items:flex-start; }
  .goal-focus-title { font-size:18px; line-height:1.25; font-weight:800; color:var(--fg); }
  .goal-focus-path { color:var(--muted); font-size:11px; line-height:1.45; margin:4px 0 8px; }
  .goal-focus-desc { line-height:1.55; color:var(--fg); background:rgba(4,16,10,.48);
    border:1px solid rgba(83,231,192,.1); border-radius:12px; padding:10px; margin:10px 0; }
  .goal-recap-card { border:1px solid rgba(83,231,192,.2); border-radius:14px; padding:12px;
    margin:12px 0; background:linear-gradient(135deg,rgba(83,231,192,.09),rgba(2,13,8,.62)); }
  .goal-recap-card .cur-sub { margin-top:0; }
  .goal-recap-grid { display:grid; gap:8px; }
  .goal-recap-item { padding:8px 9px; border:1px solid rgba(83,231,192,.1);
    border-radius:10px; background:rgba(2,13,8,.44); }
  .goal-recap-item b { display:block; color:var(--cyan); font-size:10px; letter-spacing:1.2px;
    text-transform:uppercase; margin-bottom:4px; }
  .goal-recap-item span { display:block; color:var(--fg); line-height:1.45; overflow-wrap:anywhere; }
  .goal-recap-item ul { margin:0; padding-left:18px; color:var(--fg); line-height:1.45; overflow-wrap:anywhere; }
  .goal-recap-item li { margin:4px 0; }
  .goal-recap-sources { display:flex; flex-wrap:wrap; gap:5px; margin-top:8px; }
  .goal-recap-card details { margin-top:8px; }
  .goal-recap-card summary { color:var(--muted); cursor:pointer; font-size:12px; }
  .goal-focus-mini { display:grid; gap:7px; margin:10px 0; }
  .goal-focus-leaf { display:flex; gap:8px; align-items:flex-start; padding:8px 9px;
    border:1px solid rgba(83,231,192,.12); border-radius:10px; background:rgba(83,231,192,.04);
    line-height:1.35; }
  .goal-focus-leaf input { margin-top:2px; }
  .goal-focus-muted { color:var(--muted); font-size:12px; line-height:1.45; }
  .goal-question-card { border:1px solid rgba(83,231,192,.16); border-radius:12px;
    background:rgba(5,20,13,.54); padding:10px; margin:8px 0; }
  .goal-question-card b { display:block; color:var(--fg); line-height:1.35; margin-bottom:5px; }
  .goal-question-card textarea { width:100%; box-sizing:border-box; min-height:74px; resize:vertical;
    background:rgba(2,12,7,.7); border:1px solid var(--line); border-radius:10px; color:var(--fg);
    padding:9px 10px; font:inherit; margin-top:8px; }
  .goal-question-hint { color:var(--muted); font-size:12px; line-height:1.45; }
  .goal-question-options { display:flex; flex-wrap:wrap; gap:5px; margin-top:7px; }
  .goal-question-options span { border:1px solid rgba(83,231,192,.16); border-radius:999px;
    padding:3px 7px; color:var(--muted); font-size:11px; background:rgba(83,231,192,.045); }
  .goal-full-note { margin:10px 0; border:1px solid rgba(83,231,192,.12); border-radius:12px;
    background:rgba(3,13,8,.42); padding:8px 10px; }
  .goal-full-note summary { cursor:pointer; color:var(--cyan); font-size:12px; letter-spacing:.6px;
    text-transform:uppercase; }
  .goal-full-note div { color:var(--muted); line-height:1.55; margin-top:8px; white-space:pre-wrap; }
  .goal-ai-strip { display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin:10px 0 12px;
    border:1px solid var(--line); border-radius:14px; padding:10px 12px; background:rgba(5,22,14,.42); }
  .goal-ai-strip .strip-copy { color:var(--muted); line-height:1.4; flex:1; min-width:240px; }
  .goal-ai-strip b { color:var(--cyan); }
  .goal-ai-strip button { padding:7px 11px; }
  .growth-map-tree { position:relative; min-height:620px; border:1px solid var(--line);
    border-radius:18px; overflow:hidden; background:
      radial-gradient(circle at 50% 48%, rgba(47,227,160,.12), transparent 32%),
      radial-gradient(circle at 22% 18%, rgba(83,231,192,.09), transparent 28%),
      rgba(1,11,7,.62); cursor:grab; touch-action:none; }
  .growth-map-tree.dragging { cursor:grabbing; }
  .growth-map-tree::before { content:''; position:absolute; inset:0; pointer-events:none;
    background-image:radial-gradient(circle, rgba(213,255,238,.38) 0 1px, transparent 1.5px);
    background-size:78px 68px; opacity:.22; }
  .growth-constellation-svg { position:relative; z-index:1; display:block; width:100%;
    height:min(68vh,720px); min-height:620px; }
  .constellation-edge { stroke:rgba(133,255,216,.32); stroke-width:1.2; }
  .constellation-edge.selected { stroke:rgba(83,231,192,.78); stroke-width:2; }
  .constellation-node { cursor:grab; outline:none; }
  .constellation-node.dragging-node { cursor:grabbing; }
  .constellation-node circle.core { fill:rgba(230,255,246,.9); stroke:rgba(83,231,192,.9); stroke-width:1.4; }
  .constellation-node circle.glow { fill:rgba(83,231,192,.14); }
  .constellation-node.umbrella circle.core { fill:rgba(244,255,218,.96); stroke:rgba(214,255,131,.96); }
  .constellation-node.umbrella circle.glow { fill:rgba(214,255,131,.18); }
  .constellation-node.overgoal circle.core { fill:rgba(126,226,255,.92); stroke:rgba(183,245,255,.98); }
  .constellation-node.overgoal circle.glow { fill:rgba(126,226,255,.16); }
  .constellation-node.subgoal circle.core { fill:rgba(184,143,255,.9); stroke:rgba(222,202,255,.98); }
  .constellation-node.subgoal circle.glow { fill:rgba(184,143,255,.14); }
  .constellation-node.task circle.core { fill:rgba(92,231,151,.86); stroke:rgba(192,255,217,.95); }
  .constellation-node.task circle.glow { fill:rgba(92,231,151,.12); }
  .constellation-node text { fill:rgba(227,255,242,.9); font-size:12px; font-weight:700;
    paint-order:stroke; stroke:rgba(1,9,5,.88); stroke-width:4px; stroke-linejoin:round; }
  .constellation-node.task text { font-size:10.5px; font-weight:600; fill:rgba(211,238,226,.78); }
  .constellation-node.paused,.constellation-node.completed { opacity:.58; }
  .constellation-node.selected circle.glow { fill:rgba(47,227,160,.28); }
  .constellation-node.selected circle.core { fill:var(--cyan); stroke:white; stroke-width:2; }
  .constellation-node.dragging-node circle.core { stroke:white; stroke-width:2.6; }
  .constellation-node.needs-care circle.halo { fill:none; stroke:rgba(255,209,102,.62); stroke-width:2;
    stroke-dasharray:4 5; }
  .constellation-node:hover circle.core { stroke:white; stroke-width:2; }
  .constellation-legend { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; color:var(--muted);
    font-size:11px; }
  .constellation-legend span { border:1px solid var(--line2); border-radius:20px; padding:4px 9px;
    background:rgba(83,231,192,.045); }
  @media(max-width:960px){ .growth-map-workspace{grid-template-columns:1fr}.goal-focus-panel{position:relative;max-height:none} }
  @media(max-width:760px){ .growth-map-summary{grid-template-columns:1fr}.growth-map-tree{min-height:520px}
    .growth-constellation-svg{min-height:520px} }
  .goal-edit-drawer { width:min(560px,90vw); }
  .goal-focus { animation:goal-focus 1.5s ease; }
  @keyframes goal-focus { 0%,100%{box-shadow:none} 30%{box-shadow:0 0 0 2px var(--green),0 0 22px rgba(47,227,160,.42)} }
  @media(max-width:760px){ .goal-layout{grid-template-columns:1fr}.goal-pane{min-height:220px} }
  #clar-bulk-text { flex:1; min-width:200px; background:var(--card2); border:1px solid var(--line);
    border-radius:20px; color:var(--fg); padding:8px 16px; font:inherit; font-size:13px; outline:none; }
  #clar-bulk-text:focus { border-color:var(--green); box-shadow:0 0 10px rgba(47,227,160,.2); }

  /* memory view */
  #mem-search { flex:1; min-width:200px; max-width:380px; background:var(--card2);
    border:1px solid var(--line); border-radius:20px; color:var(--fg);
    padding:8px 16px; font:inherit; font-size:13px; outline:none; }
  #mem-search:focus { border-color:var(--green); box-shadow:0 0 10px rgba(47,227,160,.2); }
  .toggle { display:flex; align-items:center; gap:8px; font-size:12.5px;
    color:var(--muted); cursor:pointer; user-select:none; }
  .toggle .sw { width:34px; height:18px; border-radius:10px; background:rgba(112,214,158,.16);
    border:1px solid var(--line); position:relative; transition:background .18s; }
  .toggle .sw::after { content:''; position:absolute; top:2px; left:2px; width:12px; height:12px;
    border-radius:50%; background:#91b5a0; transition:all .18s; }
  .toggle.on .sw { background:rgba(47,227,160,.3); }
  .toggle.on .sw::after { left:18px; background:var(--cyan); box-shadow:0 0 8px rgba(83,231,192,.65); }
  #mem-count { font-size:12px; color:var(--muted); margin-left:auto; }

  .cat { background:linear-gradient(135deg,rgba(8,24,16,.48),rgba(4,13,10,.34));
    border:1px solid var(--line); border-radius:14px; margin-bottom:12px; overflow:hidden;
    box-shadow:0 6px 20px rgba(0,0,0,.26); -webkit-backdrop-filter:blur(7px); backdrop-filter:blur(7px); }
  .cat > .head { display:flex; align-items:center; gap:10px; padding:11px 16px;
    cursor:pointer; user-select:none; font-weight:600; font-size:13.5px; }
  .cat > .head:hover { background:rgba(24,59,38,.3); }
  .cat > .head .n { color:var(--muted); font-weight:400; font-size:12px; }
  .cat > .head .arrow { margin-left:auto; color:var(--muted); font-size:11px;
    transition:transform .18s; }
  .cat.closed > .head .arrow { transform:rotate(-90deg); }
  .cat.closed > .facts { display:none; }
  .fact { display:flex; gap:14px; padding:9px 16px; border-top:1px solid var(--line2);
    font-size:13px; line-height:1.5; background:rgba(3,13,8,.22); }
  .fact .attr { width:210px; flex:none; color:var(--muted); overflow:hidden;
    text-overflow:ellipsis; }
  .fact .val { flex:1; white-space:pre-wrap; word-break:break-word; }
  .fact .status { flex:none; font-size:10.5px; letter-spacing:1px; text-transform:uppercase;
    color:var(--grey); align-self:center; }
  .fact.superseded { opacity:.45; }
  .fact.superseded .val { text-decoration:line-through; text-decoration-color:rgba(255,255,255,.35); }
  .fact .dates { flex:none; color:var(--grey); font-size:11px; align-self:center; }
  .fact .forget { flex:none; align-self:center; padding:3px 9px; border-radius:8px;
    font-size:10.5px; color:var(--red); border-color:rgba(255,107,138,.3);
    background:rgba(255,107,138,.05); box-shadow:none; opacity:.72; }
  .fact .forget:hover { opacity:1; background:rgba(255,107,138,.14);
    border-color:rgba(255,107,138,.55); }

  /* timeline */
  .tl-month { font-size:12px; letter-spacing:1.8px; text-transform:uppercase;
    color:var(--cyan); margin:22px 0 8px; display:flex; align-items:center; gap:10px; }
  .tl-month::after { content:''; flex:1; height:1px; background:var(--line2); }
  .tl-row { display:flex; gap:12px; padding:9px 10px 9px 16px; margin:5px 0; font-size:13px;
    line-height:1.55; border-left:2px solid var(--line); border-radius:0 9px 9px 0;
    background:rgba(4,15,10,.3); position:relative; }
  .tl-row::before { content:''; position:absolute; left:-5px; top:14px; width:8px;
    height:8px; border-radius:50%; background:var(--cyan);
    box-shadow:0 0 8px rgba(83,231,192,.55); }
  .tl-row.superseded { opacity:.5; }
  .tl-row.superseded::before { background:var(--grey); box-shadow:none; }
  .tl-row .tl-date { flex:none; width:78px; color:var(--muted); font-size:12px; }
  .tl-row .tl-cat { flex:none; font-size:10.5px; letter-spacing:1px;
    text-transform:uppercase; color:var(--cyan); align-self:flex-start;
    border:1px solid var(--line2); border-radius:20px; padding:2px 9px; margin-top:1px; }
  .tl-row .tl-body { flex:1; word-break:break-word; }
  .tl-row .tl-attr { color:var(--muted); }
  .tl-row.superseded .tl-val { text-decoration:line-through;
    text-decoration-color:rgba(255,255,255,.35); }
  .tl-row .tl-until { color:var(--amber); font-size:11.5px; }

  /* import / drop zone */
  #dropzone { border:2px dashed var(--line); border-radius:16px; padding:44px 20px;
    text-align:center; font-size:15px; color:var(--muted); transition:all .18s ease;
    background:rgba(5,18,11,.34); cursor:default; -webkit-backdrop-filter:blur(6px); backdrop-filter:blur(6px); }
  #dropzone span { font-size:11.5px; opacity:.8; }
  #dropzone.hover { border-color:var(--cyan); color:var(--cyan);
    background:rgba(83,231,192,.06); box-shadow:0 0 24px rgba(83,231,192,.15) inset; }
  .year-label { display:flex; align-items:center; gap:8px; font-size:12.5px; color:var(--muted); }
  #drop-year { width:82px; background:var(--card2); border:1px solid var(--line);
    border-radius:10px; color:var(--fg); padding:6px 10px; font:inherit; outline:none; }
  #drop-year:focus { border-color:var(--cyan); }
  #import-status { font-size:12px; color:var(--cyan); }
  .staged-row { display:flex; gap:12px; padding:8px 4px; border-bottom:1px solid var(--line2);
    font-size:13px; align-items:baseline; }
  .staged-row:last-child { border-bottom:none; }
  .staged-row .sf-name { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .staged-row .sf-meta { flex:none; color:var(--muted); font-size:12px; }
  .sf-status { flex:none; font-size:10.5px; letter-spacing:1px; text-transform:uppercase;
    border-radius:20px; padding:2px 10px; border:1px solid var(--line2); color:var(--muted); }
  .sf-status.imported { color:var(--green); border-color:rgba(47,227,160,.45); }
  .sf-status.changed { color:var(--amber); border-color:rgba(255,209,102,.45); }
  .sf-status.new { color:var(--cyan); border-color:rgba(83,231,192,.4); }
  .sf-warn { font-size:11.5px; color:var(--amber); padding:2px 4px 8px 18px;
    line-height:1.6; border-bottom:1px solid var(--line2); }
  .sf-remove { flex:none; width:22px; height:22px; border-radius:7px;
    border:1px solid var(--line2); background:none; color:var(--grey);
    font-size:11px; line-height:1; cursor:pointer; padding:0; }
  .sf-remove:hover { color:var(--red); border-color:rgba(255,107,138,.5);
    background:rgba(255,107,138,.08); }
  #import-result pre { margin:0; font:12px/1.6 Consolas,monospace; color:#d8e8df;
    white-space:pre-wrap; background:none; padding:0; }
  #view-timeline #tl-groups { max-height:calc(100vh - 150px); overflow:auto; padding-right:6px; }

  #toast { position:fixed; bottom:22px; left:50%; transform:translateX(-50%) translateY(80px);
    background:rgba(5,17,11,.95); border:1px solid var(--line); color:var(--fg);
    border-radius:12px; padding:10px 20px; font-size:13px; transition:transform .25s ease;
    box-shadow:0 8px 30px rgba(0,0,0,.5); z-index:50; max-width:70vw; }
  #toast.show { transform:translateX(-50%) translateY(0); }
  #toast.err { border-color:rgba(255,107,138,.6); color:var(--red); }
  #toast button { margin-left:12px; padding:5px 10px; border-radius:9px;
    border-color:rgba(83,231,192,.45); color:var(--green); background:rgba(47,227,160,.08); }
  .spin { display:inline-block; width:12px; height:12px; border:2px solid rgba(83,231,192,.3);
    border-top-color:var(--cyan); border-radius:50%; animation:spin .8s linear infinite;
    vertical-align:-2px; margin-right:6px; }
  @keyframes spin { to { transform:rotate(360deg); } }

  /* Onboarding (launch profile first run) */
  .onboard-overlay { position:fixed; inset:0; z-index:90; display:none; padding:24px;
    background:rgba(1,7,4,.86); -webkit-backdrop-filter:blur(4px); backdrop-filter:blur(4px); }
  .onboard-overlay.open { display:flex; align-items:center; justify-content:center; }
  .onboard-shell { width:min(560px,94vw); max-height:88vh; overflow:auto;
    border:1px solid var(--line); border-radius:20px; background:rgba(3,13,8,.96);
    box-shadow:0 24px 80px rgba(0,0,0,.62); padding:28px 30px; box-sizing:border-box; }
  .onboard-shell h1 { margin:0 0 6px; font-size:21px; color:var(--green);
    text-shadow:0 0 14px rgba(47,227,160,.4); }
  .onboard-shell .onboard-step-label { font-size:10px; letter-spacing:2px; text-transform:uppercase;
    color:var(--cyan); margin-bottom:10px; }
  .onboard-shell p.onboard-copy { color:var(--muted); line-height:1.6; font-size:13.5px; margin:0 0 16px; }
  .onboard-shell label { display:block; color:var(--muted); font-size:11px;
    text-transform:uppercase; letter-spacing:1.2px; margin:14px 0 6px; }
  .onboard-shell input, .onboard-shell textarea { width:100%; box-sizing:border-box; }
  .onboard-error { color:var(--red); font-size:12.5px; line-height:1.5; margin-top:10px; display:none; }
  .onboard-error.show { display:block; }
  .onboard-actions { display:flex; justify-content:space-between; align-items:center; gap:10px; margin-top:20px; }
  .onboard-skip { background:none; border:none; color:var(--muted); text-decoration:underline dotted;
    box-shadow:none; padding:8px 2px; }
  .onboard-dots { display:flex; gap:6px; margin-bottom:16px; }
  .onboard-dots span { width:7px; height:7px; border-radius:50%; background:rgba(112,214,158,.22); }
  .onboard-dots span.on { background:var(--green); box-shadow:0 0 8px rgba(47,227,160,.5); }
</style></head>
<body>
<div id="motes">
  <span style="left:6%;  width:4px; height:4px;  --drift:18px;  animation-duration:16s; animation-delay:-2s;"></span>
  <span style="left:14%; width:3px; height:3px;  --drift:-14px; animation-duration:21s; animation-delay:-9s;"></span>
  <span style="left:23%; width:5px; height:5px;  --drift:10px;  animation-duration:18s; animation-delay:-4s;"></span>
  <span style="left:34%; width:3px; height:3px;  --drift:-8px;  animation-duration:23s; animation-delay:-14s;"></span>
  <span style="left:45%; width:4px; height:4px;  --drift:16px;  animation-duration:19s; animation-delay:-1s;"></span>
  <span style="left:56%; width:3px; height:3px;  --drift:-12px; animation-duration:25s; animation-delay:-11s;"></span>
  <span style="left:65%; width:5px; height:5px;  --drift:14px;  animation-duration:17s; animation-delay:-6s;"></span>
  <span style="left:74%; width:3px; height:3px;  --drift:-16px; animation-duration:22s; animation-delay:-3s;"></span>
  <span style="left:83%; width:4px; height:4px;  --drift:9px;   animation-duration:20s; animation-delay:-16s;"></span>
  <span style="left:91%; width:3px; height:3px;  --drift:-10px; animation-duration:24s; animation-delay:-8s;"></span>
  <span style="left:38%; width:2px; height:2px;  --drift:6px;   animation-duration:15s; animation-delay:-12s;"></span>
  <span style="left:70%; width:2px; height:2px;  --drift:-7px;  animation-duration:26s; animation-delay:-5s;"></span>
</div>
<div class="onboard-overlay" id="onboard-overlay" aria-hidden="true">
  <div class="onboard-shell">
    <div class="onboard-dots" id="onboard-dots">
      <span class="on" data-step="key"></span><span data-step="soul"></span><span data-step="done"></span>
    </div>

    <div class="onboard-step" id="onboard-step-key">
      <div class="onboard-step-label">Step 1 of 2</div>
      <h1>Welcome to Faerie Fire</h1>
      <p class="onboard-copy">Faerie Fire runs on Claude, using your own Anthropic API key — nothing is shared
        with anyone else and the key never leaves this computer. You can get one at
        <a href="https://console.anthropic.com/" target="_blank" rel="noopener">console.anthropic.com</a>.</p>
      <label for="onboard-key-input">Anthropic API key</label>
      <input type="password" id="onboard-key-input" placeholder="sk-ant-..." autocomplete="off" spellcheck="false">
      <div class="onboard-error" id="onboard-key-error"></div>
      <div class="onboard-actions">
        <button class="onboard-skip" id="onboard-skip-btn" type="button">Skip for now</button>
        <button class="accent" id="onboard-key-continue" type="button">Validate &amp; continue</button>
      </div>
    </div>

    <div class="onboard-step" id="onboard-step-soul" style="display:none">
      <div class="onboard-step-label">Step 2 of 2</div>
      <h1>Name your Soul</h1>
      <p class="onboard-copy">Everything in Faerie Fire — Roots, Branches, Leaves — grows underneath one Soul:
        the overall direction, the kind of life and growth this map exists to support. You can always change
        this later from Soul Calibration.</p>
      <label for="onboard-soul-title">What should we call it?</label>
      <input type="text" id="onboard-soul-title" placeholder="Actualized Self" maxlength="80">
      <label for="onboard-soul-purpose">What this is for</label>
      <textarea id="onboard-soul-purpose" rows="3">This app is designed to help you actualize your Soul and become the best version of yourself. The answers are already inside you — Faerie Fire just helps you extract and build them, across every part of your life. Edit this if you'd put it differently.</textarea>
      <div class="onboard-error" id="onboard-soul-error"></div>
      <div class="onboard-actions">
        <span></span>
        <button class="accent" id="onboard-soul-continue" type="button">Create my Soul</button>
      </div>
    </div>

    <div class="onboard-step" id="onboard-step-done" style="display:none">
      <div class="onboard-step-label">All set</div>
      <h1>Your Soul is planted</h1>
      <p class="onboard-copy">Faerie seeded one starter investigation — <b>"Getting to know Faerie Fire"</b> — under
        Investigations, so there's something to answer on day one. Everything else grows from here: talk to Faerie
        in Command Center, or watch the Growth tree fill in as you go.</p>
      <div class="onboard-actions">
        <span></span>
        <button class="accent" id="onboard-enter-btn" type="button">Enter Faerie Fire</button>
      </div>
    </div>
  </div>
</div>
<div id="app">
  <header>
    <span class="logo">✦ Faerie Fire</span>
    <button class="header-refresh" id="header-refresh-self" title="Refresh dashboard">⟳</button>
    <button class="settings-cog" id="settings-cog" title="Settings and tools">⚙</button>
    <span class="backend" id="backend" hidden></span>
  </header>
  <nav>
    <div class="tab active" data-view="self" data-group="self">Command Center</div>
    <div class="tab" data-view="goals" data-group="growth">Growth</div>
    <div class="tab" data-view="curiosity" data-group="growth">Investigations</div>
    <details class="nav-group" data-group="knowledge">
      <summary class="group-label">Knowledge</summary>
      <div class="nav-menu">
        <div class="tab" data-view="inferences" data-group="knowledge">Inferences</div>
        <div class="tab" data-view="clarify" data-group="knowledge">Clarify</div>
        <div class="tab" data-view="memory" data-group="knowledge">Memory</div>
      </div>
    </details>
  </nav>

  <aside class="planner-drawer toolbox-drawer" id="settings-drawer">
    <div class="cur-head"><span class="cur-label">Settings & tools</span>
      <button id="settings-close" style="margin-left:auto">Close</button></div>
    <p class="hint">Less-used screens live here so the main navigation can stay calm.</p>
    <div class="actions">
      <button id="settings-edit-soul">Edit Soul</button>
      <button id="settings-open-calibration">Soul Calibration<span id="settings-cal-status" class="hint" style="display:block;font-size:11px;margin-top:2px"></span></button>
      <button id="settings-change-key">Change API Key</button>
      <button id="settings-daily-report">Today's Report</button>
      <button id="settings-full-report">Full Report</button>
      <button class="tab personal-only" data-view="timeline" data-group="tools">Open Timeline</button>
      <button class="tab personal-only" data-view="import" data-group="tools">Open Import</button>
      <button class="personal-only" id="settings-db-rescue">Database rescue</button>
    </div>
  </aside>

  <div class="cc-ctx-menu" id="cc-chat-ctx-menu" style="display:none">
    <button type="button" class="cc-ctx-item" data-action="rename">Rename</button>
    <button type="button" class="cc-ctx-item danger" data-action="delete">Delete</button>
  </div>

  <aside class="planner-drawer soul-calibration-drawer" id="soul-calibration-drawer">
    <div class="cur-head">
      <span class="cur-label">Soul Calibration</span>
      <span id="soul-cal-progress" class="hint" style="margin:0 12px"></span>
      <button id="soul-cal-close" style="margin-left:auto">Close</button>
    </div>
    <p class="hint">13 quick questions, one at a time — these shape how Faerie thinks and
      talks with you, not just what it knows about you. Skip any time; skipped ones
      stay hidden unless you type <code>/recalibrate</code> in chat to start over.</p>
    <p class="hint">Feeling overwhelmed? Just write whatever basic thing comes to mind first —
      as more thoughts surface, add them too. Faerie will sort it out.</p>
    <div id="soul-cal-body"><div class="hint">Loading…</div></div>
  </aside>

  <div class="view active" id="view-self">
    <div class="toolbar command-tools">
      <button class="personal-only" id="self-database-rescue">Database rescue</button>
      <span id="self-status" class="hint" style="margin:0"></span>
    </div>
    <div class="command-center-shell">
      <aside class="command-portrait-col">
        <div class="self-panel self-identity-card">
          <div id="self-level-widget" class="self-empty">Loading…</div>
          <div class="self-portrait anim-still" id="self-portrait">
            <div class="portrait-rays"></div>
            <div class="portrait-motes"></div>
            <div class="portrait-wind"></div>
            <div class="portrait-droplets"></div>
            <div class="portrait-aurora"></div>
            <span class="self-portrait-sparkle">✦</span>
            <button class="self-portrait-edit" id="self-portrait-edit-btn" title="Customize portrait">✎</button>
            <div class="self-customizer" id="self-customizer">
              <label>Ambient effect</label>
              <select id="self-portrait-anim">
                <option value="still">Still</option>
                <option value="sunshafts">Sunshafts</option>
                <option value="motes">Motes</option>
                <option value="fireflies">Fireflies</option>
                <option value="breeze">Breeze</option>
                <option value="rain">Rain</option>
                <option value="dreamlight">Dreamlight</option>
                <option value="living">Living (all)</option>
              </select>
              <button id="self-portrait-upload-btn" style="width:100%;margin-top:10px">Change image…</button>
              <p class="hint">Pick a photo or a scene that feels like you right now. The ambient effect layers softly over it.</p>
            </div>
          </div>
        </div>
        <div id="self-profile-widgets" class="self-empty">Loading your daily command widgets…</div>
      </aside>
      <div class="command-chat-col">
        <section class="command-chat-panel" aria-label="Command Center chat">
          <aside class="cc-chat-list">
            <div class="cc-chat-list-head">
              <button id="cc-chat-list-collapse" class="cc-chat-list-toggle" type="button" title="Hide conversations">«</button>
              <b>Conversations</b>
              <button id="cc-new-chat" class="cc-new-chat-btn" type="button" title="New conversation">+</button>
            </div>
            <div id="cc-chat-list"><div class="hint">Loading chats…</div></div>
            <button id="cc-delete-chat" class="skip" style="width:100%;margin-top:10px">Delete current</button>
          </aside>
          <main class="cc-chat-main">
            <div class="cc-chat-head">
              <div class="cc-chat-head-text">
                <h2>✦ Command Center</h2>
                <p>Talk with Faerie here. This is the single chat surface; it can use memory, investigations, Growth context, attachments, and filing commands.</p>
              </div>
              <button id="cc-fullscreen-toggle" class="cc-fullscreen-btn" type="button" title="Expand chat">⛶</button>
            </div>
            <div id="cc-log" class="cc-log"><div class="cc-empty">Loading the thread…</div></div>
            <div id="cc-proposal" class="cc-proposal" style="display:none"></div>
            <div class="cc-compose">
              <div id="cc-attachments" class="cc-attachments"></div>
              <div class="cc-compose-input-wrap">
                <button id="cc-attach" class="cc-icon-btn cc-attach-btn" type="button" title="Attach file">+</button>
                <textarea id="cc-input" placeholder="Ask Faerie, paste a thought, or use /file to save a brain dump…"></textarea>
                <button id="cc-send" class="cc-icon-btn cc-send-btn" type="button" title="Send">➤</button>
              </div>
              <span id="cc-status" class="hint" style="margin:6px 0 0;display:block"></span>
            </div>
          </main>
        </section>
        <section class="command-investigations-panel" aria-label="Investigations">
          <div class="command-section-divider"><span>Investigations</span></div>
          <div id="self-investigations-cards" class="self-empty">Loading investigations…</div>
        </section>
      </div>
      <aside id="self-dashboard" class="command-side self-empty">Loading your daily command widgets…</aside>
    </div>
  </div>

  <div class="view" id="view-inferences">
    <div class="investigate-box">
      <div class="title">Ask Faerie to investigate a pattern</div>
      <p class="hint">Give it a direction: “Try to understand why I avoid X” or “How does this memory relate to attachment theory?” It will use relevant memories, behavioral evidence, and existing beliefs.</p>
      <div class="investigate-row">
        <textarea id="investigate-prompt" placeholder="What should Faerie try to understand about you?"></textarea>
        <button class="accent" id="investigate-btn">Investigate</button>
      </div>
      <div class="inquiry-resume" id="inquiry-resume"></div>
    </div>
    <div class="toolbar">
      <button class="accent" id="run-btn">Regenerate inferences</button>
      <button id="refresh-inf">Refresh</button>
      <span id="inf-status"></span>
    </div>
    <p class="hint" id="gate-hint"></p>
    <div id="stack"></div>
    <h2 class="section">Still forming · <span class="accent-word" id="gate-label"></span> to appear</h2>
    <div id="forming" class="card" style="padding:6px 14px"></div>
    <h2 class="section">What I now believe about you</h2>
    <div id="beliefs" class="card" style="padding:6px 14px"></div>
    <aside class="inquiry-drawer" id="inquiry-drawer"></aside>
  </div>

  <div class="view" id="view-clarify">
    <div class="toolbar">
      <button class="accent" id="clar-scan-btn">Scan for ambiguity</button>
      <button id="refresh-clar">Refresh</button>
      <span id="clar-status"></span>
    </div>
    <p class="hint">Ambiguous wording ("possibly a relative", "family-adjacent figure") still asks
      you directly — only you know the answer. Objective date problems (a memory mentioning tech
      from before it existed, an implausible age, a school grade that doesn't match your age) are
      corrected automatically once a birth date is set below — the fix shows up under "Recently
      resolved" tagged <b>auto-fixed</b> so you can double-check it. Select several open questions
      to dismiss or answer together instead of one at a time.</p>
    <div class="toolbar">
      <label class="year-label">Birth date (for age checks)
        <input id="birth-date" type="date"></label>
      <button id="birth-date-save">Save</button>
      <span id="birth-date-status" class="hint" style="margin:0"></span>
    </div>
    <div class="toolbar" style="align-items:flex-start">
      <label class="year-label">Grade/school-year chart (exact, overrides age guess)
        <textarea id="grade-chart-text" rows="3" style="width:100%;min-width:320px"
          placeholder="Kindergarten&#9;2000–2001&#10;1st grade&#9;2001–2002&#10;..."></textarea></label>
      <button id="grade-chart-save">Save</button>
      <span id="grade-chart-status" class="hint" style="margin:0"></span>
    </div>
    <div class="toolbar" id="clar-bulk-bar" style="display:none">
      <label class="toggle" id="clar-select-all"><div class="sw"></div><span>Select all</span></label>
      <button id="clar-bulk-dismiss">Dismiss selected</button>
      <input id="clar-bulk-text" type="text" placeholder="Same answer for all selected…">
      <button class="accent" id="clar-bulk-answer">Apply to selected</button>
      <span id="clar-bulk-status" class="hint" style="margin:0"></span>
    </div>
    <div id="clar-open"></div>
    <h2 class="section">Recently resolved</h2>
    <div id="clar-resolved" class="card" style="padding:6px 14px"></div>
  </div>

  <div class="view" id="view-curiosity">
    <div id="cur-list"></div>
    <div id="cur-switcher"></div>
  </div>

  <div class="view" id="view-goals">
    <span id="goal-status" class="hint" style="display:none"></span>
    <div class="growth-map-main" id="goal-map-main">
      <div id="goal-ai-strip" class="goal-ai-strip"></div>
      <div class="growth-map-workspace">
        <div class="growth-map-stage">
          <div id="goal-map-tree" class="growth-map-tree" aria-label="Main living constellation map"></div>
          <div class="constellation-legend">
            <span>✦ Soul</span><span>◆ Root</span><span>◇ Branch</span><span>✓ Leaf</span><span>gold halo = needs care</span>
          </div>
        </div>
        <aside class="goal-pane goal-focus-panel" id="goal-focus-panel">
          <div class="empty">Select a star to see what matters now.</div>
        </aside>
      </div>
    </div>
    <div class="goal-list-view" id="goal-list-view" hidden>
      <div class="goal-ai-overview" id="goal-ai-overview"></div>
      <div class="goal-layout">
        <div class="goal-pane" id="goal-tree"></div>
        <div class="goal-pane goal-detail" id="goal-detail">
          <div class="empty">Select a goal to see its plan, progress, and evidence.</div>
        </div>
      </div>
    </div>
  </div>

  <aside class="planner-drawer goal-edit-drawer" id="goal-edit-drawer">
    <div class="cur-head"><span class="cur-label">Edit Details</span>
      <button id="goal-edit-close" style="margin-left:auto">Close</button></div>
    <p class="hint">Detailed editing lives here so the main Growth page can stay focused on orientation and action.</p>
    <div id="goal-edit-form" class="hint">Select a node, then use the detail panel controls.</div>
  </aside>

  <div class="growth-map-overlay" id="growth-map-overlay" aria-hidden="true">
    <div class="growth-map-shell">
      <div class="cur-head growth-map-head">
        <span class="cur-label">Living Map</span>
        <button id="growth-map-close" style="margin-left:auto">Back to focus</button>
      </div>
      <p class="hint">A lightweight constellation view of your existing Soul tree. It does not create new data yet — it helps you orient, then hands focus back to the normal Growth page.</p>
      <div id="growth-map-summary" class="growth-map-summary"></div>
      <div id="growth-map-tree" class="growth-map-tree" aria-label="Living constellation map"></div>
      <div class="constellation-legend">
        <span>✦ Soul</span><span>◆ Root</span><span>◇ Branch</span><span>✓ Leaf</span><span>gold halo = needs care</span>
      </div>
    </div>
  </div>

  <aside class="planner-drawer" id="goal-planner">
    <div class="cur-head"><span class="cur-label">Shape this into a plan</span>
      <button id="planner-close" style="margin-left:auto">Close</button></div>
    <p class="hint">Faerie will ask one useful question at a time. Nothing enters your
      goal tree until you review the summary and choose Create plan.</p>
    <div id="planner-messages"></div>
    <textarea id="planner-answer" rows="3" placeholder="Answer in your own words…"></textarea>
    <div class="actions">
      <button id="planner-abandon" class="skip">Abandon</button>
      <button id="planner-summary">Summarize &amp; review</button>
      <button id="planner-send" class="accent">Continue</button>
    </div>
    <div id="planner-review" style="display:none">
      <div class="cur-sub">Editable draft JSON</div>
      <textarea class="planner-draft" id="planner-draft" rows="16" spellcheck="false"></textarea>
      <div class="actions"><button id="planner-create" class="accent">Create plan</button></div>
    </div>
  </aside>

  <aside class="planner-drawer" id="goal-agent-chat">
    <div class="cur-head"><span class="cur-label" id="agent-chat-title">Ask GoalAI</span>
      <button id="agent-chat-close" style="margin-left:auto">Close</button></div>
    <p class="hint">This agent is bounded to the selected goal branch. Goal changes and
      memories remain proposals until you approve them.</p>
    <div id="agent-chat-messages"></div>
    <textarea id="agent-chat-input" rows="4" placeholder="Ask about this goal…"></textarea>
    <div class="actions"><button class="accent" id="agent-chat-send">Send</button></div>
  </aside>

  <div class="view" id="view-memory">
    <div class="toolbar">
      <input id="mem-search" type="text" placeholder="Search memory…" spellcheck="false">
      <div class="toggle" id="hist-toggle"><div class="sw"></div><span>Show history</span></div>
      <button id="refresh-mem">Refresh</button>
      <span id="mem-count"></span>
    </div>
    <div id="mem-groups"></div>
  </div>

  <div class="view" id="view-timeline">
    <p class="hint">Your evolution, oldest beliefs to newest — every fact placed at the date
      it became true. Struck-through facts were later revised; the arrow shows when.</p>
    <div id="tl-groups"></div>
  </div>

  <div class="view" id="view-import">
    <p class="hint">Drop journals or notes here (.md / .txt) — they're staged locally, entries
      are split by date markers like "06/16", and nothing is sent anywhere until you run the
      import. Files without a header get the year below for their dates.</p>
    <div class="toolbar">
      <label class="year-label">Year for undated headers
        <input id="drop-year" type="number" min="1990" max="2100"></label>
      <span id="import-status"></span>
    </div>
    <div id="dropzone">Drop files here<br><span>.md, .txt or .docx · staged into your local journal folder</span></div>
    <h2 class="section">Staged files</h2>
    <div id="staged" class="card" style="padding:6px 14px"></div>
    <div class="toolbar" style="margin-top:12px">
      <button class="accent" id="btn-import">Import into memory</button>
      <label class="toggle" id="reset-toggle"><div class="sw"></div><span>Re-walk earlier months (reset)</span></label>
      <label class="toggle" id="deep-toggle" title="For autobiographies / dense retrospectives: one model call per entry, exhaustive extraction, facts dated to when events happened (slower, more calls)"><div class="sw"></div><span>Deep extract</span></label>
    </div>
    <div id="import-result" class="card" style="display:none; padding:12px 16px"></div>
    <h2 class="section">Memory hygiene</h2>
    <p class="hint">Merges near-duplicate memories (e.g. the same anecdote imported twice with
      slightly different wording) and prunes stale rejections/evidence. Runs nightly on its own —
      use this to tidy up right after a big import, before scanning Clarify.</p>
    <div class="toolbar">
      <button id="consolidate-btn">Consolidate now</button>
      <span id="consolidate-status" class="hint" style="margin:0"></span>
    </div>
  </div>
</div>
<div id="toast"></div>

<script>
'use strict';
let GATE = 0.8, showHist = false, memData = [], toastTimer = null;
let appProfile = 'personal', initialView = 'self', appBootstrapped = false;
let commandAttachments = [], commandChatState = null;

function $(id){ return document.getElementById(id); }
function esc(s){ const d=document.createElement('div'); d.textContent=String(s==null?'':s); return d.innerHTML; }
function pct(x){ return x==null ? '' : Math.round(x*100) + '%'; }
function api(){ return window.pywebview && pywebview.api; }
function bridgeTimeout(promise,label,ms=15000){
  return new Promise((resolve,reject)=>{
    const timer=setTimeout(()=>reject(new Error(label+' timed out')),ms);
    Promise.resolve(promise).then(value=>{ clearTimeout(timer); resolve(value); },
      error=>{ clearTimeout(timer); reject(error); });
  });
}
function normalizeViewName(name){
  const raw=String(name||'self').toLowerCase().replace(/_/g,'-');
  const aliases={'command-center':'self','command':'self','dashboard':'self','growth':'goals',
    'investigations':'curiosity','curiosities':'curiosity'};
  return aliases[raw]||raw;
}
function applyAppBootstrap(info){
  info=info||{};
  appProfile=info.profile||'personal';
  initialView=normalizeViewName(info.initial_view||'self');
  document.body.classList.toggle('profile-launch', appProfile==='launch');
  if($('backend')){
    const backend=info.backend||info.inference_backend||'?';
    $('backend').textContent='profile: '+appProfile+' · backend: '+backend;
  }
  if(appProfile==='launch'){
    ['inferences','clarify','memory','timeline','import'].forEach(view=>{
      document.querySelectorAll('[data-view="'+view+'"]').forEach(el=>el.classList.add('personal-only'));
    });
    document.querySelectorAll('nav .nav-group[data-group="knowledge"]').forEach(el=>el.classList.add('personal-only'));
    if(['inferences','clarify','memory','timeline','import'].includes(initialView)) initialView='self';
  }
  appBootstrapped=true;
}

/* ---------- onboarding (launch profile first run) ---------- */
function onboardShowStep(step){
  ['key','soul','done'].forEach(s=>{
    const el=$('onboard-step-'+s);
    if(el) el.style.display=(s===step?'':'none');
  });
  document.querySelectorAll('#onboard-dots span').forEach(dot=>{
    dot.classList.toggle('on', dot.getAttribute('data-step')===step);
  });
}
function onboardError(id, message){
  const el=$(id);
  if(!el) return;
  if(message){ el.textContent=message; el.classList.add('show'); }
  else { el.textContent=''; el.classList.remove('show'); }
}
function openOnboarding(){
  const overlay=$('onboard-overlay');
  if(!overlay) return;
  overlay.classList.add('open');
  overlay.setAttribute('aria-hidden','false');
  const focusStep=step=>{
    onboardShowStep(step);
    const focusId=step==='soul'?'onboard-soul-title':'onboard-key-input';
    setTimeout(()=>{ const el=$(focusId); if(el) el.focus(); }, 50);
  };
  if(api()&&pywebview.api.onboarding_status){
    bridgeTimeout(pywebview.api.onboarding_status(),'Onboarding status',8000)
      .then(r=>focusStep(r&&r.has_key?'soul':'key'))
      .catch(()=>focusStep('key'));
  } else {
    focusStep('key');
  }
}
function closeOnboardingAndEnter(){
  const overlay=$('onboard-overlay');
  if(overlay){ overlay.classList.remove('open'); overlay.setAttribute('aria-hidden','true'); }
  activateView(initialView);
  if(appProfile==='personal' && initialView!=='inferences') loadState();
}
(function initOnboardingHandlers(){
  const keyBtn=$('onboard-key-continue');
  if(keyBtn) keyBtn.onclick=()=>{
    if(!api()) return;
    const input=$('onboard-key-input');
    const key=(input&&input.value||'').trim();
    onboardError('onboard-key-error','');
    keyBtn.disabled=true; keyBtn.textContent='Validating…';
    bridgeTimeout(pywebview.api.onboarding_save_key(key),'Key validation',20000).then(r=>{
      keyBtn.disabled=false; keyBtn.textContent='Validate & continue';
      if(!r||r.ok===false){ onboardError('onboard-key-error',(r&&r.message)||'Could not validate that key.'); return; }
      onboardShowStep('soul');
      setTimeout(()=>{ const el=$('onboard-soul-title'); if(el) el.focus(); }, 50);
    }).catch(e=>{
      keyBtn.disabled=false; keyBtn.textContent='Validate & continue';
      onboardError('onboard-key-error','Could not reach Faerie Fire: '+e);
    });
  };
  const skipBtn=$('onboard-skip-btn');
  if(skipBtn) skipBtn.onclick=()=>{
    if(!api()) return;
    skipBtn.disabled=true;
    bridgeTimeout(pywebview.api.onboarding_skip(),'Skip onboarding',10000).then(()=>{
      skipBtn.disabled=false;
      closeOnboardingAndEnter();
    }).catch(()=>{ skipBtn.disabled=false; closeOnboardingAndEnter(); });
  };
  const soulBtn=$('onboard-soul-continue');
  if(soulBtn) soulBtn.onclick=()=>{
    if(!api()) return;
    const title=($('onboard-soul-title')&&$('onboard-soul-title').value||'').trim();
    const purpose=($('onboard-soul-purpose')&&$('onboard-soul-purpose').value||'').trim();
    onboardError('onboard-soul-error','');
    soulBtn.disabled=true; soulBtn.textContent='Planting…';
    bridgeTimeout(pywebview.api.onboarding_create_soul(title, purpose),'Create Soul',20000).then(r=>{
      soulBtn.disabled=false; soulBtn.textContent='Create my Soul';
      if(!r||r.ok===false){ onboardError('onboard-soul-error',(r&&r.message)||'Could not save that.'); return; }
      onboardShowStep('done');
    }).catch(e=>{
      soulBtn.disabled=false; soulBtn.textContent='Create my Soul';
      onboardError('onboard-soul-error','Could not reach Faerie Fire: '+e);
    });
  };
  const enterBtn=$('onboard-enter-btn');
  if(enterBtn) enterBtn.onclick=closeOnboardingAndEnter;
})();

function autoGrow(textarea){
  if(!textarea||textarea.tagName!=='TEXTAREA') return;
  textarea.style.height='auto';
  textarea.style.height=Math.min(textarea.scrollHeight,Math.round(window.innerHeight*.6))+'px';
}
function autoGrowWithin(root){ (root||document).querySelectorAll('textarea').forEach(autoGrow); }
document.addEventListener('input',e=>{ if(e.target&&e.target.tagName==='TEXTAREA') autoGrow(e.target); });
new MutationObserver(records=>records.forEach(record=>record.addedNodes.forEach(node=>{
  if(node.nodeType===1){ if(node.tagName==='TEXTAREA') autoGrow(node); autoGrowWithin(node); }
}))).observe(document.documentElement,{childList:true,subtree:true});

/* Shift+Enter submits via the given callback; plain Enter keeps inserting a
   newline (default textarea behavior — nothing to do for that case). */
function bindShiftEnterSubmit(textarea, onSubmit){
  // Enter sends; Shift+Enter inserts a newline (standard chat-box convention).
  textarea.addEventListener('keydown', e=>{
    if(e.key==='Enter' && !e.shiftKey){
      e.preventDefault();
      onSubmit();
    }
  });
}

function toast(msg, isErr, actionLabel, onAction, duration){
  const t=$('toast'); t.innerHTML='';
  const label=document.createElement('span'); label.textContent=msg; t.appendChild(label);
  if(actionLabel&&onAction){
    const btn=document.createElement('button'); btn.type='button'; btn.textContent=actionLabel;
    btn.onclick=()=>{ clearTimeout(toastTimer); t.classList.remove('show'); onAction(); };
    t.appendChild(btn);
  }
  t.className=(isErr?'err ':'')+'show';
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'), duration||3200);
}

let lastAutoDbRescueAt=0, autoDbRescuePromise=null;
function isDbLockMessage(value){
  return /database is locked|database locked|sqlite.*locked/i.test(String(value&&value.message||value||''));
}
function autoDatabaseRescue(reason){
  if(!api()||!pywebview.api.database_unlock) return Promise.resolve(null);
  const now=Date.now();
  if(autoDbRescuePromise) return autoDbRescuePromise;
  if(now-lastAutoDbRescueAt<15000) return Promise.resolve(null);
  lastAutoDbRescueAt=now;
  autoDbRescuePromise=pywebview.api.database_unlock().then(r=>{
    autoDbRescuePromise=null;
    if(r&&r.ok!==false) console.debug('database auto-rescue complete', reason||'');
    return r;
  }).catch(e=>{ autoDbRescuePromise=null; console.debug('database auto-rescue failed', e); return null; });
  return autoDbRescuePromise;
}
function withDbRetry(factory){
  return factory().then(r=>{
    if(r&&r.ok===false&&isDbLockMessage(r.message)){
      return autoDatabaseRescue('locked action').then(()=>factory());
    }
    return r;
  }).catch(e=>{
    if(isDbLockMessage(e)) return autoDatabaseRescue('locked exception').then(()=>factory());
    throw e;
  });
}

/* ---------- tabs ---------- */
function activateView(name){
  name=normalizeViewName(name);
  if(appProfile==='launch' && ['inferences','clarify','memory','timeline','import'].includes(name)){
    name='self';
    toast('That personal screen is hidden in launch profile.');
  }
  const tab=document.querySelector('.tab[data-view="'+name+'"]');
  if(!tab) return;
  document.querySelectorAll('.tab[data-view]').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('nav .nav-group').forEach(g=>{
    g.classList.remove('active');
    g.open=false;
  });
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  tab.classList.add('active');
  const settings=$('settings-drawer');
  if(settings) settings.classList.remove('open');
  const group=tab.dataset.group;
  if(group&&group!=='self'&&group!=='tools'){
    const groupEl=document.querySelector('nav .nav-group[data-group="'+group+'"]');
    if(groupEl){ groupEl.classList.add('active'); groupEl.open=true; }
  }
  $('view-'+name).classList.add('active');
  if(name==='self') loadCommandCenter();
  if(name==='memory') loadMemory();
  if(name==='timeline') loadTimeline();
  if(name==='import') loadStaged();
  if(name==='clarify') loadClarify();
  if(name==='curiosity') loadCuriosity();
  if(name==='goals') loadGoals();
  autoDatabaseRescue('tab switch');
}

document.querySelectorAll('nav .tab').forEach(tab=>{
  tab.onclick=()=>activateView(tab.dataset.view);
});
document.querySelectorAll('#settings-drawer .tab[data-view]').forEach(tab=>{
  tab.onclick=()=>activateView(tab.dataset.view);
});
document.querySelectorAll('nav .nav-group').forEach(group=>{
  group.addEventListener('toggle',()=>{
    if(group.open){
      document.querySelectorAll('nav .nav-group').forEach(other=>{
        if(other!==group) other.open=false;
      });
    }
  });
});
if($('settings-cog')) $('settings-cog').onclick=()=>{
  $('settings-drawer').classList.add('open');
  refreshSettingsCalibrationLabel();
};
function refreshSettingsCalibrationLabel(state){
  const span=$('settings-cal-status'); if(!span) return;
  if(state){
    const complete=!!state.complete || ((state.total||0)>0 && calCovered(state)>=(state.total||0));
    span.textContent=complete?'Completed — click to review or adjust':calCovered(state)+'/'+(state.total||0)+' covered so far';
    return;
  }
  if(!api()||!pywebview.api.command_calibration_status){ span.textContent=''; return; }
  pywebview.api.command_calibration_status().then(r=>{
    if(!r||r.ok===false){ span.textContent=''; return; }
    refreshSettingsCalibrationLabel(r);
  }).catch(()=>{ span.textContent=''; });
}
if($('settings-close')) $('settings-close').onclick=()=>$('settings-drawer').classList.remove('open');
if($('settings-db-rescue')) $('settings-db-rescue').onclick=runDatabaseRescue;

/* ---------- Soul Calibration (standalone popout drawer) ---------- */
let soulCalState=null;
let soulCalSynthesisFired=false;

let soulCalSelectedKey=null;

function soulCalFieldByKey(state, key){
  const sections=(state&&state.sections)||[];
  for(const sec of sections){
    for(const attr of (sec.attributes||[])){
      if((sec.section+'::'+attr.attribute)===key) return Object.assign({section:sec.section},attr);
    }
  }
  return null;
}

function soulCalNextField(state){
  const sections=(state&&state.sections)||[];
  for(const sec of sections){
    for(const attr of (sec.attributes||[])){
      if(attr.state==='remaining') return Object.assign({section:sec.section},attr);
    }
  }
  return null;
}

// The field actually shown in the form: a manually clicked row if one is
// selected (so past answers can be reviewed/edited out of order), otherwise
// the natural next unanswered question.
function soulCalActiveField(state){
  if(soulCalSelectedKey){
    const picked=soulCalFieldByKey(state, soulCalSelectedKey);
    if(picked) return picked;
  }
  return soulCalNextField(state);
}

function soulCalChecklistHtml(state, activeKey){
  const sections=(state&&state.sections)||[];
  return sections.map(sec=>{
    const attrs=(sec.attributes||[]).filter(a=>a.state!=='skipped');
    if(!attrs.length) return '';
    return '<div class="calibration-section">'+esc(sec.section)+'</div>'+
    attrs.map(a=>{
      const key=sec.section+'::'+a.attribute;
      const mark=a.state==='done'?'✓':'○';
      return '<div class="calibration-row '+a.state+(key===activeKey?' active':'')+
        '" data-cal-key="'+esc(key)+'" title="Click to review or edit"><span class="cal-mark">'+mark+
        '</span><span>'+esc(a.label)+'</span></div>';
    }).join('')
  }).join('');
}

function bindSoulCalDrawer(){
  const textarea=$('soul-cal-answer');
  if(textarea){
    textarea.focus();
    bindShiftEnterSubmit(textarea, ()=>submitSoulCalField(false));
  }
  const saveBtn=$('soul-cal-save'); if(saveBtn) saveBtn.onclick=()=>submitSoulCalField(false);
  const skipBtn=$('soul-cal-skip'); if(skipBtn) skipBtn.onclick=()=>submitSoulCalField(true);
  document.querySelectorAll('#soul-cal-body .calibration-row[data-cal-key]').forEach(row=>{
    row.onclick=()=>{
      soulCalSelectedKey=row.dataset.calKey;
      renderSoulCalDrawer();
    };
  });
}

function renderSoulCalDrawer(){
  const state=soulCalState;
  const body=$('soul-cal-body'); if(!body) return;
  if(!state){ body.innerHTML='<div class="hint">Loading…</div>'; return; }
  const calIsComplete=!!state.complete || ((state.total||0)>0 && calCovered(state)>=(state.total||0));
  if($('soul-cal-progress')) $('soul-cal-progress').textContent=calIsComplete?'Completed':
    calCovered(state)+'/'+(state.total||0)+' covered';
  refreshSettingsCalibrationLabel(state);
  const naturalNext=soulCalNextField(state);
  const active=soulCalActiveField(state);
  const jumped=!!(active && soulCalSelectedKey &&
    (!naturalNext || active.attribute!==naturalNext.attribute || active.section!==naturalNext.section));
  let formHtml;
  if(active){
    const isDone=active.state==='done';
    const buttons=[];
    if(jumped) buttons.push('<button type="button" id="soul-cal-back" class="skip">Back to next question</button>');
    if(!isDone) buttons.push('<button type="button" id="soul-cal-skip" class="skip">Skip for now</button>');
    buttons.push('<button type="button" id="soul-cal-save" class="accent" style="margin-left:auto">'+
      (jumped?'Save':'Save &amp; next')+'</button>');
    formHtml='<div class="soul-calibration-field">'+
      '<label>'+esc(active.section)+(jumped?' · reviewing':'')+'</label>'+
      '<div class="soul-calibration-prompt">'+esc(active.prompt)+'</div>'+
      '<textarea id="soul-cal-answer" placeholder="Type your answer…">'+esc(active.value||'')+'</textarea>'+
      '<div class="actions" style="margin-top:10px">'+buttons.join('')+'</div>'+
    '</div>';
  } else {
    formHtml='<div class="soul-calibration-field">'+
      '<div class="self-empty">✓ Soul Calibration completed — all 13 covered. Faerie '+
      'introduced itself in chat with a synthesis of what you shared. You can revisit '+
      'or change any answer anytime: reopen this from Settings → Soul Calibration, or '+
      'just click a question below to edit it.</div></div>';
  }
  body.innerHTML=formHtml+'<div class="soul-facts">'+
    soulCalChecklistHtml(state, active?(active.section+'::'+active.attribute):null)+'</div>';
  bindSoulCalDrawer();
  const backBtn=$('soul-cal-back');
  if(backBtn) backBtn.onclick=()=>{ soulCalSelectedKey=null; renderSoulCalDrawer(); };
  if(!naturalNext && !soulCalSynthesisFired){
    soulCalSynthesisFired=true;
    hideCalibrationSidebar();
    if(api()&&pywebview.api.command_calibration_synthesis){
      pywebview.api.command_calibration_synthesis().catch(()=>{});
    }
  }
}

function calCovered(state){
  return (state&&state.covered!=null)?state.covered:((state&&state.done)||0);
}

function hideCalibrationSidebar(){
  const shell=document.querySelector('.command-center-shell');
  const sidebar=$('self-dashboard');
  if(shell) shell.classList.add('no-sidebar');
  if(sidebar){
    sidebar.style.display='none';
    sidebar.innerHTML='';
  }
}

function submitSoulCalField(skip){
  if(!api()||!pywebview.api.command_calibration_save) return;
  const active=soulCalActiveField(soulCalState);
  if(!active) return;
  const textarea=$('soul-cal-answer');
  const value=skip?'':(textarea?textarea.value.trim():'');
  if(!skip && !value){ toast('Write an answer, or skip it.', true); return; }
  const saveBtn=$('soul-cal-save'), skipBtn=$('soul-cal-skip');
  if(saveBtn) saveBtn.disabled=true;
  if(skipBtn) skipBtn.disabled=true;
  pywebview.api.command_calibration_save(active.section, active.attribute, value, skip).then(r=>{
    if(!r||r.ok===false){
      if(saveBtn) saveBtn.disabled=false;
      if(skipBtn) skipBtn.disabled=false;
      toast((r&&r.message)||'Could not save that.', true);
      return;
    }
    soulCalState=r;
    soulCalSelectedKey=null;
    renderSoulCalDrawer();
    loadSelf();
  }).catch(e=>{
    if(saveBtn) saveBtn.disabled=false;
    if(skipBtn) skipBtn.disabled=false;
    toast('Could not save: '+e, true);
  });
}

function openSoulCalDrawer(){
  const drawer=$('soul-calibration-drawer'); if(!drawer) return;
  drawer.classList.add('open');
  soulCalSelectedKey=null;
  if(!api()||!pywebview.api.command_calibration_status){
    $('soul-cal-body').innerHTML='<div class="hint">Restart Faerie Fire to load this.</div>';
    return;
  }
  $('soul-cal-body').innerHTML='<div class="hint">Loading…</div>';
  pywebview.api.command_calibration_status().then(r=>{
    soulCalState=(r&&r.ok)?r:{sections:[],done:0,total:0,complete:false};
    soulCalSynthesisFired=!!soulCalState.complete;
    renderSoulCalDrawer();
  }).catch(e=>{
    $('soul-cal-body').innerHTML='<div class="hint">Could not load: '+esc(String(e))+'</div>';
  });
}

if($('soul-cal-close')) $('soul-cal-close').onclick=()=>{
  $('soul-calibration-drawer').classList.remove('open');
  loadSelf();
};
if($('settings-open-calibration')) $('settings-open-calibration').onclick=()=>{
  $('settings-drawer').classList.remove('open');
  openSoulCalDrawer();
};
function openEditSoul(){
  if(!api()) return;
  bridgeTimeout(pywebview.api.goal_state(),'Soul state',15000).then(r=>{
    if(!r||r.ok===false||!r.tree){ toast((r&&r.message)||'Could not load the Soul.',true); return; }
    const node=r.tree;
    const title=prompt('Soul name:',node.title||'');
    if(title===null) return;
    const trimmedTitle=title.trim();
    const purpose=prompt('Soul purpose (why this Soul exists):',node.description||'');
    if(purpose===null) return;
    const trimmedPurpose=purpose.trim();
    const changes={};
    if(trimmedTitle && trimmedTitle!==node.title) changes.title=trimmedTitle;
    if(trimmedPurpose!==(node.description||'')) changes.description=trimmedPurpose;
    if(!Object.keys(changes).length){ toast('Nothing changed.'); return; }
    pywebview.api.goal_update(node.id,changes).then(res=>{
      if(!res||res.ok===false){ toast((res&&res.message)||'Could not save the Soul.',true); return; }
      toast('Soul updated.');
      applyGoalTreeUpdate(res);
      if(typeof loadSelf==='function') loadSelf();
    }).catch(e=>toast('Could not save the Soul: '+e,true));
  }).catch(e=>toast('Could not load the Soul: '+e,true));
}
if($('settings-edit-soul')) $('settings-edit-soul').onclick=()=>{
  $('settings-drawer').classList.remove('open');
  openEditSoul();
};
function openChangeApiKey(){
  if(!api()||!pywebview.api.onboarding_save_key){ toast('Key changes are not available in this build.',true); return; }
  const key=prompt('Enter your Anthropic API key (sk-ant-...):','');
  if(key===null) return;
  const trimmed=key.trim();
  if(!trimmed){ toast('Key is empty.',true); return; }
  toast('Checking the key...');
  bridgeTimeout(pywebview.api.onboarding_save_key(trimmed),'API key save',20000).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not save the key.',true); return; }
    toast('API key saved.');
  }).catch(e=>toast('Could not save the key: '+e,true));
}
if($('settings-change-key')) $('settings-change-key').onclick=()=>{
  $('settings-drawer').classList.remove('open');
  openChangeApiKey();
};
function runActivityReport(kind){
  if(!api()) return;
  const isFull=kind==='full';
  const fn=isFull?pywebview.api.generate_full_report:pywebview.api.generate_daily_report;
  if(!fn){ toast('Reports are not available in this build.',true); return; }
  toast(isFull?'Building the full report...':'Building today\'s report...');
  bridgeTimeout(fn(),'Activity report',30000).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not build the report.',true); return; }
    toast('Report opened.',false,'Open folder',()=>{
      if(pywebview.api.open_reports_folder) pywebview.api.open_reports_folder();
    });
  }).catch(e=>toast('Could not build the report: '+e,true));
}
if($('settings-daily-report')) $('settings-daily-report').onclick=()=>{
  $('settings-drawer').classList.remove('open');
  runActivityReport('daily');
};
if($('settings-full-report')) $('settings-full-report').onclick=()=>{
  $('settings-drawer').classList.remove('open');
  runActivityReport('full');
};
document.addEventListener('click',e=>{
  if(!e.target.closest('nav')) document.querySelectorAll('nav .nav-group').forEach(g=>g.open=false);
});

function switchView(name){
  activateView(name);
}

function refreshActiveView(){
  const active=document.querySelector('.view.active');
  const name=active ? active.id.replace(/^view-/,'') : 'self';
  if(name==='self') { loadCommandCenter(); return; }
  if(name==='goals') { loadGoals(); return; }
  if(name==='curiosity') { loadCuriosity(); return; }
  if(name==='memory') { loadMemory(); return; }
  if(name==='timeline') { loadTimeline(); return; }
  if(name==='import') { loadStaged(); return; }
  if(name==='clarify') { loadClarify(); return; }
  if(name==='inferences') { loadState(); return; }
  loadCommandCenter();
}

/* ---------- command center chat ---------- */
function commandMessageText(message){
  const content=message&&message.content;
  if(Array.isArray(content)){
    return content.map(block=>block&&block.text?block.text:(block&&block.type?`[${block.type}]`:''))
      .filter(Boolean).join('\n');
  }
  return String(content==null?'':content);
}
function renderCommandAttachments(){
  const box=$('cc-attachments'); if(!box) return;
  box.innerHTML=commandAttachments.map((a,i)=>'<span class="cc-chip">'+
    esc(a.name||a.kind||'attachment')+' <button data-cc-remove="'+i+'" title="Remove">×</button></span>').join('');
  box.querySelectorAll('[data-cc-remove]').forEach(btn=>{
    btn.onclick=()=>{
      commandAttachments.splice(parseInt(btn.dataset.ccRemove,10),1);
      renderCommandAttachments();
    };
  });
}
function renderCommandChat(state){
  commandChatState=state||commandChatState||{};
  const chats=(commandChatState&&commandChatState.chats)||[];
  const active=(commandChatState&&commandChatState.active_chat_id)||'';
  const messages=(commandChatState&&commandChatState.messages)||[];
  const list=$('cc-chat-list');
  if(list){
    list.innerHTML=chats.length?chats.map(chat=>
      '<button class="cc-chat-item '+(chat.id===active?'active':'')+'" data-chat="'+esc(chat.id)+'">'+
      esc(chat.title||'New chat')+'</button>').join(''):'<div class="hint">No chats yet.</div>';
    list.querySelectorAll('[data-chat]').forEach(btn=>{
      btn.onclick=()=>pywebview.api.command_switch_chat(btn.dataset.chat)
        .then(renderCommandChat).catch(e=>toast('Could not switch chats: '+e,true));
      btn.oncontextmenu=(e)=>{
        e.preventDefault();
        showCcCtxMenu(e.clientX, e.clientY, btn.dataset.chat);
      };
    });
  }
  const log=$('cc-log');
  if(log){
    log.innerHTML=messages.length?messages.map(m=>
      '<div class="cc-message '+(m.role==='user'?'user':'assistant')+'">'+
      esc(commandMessageText(m))+'</div>').join(''):
      '<div class="cc-empty">Start here. Ask a question, paste a thought, attach a file, or use <b>/file</b> to turn a brain dump into a project note.</div>';
    log.scrollTop=log.scrollHeight;
  }
  renderPendingProposal();
}
function renderPendingProposal(){
  const box=$('cc-proposal'); if(!box) return;
  const proposal=commandChatState&&commandChatState.pending_proposal;
  if(!proposal){ box.style.display='none'; box.innerHTML=''; return; }
  const label=proposal.label||'this';
  box.style.display='flex';
  box.innerHTML='<span class="cc-proposal-text">Waiting on your decision for “'+esc(label)+'”.</span>'+
    '<button class="accent" id="cc-proposal-approve">Approve</button>';
  const btn=$('cc-proposal-approve');
  if(btn) btn.onclick=approvePendingProposal;
}
function approvePendingProposal(){
  if(!api()||!pywebview.api.command_send) return;
  const btn=$('cc-proposal-approve'); if(btn) btn.disabled=true;
  renderCommandChat({ok:true,
    active_chat_id:commandChatState&&commandChatState.active_chat_id,
    chats:commandChatState&&commandChatState.chats,
    pending_proposal:commandChatState&&commandChatState.pending_proposal,
    messages:(commandChatState&&commandChatState.messages||[]).concat([
      {role:'user',content:'approve'}
    ])});
  $('cc-status').innerHTML='<span class="spin"></span>Thinking…';
  pywebview.api.command_send('approve', []).then(r=>{
    $('cc-status').textContent='';
    if(!r||r.ok===false){ toast((r&&r.message)||'Command Center failed.',true); return; }
    renderCommandChat({ok:true,active_chat_id:r.active_chat_id,chats:r.chats,
      pending_proposal:r.pending_proposal,
      messages:(commandChatState&&commandChatState.messages||[]).concat([
        {role:'assistant',content:r.text||''}
      ])});
    loadCommandChat();
    // Every turn can silently save a calibration fact or change the tree —
    // keep the sidebar (Soul Calibration checklist, goals) live instead of
    // only refreshing on page load / manual "Refresh dashboard".
    loadSelf();
  }).catch(e=>{ $('cc-status').textContent=''; toast('Command Center failed: '+e,true); });
}
function loadCommandChat(){
  if(!api()||!pywebview.api.command_chat_state){
    if($('cc-status')) $('cc-status').textContent='Restart Faerie Fire to load the Command Center bridge.';
    if($('cc-chat-list')) $('cc-chat-list').innerHTML='<div class="hint">Bridge update needed.</div>';
    if($('cc-log')) $('cc-log').innerHTML='<div class="cc-empty">This window has the new Command Center page but an older Python bridge. Close this Faerie Fire window and reopen it from the tray so chat can load.</div>';
    return;
  }
  $('cc-status').innerHTML='<span class="spin"></span>Loading chat…';
  bridgeTimeout(pywebview.api.command_chat_state(),'Command Center chat',20000).then(r=>{
    $('cc-status').textContent='';
    if(!r||r.ok===false){
      const msg=(r&&r.message)||'Could not load Command Center chat.';
      toast(msg,true);
      // Leaving "Loading chats…"/"Loading the thread…" untouched here made a
      // real failure (e.g. no API key saved yet) look exactly like a frozen
      // app once the toast faded — show the actual reason persistently
      // instead, with a nudge toward the fix.
      if($('cc-chat-list')) $('cc-chat-list').innerHTML='<div class="hint">'+esc(msg)+'</div>';
      if($('cc-log')) $('cc-log').innerHTML='<div class="cc-empty">'+esc(msg)+
        ' If this is a fresh install, add your Anthropic API key during onboarding, '+
        'or check Settings.</div>';
      return;
    }
    renderCommandChat(r);
  }).catch(e=>{
    $('cc-status').textContent='';
    const msg='Could not load Command Center chat: '+e;
    toast(msg,true);
    if($('cc-chat-list')) $('cc-chat-list').innerHTML='<div class="hint">'+esc(msg)+'</div>';
    if($('cc-log')) $('cc-log').innerHTML='<div class="cc-empty">'+esc(msg)+'</div>';
  });
}
function sendCommandMessage(){
  if(!api()||!pywebview.api.command_send) return;
  const input=$('cc-input');
  const text=input.value.trim();
  const attachmentsForSend=commandAttachments;
  if(!text && !attachmentsForSend.length){ input.focus(); return; }
  // Show the user's message immediately — don't wait on the model round-trip.
  input.value=''; autoGrow(input);
  commandAttachments=[];
  renderCommandAttachments();
  renderCommandChat({ok:true,
    active_chat_id:commandChatState&&commandChatState.active_chat_id,
    chats:commandChatState&&commandChatState.chats,
    pending_proposal:commandChatState&&commandChatState.pending_proposal,
    messages:(commandChatState&&commandChatState.messages||[]).concat([
      {role:'user',content:text}
    ])});
  $('cc-send').disabled=true;
  $('cc-status').innerHTML='<span class="spin"></span>Thinking…';
  pywebview.api.command_send(text, attachmentsForSend).then(r=>{
    $('cc-send').disabled=false;
    $('cc-status').textContent='';
    if(!r||r.ok===false){ toast((r&&r.message)||'Command Center failed.',true); return; }
    renderCommandChat({ok:true,active_chat_id:r.active_chat_id,chats:r.chats,
      pending_proposal:r.pending_proposal,
      messages:(commandChatState&&commandChatState.messages||[]).concat([
        {role:'assistant',content:r.text||''}
      ])});
    loadCommandChat();
    // Every turn can silently save a calibration fact or change the tree —
    // keep the sidebar (Soul Calibration checklist, goals) live instead of
    // only refreshing on page load / manual "Refresh dashboard".
    loadSelf();
  }).catch(e=>{
    $('cc-send').disabled=false;
    $('cc-status').textContent='';
    toast('Command Center failed: '+e,true);
  });
}
function attachCommandFile(){
  if(!api()||!pywebview.api.command_attach_file) return;
  pywebview.api.command_attach_file().then(r=>{
    if(!r||r.ok===false){ if(r&&r.message) toast(r.message,true); return; }
    commandAttachments.push(r.attachment);
    renderCommandAttachments();
  }).catch(e=>toast('Could not attach file: '+e,true));
}
function bindCommandCenter(){
  const input=$('cc-input');
  if(input && !input.dataset.bound){
    input.dataset.bound='1';
    bindShiftEnterSubmit(input, sendCommandMessage);
    input.addEventListener('paste',e=>{
      const items=[...(e.clipboardData&&e.clipboardData.items||[])];
      items.forEach(item=>{
        if(item.kind==='file'){
          const file=item.getAsFile();
          if(file && file.type.startsWith('image/')){
            const reader=new FileReader();
            reader.onload=()=>{
              const data=String(reader.result||'').split(',')[1]||'';
              commandAttachments.push({kind:'image',name:file.name||'pasted image',
                media_type:file.type||'image/png',data});
              renderCommandAttachments();
            };
            reader.readAsDataURL(file);
          }
        }
      });
    });
  }
  const portrait=$('self-portrait');
  if(portrait && !portrait.dataset.bound){
    portrait.dataset.bound='1';
    const editBtn=$('self-portrait-edit-btn'), drawer=$('self-customizer');
    editBtn.onclick=(e)=>{ e.stopPropagation(); drawer.classList.toggle('open'); portrait.classList.toggle('customizing',drawer.classList.contains('open')); };
    document.addEventListener('click',(e)=>{
      if(!drawer.classList.contains('open')) return;
      if(drawer.contains(e.target)||e.target===editBtn) return;
      drawer.classList.remove('open'); portrait.classList.remove('customizing');
    });
    $('self-portrait-anim').onchange=(e)=>{
      const style=e.target.value;
      portrait.className='self-portrait anim-'+style+' customizing';
      if(!api()||!pywebview.api.self_portrait_set_animation) return;
      pywebview.api.self_portrait_set_animation(style).catch(()=>{});
    };
    $('self-portrait-upload-btn').onclick=()=>{
      if(!api()||!pywebview.api.self_portrait_upload) return;
      const btn=$('self-portrait-upload-btn'); btn.disabled=true; btn.textContent='Uploading…';
      pywebview.api.self_portrait_upload().then(r=>{
        btn.disabled=false; btn.textContent='Change image…';
        if(!r||r.ok===false){ if(r&&r.message) toast(r.message,true); return; }
        if(r.image_data_url) portrait.style.setProperty('--portrait-image','url("'+r.image_data_url+'")');
      }).catch(e=>{ btn.disabled=false; btn.textContent='Change image…'; toast('Could not upload image: '+e,true); });
    };
  }
  const collapseBtn=$('cc-chat-list-collapse');
  if(collapseBtn && !collapseBtn.dataset.bound){
    collapseBtn.dataset.bound='1';
    const applyChatListCollapse=(collapsed)=>{
      const panel=document.querySelector('.command-chat-panel');
      if(!panel) return;
      panel.classList.toggle('chat-list-collapsed', collapsed);
      collapseBtn.textContent=collapsed?'»':'«';
      collapseBtn.title=collapsed?'Show conversations':'Hide conversations';
    };
    applyChatListCollapse(localStorage.getItem('ccChatListCollapsed')!=='0');
    collapseBtn.onclick=()=>{
      const panel=document.querySelector('.command-chat-panel');
      const collapsed=!(panel&&panel.classList.contains('chat-list-collapsed'));
      localStorage.setItem('ccChatListCollapsed', collapsed?'1':'0');
      applyChatListCollapse(collapsed);
    };
  }
  const fsBtn=$('cc-fullscreen-toggle');
  if(fsBtn && !fsBtn.dataset.bound){
    fsBtn.dataset.bound='1';
    const setChatFullscreen=(on)=>{
      document.body.classList.toggle('chat-fullscreen', on);
      fsBtn.textContent=on?'⤡':'⤢';
      fsBtn.title=on?'Exit fullscreen':'Expand chat';
    };
    fsBtn.onclick=()=>setChatFullscreen(!document.body.classList.contains('chat-fullscreen'));
    if(!document.body.dataset.ccFsEscBound){
      document.body.dataset.ccFsEscBound='1';
      document.addEventListener('keydown',e=>{
        if(e.key==='Escape' && document.body.classList.contains('chat-fullscreen')) setChatFullscreen(false);
      });
    }
  }
}
function loadSelfPortrait(){
  if(!api()||!pywebview.api.self_portrait_state) return;
  pywebview.api.self_portrait_state().then(r=>{
    if(!r||r.ok===false) return;
    const portrait=$('self-portrait'); if(!portrait) return;
    const style=r.animation||'still';
    portrait.className='self-portrait anim-'+style;
    const sel=$('self-portrait-anim'); if(sel) sel.value=style;
    if(r.image_data_url) portrait.style.setProperty('--portrait-image','url("'+r.image_data_url+'")');
  }).catch(()=>{});
}
function loadCommandCenter(){
  bindCommandCenter();
  loadSelf();
  loadSelfPortrait();
  loadCommandChat();
}

/* ---------- self dashboard ---------- */
function clamp(n,min,max){ return Math.max(min,Math.min(max,n)); }

function selfBlocks(value){
  const count=Math.round(clamp(value||0,0,100)/10);
  return '<div class="self-blocks">'+Array.from({length:10},(_,i)=>
    '<i class="'+(i<count?'on':'')+'"></i>').join('')+'</div>';
}

function selfMetricBar(label,value){
  const v=value==null?0:clamp(value,0,100);
  return '<div class="self-bar-card"><div class="self-bar-head"><span>'+esc(label)+
    '</span><span>'+(value==null?'unknown':Math.round(v)+'%')+'</span></div>'+selfBlocks(v)+'</div>';
}

function selfTasks(node,out){
  out=out||[];
  if(!node) return out;
  if(node.type==='task'&&node.status!=='archived'&&node.status!=='paused') out.push(node);
  (node.children||[]).forEach(child=>selfTasks(child,out));
  return out;
}

function selfPriorityRank(task){
  const p={high:3,normal:2,low:1}[task.priority||'normal']||2;
  const due=task.due_date?new Date(task.due_date+'T00:00:00').getTime():Number.MAX_SAFE_INTEGER;
  return {priority:p,due};
}

function selfSortedTasks(tasks){
  return [...tasks].sort((a,b)=>{
    if(a.status==='completed'&&b.status!=='completed') return 1;
    if(a.status!=='completed'&&b.status==='completed') return -1;
    const ar=selfPriorityRank(a), br=selfPriorityRank(b);
    if(br.priority!==ar.priority) return br.priority-ar.priority;
    if(ar.due!==br.due) return ar.due-br.due;
    return (a.position||0)-(b.position||0);
  });
}

function selfCuriositySnapshots(curiosities){
  return (curiosities||[]).filter(c=>c.metric_profile&&c.metric_snapshot);
}

function selfStateAverages(curiosities){
  const totals={};
  selfCuriositySnapshots(curiosities).forEach(c=>{
    const labels={};
    ((c.metric_profile&&c.metric_profile.state_metrics)||[]).forEach(d=>{ labels[d.slug]=d.label; });
    Object.entries((c.metric_snapshot&&c.metric_snapshot.state)||{}).forEach(([slug,value])=>{
      const key=labels[slug]||slug;
      if(!totals[key]) totals[key]={sum:0,n:0};
      totals[key].sum+=value; totals[key].n+=1;
    });
  });
  return Object.entries(totals).map(([label,x])=>({label,value:x.sum/x.n}));
}

function selfFormatHour(h){
  const hour=((h%24)+24)%24;
  const period=hour<12?'AM':'PM';
  const twelve=hour%12===0?12:hour%12;
  return twelve+' '+period;
}
function selfTimeAgo(iso){
  if(!iso) return 'never';
  const then=new Date(iso).getTime();
  if(isNaN(then)) return 'never';
  const mins=Math.floor((Date.now()-then)/60000);
  if(mins<1) return 'just now';
  if(mins<60) return mins+'m ago';
  const hours=Math.floor(mins/60);
  if(hours<24) return hours+'h ago';
  return Math.floor(hours/24)+'d ago';
}
function selfCollapsibleList(rowsHtml, limit){
  limit = limit||4;
  if(!rowsHtml.length) return '';
  if(rowsHtml.length<=limit) return rowsHtml.join('');
  const hiddenCount = rowsHtml.length-limit;
  return '<div class="self-collapsible">'+
    rowsHtml.slice(0,limit).join('')+
    '<div class="self-collapse-extra" hidden>'+rowsHtml.slice(limit).join('')+'</div>'+
    '<button type="button" class="self-collapse-toggle" data-hidden-count="'+hiddenCount+'">See '+hiddenCount+' more</button>'+
  '</div>';
}

function selfCardBackgroundStyle(index, images){
  let style='min-height:92px';
  if(images&&images.length){
    const url=images[index % images.length];
    style+=';background-image:linear-gradient(180deg,rgba(10,35,22,.15),rgba(4,12,8,.9)), url(&quot;'+esc(url)+'&quot;)';
  }
  return ' style="'+style+'"';
}

function curiosityOpenCount(cur){
  const counts=cur.item_counts||{};
  return (counts.open_questions||0)+(counts.open_suggestions||0);
}

function curiosityTopicTokens(cur){
  const stop=new Set(['investigation','investigations','curiosity','curiosities','journal',
    'current','framing','about','around','from','into','with','that','this','does',
    'what','why','when','where','really','thing','things','issue','issues']);
  return new Set(String(((cur&&cur.label)||'')+' '+((cur&&cur.directive)||'')).toLowerCase()
    .match(/[a-z][a-z'-]*/g)?.map(w=>w.endsWith("'s")?w.slice(0,-2):w)
    .filter(w=>w.length>=3&&!stop.has(w)) || []);
}

function curiositySimilarTopic(a,b){
  if(!a.size||!b.size) return false;
  if(a.size===b.size && [...a].every(x=>b.has(x))) return true;
  const smaller=Math.min(a.size,b.size);
  if(smaller<2) return false;
  let overlap=0; a.forEach(x=>{ if(b.has(x)) overlap++; });
  const union=new Set([...a,...b]).size;
  return overlap===smaller && overlap/union>=0.5;
}

function preferredCuriosityCard(a,b){
  if(!!a.is_greatest!==!!b.is_greatest) return a.is_greatest?a:b;
  const openA=curiosityOpenCount(a), openB=curiosityOpenCount(b);
  if(openA!==openB) return openA>openB?a:b;
  return (a.id||0)<=(b.id||0)?a:b;
}

function dedupeCuriositiesForDisplay(curiosities){
  const visible=[];
  (curiosities||[]).forEach(cur=>{
    const tokens=curiosityTopicTokens(cur);
    const idx=visible.findIndex(existing=>
      curiositySimilarTopic(tokens, curiosityTopicTokens(existing)));
    if(idx<0){
      visible.push(cur);
    } else {
      visible[idx]=preferredCuriosityCard(visible[idx], cur);
    }
  });
  return visible;
}

function selfInvestigationCardHtml(cur, index, images){
  const counts=cur.item_counts||{};
  const waiting=(counts.open_questions||0)+(counts.open_suggestions||0);
  const total=counts.total||0;
  const percent=total?Math.round(((counts.resolved||0)/total)*100):0;
  return '<div class="self-pursuit self-investigation-card" data-curiosity-id="'+cur.id+
    '"'+selfCardBackgroundStyle(index,images)+'>'+
    '<div class="self-pursuit-body">'+
    '<div class="self-pursuit-title">'+(cur.is_greatest?'★':'◆')+' '+esc(cur.label)+'</div>'+
    '<div class="self-pursuit-meta"><span>'+(waiting?waiting+' waiting on you':(cur.status||'active'))+'</span>'+
    '<div class="metric-progress" style="flex:1"><i style="width:'+percent+'%"></i></div></div>'+
    '</div></div>';
}

function selfInvestigationsHtml(curiosities, checkinHour, images){
  const active=dedupeCuriositiesForDisplay(
    (curiosities||[]).filter(c=>c.status!=='archived'&&c.status!=='paused'));
  const timeLabel=checkinHour!=null?selfFormatHour(checkinHour):null;
  if(!active.length){
    return '<div class="self-empty">No active investigations yet. Start one from this chat or the Investigations tab.</div>';
  }
  return (timeLabel?'<div class="hint" style="margin-bottom:10px">Auto check-ins run around '+timeLabel+' most evenings.</div>':'')+
    '<div class="self-pursuit-grid">'+active.slice(0,8).map((cur,i)=>
      selfInvestigationCardHtml(cur,i,images)).join('')+'</div>';
}

function selfPriorityTodayHtml(todayFocus){
  const picks=(todayFocus&&todayFocus.picks)||[];
  if(!picks.length){
    return '<div class="self-empty">No active priority Leaves right now.</div>';
  }
  return picks.map(p=>'<div class="self-scenario-row"><b>'+esc(p.title||('Leaf #'+p.id))+'</b>'+
    (p.reason?'<div class="hint" style="margin:4px 0 0">'+esc(p.reason)+'</div>':'')+'</div>').join('');
}

function selfLevelWidgetHtml(data){
  const goals=data.goals||{}, tree=goals.tree||null, curiosities=(data.curiosity&&data.curiosity.curiosities)||[];
  const rootTitle=(tree&&tree.title)||'Actualized Self';
  const snapshots=selfCuriositySnapshots(curiosities);
  const totalXp=snapshots.reduce((sum,c)=>sum+((c.metric_snapshot&&c.metric_snapshot.total_xp)||0),0);
  const level=Math.max(1,Math.floor(totalXp/100)+1);
  const rank=level>=50?'S-Rank':level>=35?'A-Rank':level>=25?'B-Rank':level>=12?'C-Rank':'E-Rank';
  const nextXp=100-(totalXp%100||0);
  return '<div class="self-identity-summary"><h3>'+esc(rootTitle)+'</h3>'+
      '<div class="self-rank"><span>⌃ Level: '+level+'</span><span>'+rank+'</span></div>'+
      '<div class="self-quest-card"><b>'+totalXp+'</b><div class="hint" style="margin:2px 0 0">To reach Level '+(level+1)+' attain '+nextXp+' XP</div></div>'+
    '</div>';
}

function selfProfileWidgetsHtml(data){
  const goals=data.goals||{}, tree=goals.tree||null, curiosities=(data.curiosity&&data.curiosity.curiosities)||[];
  const states=selfStateAverages(curiosities);
  const tasks=selfSortedTasks(selfTasks(tree));
  const activeTasks=tasks.filter(t=>t.status!=='completed');
  const doneTasks=tasks.filter(t=>t.status==='completed');
  const quests=activeTasks.concat(doneTasks).slice(0,10);
  const proposals=(data.goalAi&&data.goalAi.overview&&data.goalAi.overview.open_proposals)||0;
  const blocked=(data.goalAi&&data.goalAi.overview&&data.goalAi.overview.blocked)||0;
  const questions=(data.goalAi&&data.goalAi.overview&&data.goalAi.overview.open_questions)||0;
  const attention=[
    proposals?proposals+' proposal(s) waiting for approval':'',
    questions?questions+' question(s) waiting for you':'',
    blocked?blocked+' blocked node(s) need care':''
  ].filter(Boolean);
  const todayRows=quests.map(t=>'<label class="self-task '+(t.status==='completed'?'done':'')+'">'+
    '<input type="checkbox" class="self-task-toggle" data-id="'+t.id+'" '+(t.status==='completed'?'checked':'')+'>'+
    '<span>'+esc(t.title)+'</span></label>');
  return '<div class="command-widget"><h3>Daily energy</h3>'+
      (states.length?states.slice(0,6).map(x=>selfMetricBar(x.label,x.value)).join(''):
        '<div class="self-empty">No daily state check-ins from Growth/Investigations yet — answer a few reflection questions that track how you\'re feeling to populate this.</div>')+
    '</div>'+
    '<div class="command-widget"><h3>Needs attention</h3>'+
      (attention.length?attention.map(x=>'<div class="self-scenario-row">'+esc(x)+'</div>').join(''):
        '<div class="self-empty">No urgent strategy branches right now.</div>')+
    '</div>'+
    '<div class="command-widget"><h3>Highest priority today</h3>'+
      selfPriorityTodayHtml(data.todayFocus)+
    '</div>'+
    '<div class="command-widget"><h3>@Today</h3>'+
      (todayRows.length?selfCollapsibleList(todayRows,4):
        '<div class="self-empty">No active Leaves yet. Add a Leaf in Growth to populate today’s quest list.</div>')+
    '</div>';
}

function selfSidebarHtml(data){
  const calibration=data.calibration&&data.calibration.ok?data.calibration:null;
  if(!calibration||calibration.complete) return '';
  return '<div class="command-widget" id="self-soul-calibration"><h3>Soul Calibration</h3>'+
    '<div class="hint">'+calCovered(calibration)+'/'+(calibration.total||0)+' covered</div>'+
    (calibration.sections||[]).map(sec=>{
      const attrs=(sec.attributes||[]).filter(a=>a.state!=='skipped');
      if(!attrs.length) return '';
      return '<div class="calibration-section">'+esc(sec.section)+'</div>'+
      attrs.map(a=>{
        const mark=a.state==='done'?'✓':'○';
        return '<div class="calibration-row '+a.state+'"><span class="cal-mark">'+mark+'</span><span>'+esc(a.label)+'</span></div>';
      }).join('')
    }).join('')+
    '<div class="actions" style="margin-top:10px">'+
      '<button type="button" id="self-open-calibration" class="accent">'+
      (calCovered(calibration)?'Continue Soul Calibration':'Start Soul Calibration')+'</button></div>'+
  '</div>';
}

function bindSelfDashboard(){
  const calBtn=$('self-open-calibration'); if(calBtn) calBtn.onclick=openSoulCalDrawer;
  document.querySelectorAll('.self-task-toggle').forEach(box=>{
    box.onchange=()=>{
      if(!api()) return;
      const id=parseInt(box.dataset.id,10);
      const next=box.checked?'completed':'active';
      const prev=box.checked?'active':'completed';
      box.disabled=true;
      updateGoalStatusWithUndo(id,next,prev,()=>{ loadSelf(); if(goalState) loadGoals(); },
        ()=>{ box.checked=!box.checked; box.disabled=false; });
    };
  });
  document.querySelectorAll('.self-collapse-toggle').forEach(btn=>{
    btn.onclick=()=>{
      const wrap=btn.closest('.self-collapsible');
      const extra=wrap.querySelector('.self-collapse-extra');
      if(extra.hasAttribute('hidden')){
        extra.removeAttribute('hidden');
        btn.textContent='See less';
      } else {
        extra.setAttribute('hidden','');
        btn.textContent='See '+btn.dataset.hiddenCount+' more';
      }
    };
  });
  document.querySelectorAll('.self-investigation-card').forEach(card=>{
    card.onclick=()=>{
      activeCuriosityId=parseInt(card.dataset.curiosityId,10);
      switchView('curiosity');
    };
  });
}

function updateGoalStatusWithUndo(goalId,nextStatus,previousStatus,onDone,onFail){
  withDbRetry(()=>pywebview.api.goal_update(goalId,{status:nextStatus})).then(r=>{
    if(!r||r.ok===false){
      if(onFail) onFail();
      toast((r&&r.message)||'Could not update task.',true);
      return;
    }
    if(onDone) onDone(r);
    if(nextStatus==='completed'){
      toast('Leaf marked complete.','', 'Undo', ()=>{
        withDbRetry(()=>pywebview.api.goal_update(goalId,{status:previousStatus})).then(u=>{
          if(!u||u.ok===false){ toast((u&&u.message)||'Could not undo.',true); return; }
          toast('Leaf restored.');
          if(onDone) onDone(u);
        }).catch(e=>toast('Could not undo: '+e,true));
      },7000);
    }
  }).catch(e=>{
    if(onFail) onFail();
    toast('Could not update task: '+e,true);
  });
}

function runDatabaseRescue(){
  if(!api()) return;
  $('self-status').innerHTML='<span class="spin"></span>Checking database locks…';
  pywebview.api.database_unlock().then(r=>{
    $('self-status').textContent='';
    if(!r||r.ok===false){ toast((r&&r.message)||'Database rescue failed.',true); return; }
    toast('Database rescue finished. If a window was holding a lock, retry the action now.');
  }).catch(e=>{
    $('self-status').textContent='';
    toast('Database rescue failed: '+e,true);
  });
}

let backgroundImagesCache=null;
function loadBackgroundImages(){
  if(backgroundImagesCache) return Promise.resolve(backgroundImagesCache);
  if(!api()||!pywebview.api.background_images) return Promise.resolve([]);
  return pywebview.api.background_images().then(r=>{
    backgroundImagesCache=(r&&r.ok&&r.images&&r.images.length)?r.images:[];
    return backgroundImagesCache;
  }).catch(()=>[]);
}

function loadSelf(opts){
  opts=opts||{};
  if(!api()) return;
  $('self-status').innerHTML='<span class="spin"></span>Gathering tree, check-ins, and GoalAI…';
  bridgeTimeout(Promise.all([
    pywebview.api.goal_state().catch(()=>null),
    pywebview.api.curiosity_state().catch(()=>null),
    pywebview.api.goal_ai_state().catch(()=>null),
    (pywebview.api.command_calibration_status?pywebview.api.command_calibration_status():Promise.resolve(null)).catch(()=>null),
    (pywebview.api.self_today_focus?pywebview.api.self_today_focus(!!opts.forceFocus):Promise.resolve(null)).catch(()=>null),
    loadBackgroundImages()
  ]),'Command widgets',20000).then(([goals,curiosity,goalAi,calibration,todayFocus,images])=>{
    $('self-status').textContent='';
    const data={goals:goals||{},curiosity:curiosity||{},goalAi:goalAi||{},
      calibration:calibration||{},todayFocus:todayFocus||{}};
    const curiosities=(data.curiosity&&data.curiosity.curiosities)||[];
    const checkinHour=data.curiosity&&data.curiosity.checkin_hour;
    if($('self-level-widget')){
      $('self-level-widget').className='';
      $('self-level-widget').innerHTML=selfLevelWidgetHtml(data);
    }
    if($('self-profile-widgets')){
      $('self-profile-widgets').className='';
      $('self-profile-widgets').innerHTML=selfProfileWidgetsHtml(data);
    }
    if($('self-investigations-cards')){
      $('self-investigations-cards').className='';
      $('self-investigations-cards').innerHTML=selfInvestigationsHtml(curiosities,checkinHour,images);
    }
    const sidebarHtml=selfSidebarHtml(data);
    const shell=document.querySelector('.command-center-shell');
    const sidebar=$('self-dashboard');
    if(sidebarHtml){
      if(shell) shell.classList.remove('no-sidebar');
      sidebar.style.display='';
      sidebar.className='command-side';
      sidebar.innerHTML=sidebarHtml;
    } else {
      if(shell) shell.classList.add('no-sidebar');
      sidebar.style.display='none';
      sidebar.innerHTML='';
    }
    bindSelfDashboard();
  }).catch(e=>{
    $('self-status').textContent='';
    if($('self-profile-widgets')){
      $('self-profile-widgets').className='self-empty';
      $('self-profile-widgets').textContent='Could not load dashboard: '+e;
    }
    $('self-dashboard').className='command-side self-empty';
    $('self-dashboard').textContent='Could not load dashboard: '+e;
  });
}

if($('header-refresh-self')) $('header-refresh-self').onclick=()=>{
  const btn=$('header-refresh-self');
  btn.classList.remove('spinning'); void btn.offsetWidth; btn.classList.add('spinning');
  refreshActiveView();
};
$('self-database-rescue').onclick=runDatabaseRescue;
if($('cc-send')) $('cc-send').onclick=sendCommandMessage;
if($('cc-attach')) $('cc-attach').onclick=attachCommandFile;
if($('cc-new-chat')) $('cc-new-chat').onclick=()=>pywebview.api.command_new_chat().then(renderCommandChat).catch(e=>toast('Could not create chat: '+e,true));
if($('cc-delete-chat')) $('cc-delete-chat').onclick=()=>{
  const active=commandChatState&&commandChatState.active_chat_id;
  if(!active) return;
  if(!confirm('Delete this conversation?')) return;
  pywebview.api.command_delete_chat(active).then(renderCommandChat).catch(e=>toast('Could not delete chat: '+e,true));
};

let ccCtxChatId=null;
function hideCcCtxMenu(){
  const menu=$('cc-chat-ctx-menu');
  if(menu) menu.style.display='none';
  ccCtxChatId=null;
}
function showCcCtxMenu(x,y,chatId){
  const menu=$('cc-chat-ctx-menu'); if(!menu) return;
  ccCtxChatId=chatId;
  menu.style.display='block';
  menu.style.left='0px'; menu.style.top='0px';
  const maxX=Math.max(4,window.innerWidth-menu.offsetWidth-8);
  const maxY=Math.max(4,window.innerHeight-menu.offsetHeight-8);
  menu.style.left=Math.min(x,maxX)+'px';
  menu.style.top=Math.min(y,maxY)+'px';
}
document.addEventListener('click',()=>hideCcCtxMenu());
document.addEventListener('scroll',()=>hideCcCtxMenu(),true);
const ccCtxMenu=$('cc-chat-ctx-menu');
if(ccCtxMenu){
  ccCtxMenu.addEventListener('click',e=>e.stopPropagation());
  const renameBtn=ccCtxMenu.querySelector('[data-action="rename"]');
  const deleteBtn=ccCtxMenu.querySelector('[data-action="delete"]');
  if(renameBtn) renameBtn.onclick=()=>{
    const chatId=ccCtxChatId; hideCcCtxMenu();
    if(!chatId||!api()) return;
    const current=((commandChatState&&commandChatState.chats)||[]).find(c=>String(c.id)===String(chatId));
    const title=prompt('Rename conversation', (current&&current.title)||'');
    if(title===null) return;
    const trimmed=title.trim();
    if(!trimmed) return;
    pywebview.api.command_rename_chat(chatId,trimmed).then(renderCommandChat)
      .catch(e=>toast('Could not rename chat: '+e,true));
  };
  if(deleteBtn) deleteBtn.onclick=()=>{
    const chatId=ccCtxChatId; hideCcCtxMenu();
    if(!chatId||!api()) return;
    if(!confirm('Delete this conversation? This cannot be undone.')) return;
    pywebview.api.command_delete_chat(chatId).then(renderCommandChat)
      .catch(e=>toast('Could not delete chat: '+e,true));
  };
}

/* ---------- import (file drop) ---------- */
let needsReset=false;
$('drop-year').value = new Date().getFullYear();

function loadStaged(){
  if(!api()) return;
  pywebview.api.journal_files().then(r=>{
    const box=$('staged');
    if(!r.files || !r.files.length){
      box.innerHTML='<div class="empty" style="padding:14px">Nothing staged yet — drop files above.</div>';
    } else {
      box.innerHTML = r.files.map(f=>{
        const warn=(f.warnings||[]);
        return '<div class="staged-row"><span class="sf-name">'+esc(f.source)+'</span>' +
        (warn.length ? '<span class="sf-status changed" title="'+esc(warn.join('\n'))+
          '">⚠ '+warn.length+' date warning'+(warn.length>1?'s':'')+'</span>' : '') +
        '<span class="sf-status '+esc(f.status||'new')+'">'+
          (f.status==='imported'?'✓ imported':esc(f.status||'new'))+'</span>' +
        '<span class="sf-meta">'+f.entries+' entries · '+f.dated+' dated' +
        (f.from ? ' · '+esc(f.from)+' → '+esc(f.to) : '') + '</span>' +
        '<button class="sf-remove" data-file="'+esc(f.file||'')+'" title="Remove from staging (file is deleted; memory is untouched)">✕</button>' +
        '</div>' +
        (warn.length ? '<div class="sf-warn">'+warn.map(w=>'⚠ '+esc(w)).join('<br>')+'</div>' : '');
      }).join('');
      box.querySelectorAll('.sf-remove').forEach(btn=>{
        btn.onclick=()=>{
          const file=btn.dataset.file;
          if(!file || !confirm('Remove "'+file+'" from staging?\nThe staged copy is deleted (memory and your original document are untouched).')) return;
          pywebview.api.remove_journal_file(file).then(res=>{
            if(res && res.ok){ toast('Removed '+res.removed+'.'); loadStaged(); }
            else toast((res&&res.message)||'Could not remove.', true);
          }).catch(e=>toast('Could not remove: '+e, true));
        };
      });
    }
    needsReset=!!r.needs_reset;
    const t=$('reset-toggle');
    t.classList.toggle('on', needsReset);
    $('import-status').textContent = r.watermark
      ? 'imported through '+r.watermark+(needsReset?' — older entries staged, reset recommended':'')
      : 'never imported yet';
  }).catch(()=>{});
}
$('reset-toggle').onclick=()=>{ needsReset=!needsReset;
  $('reset-toggle').classList.toggle('on', needsReset); };
let deepOn=false;
$('deep-toggle').onclick=()=>{ deepOn=!deepOn;
  $('deep-toggle').classList.toggle('on', deepOn); };

const dz=$('dropzone');
['dragover','dragenter'].forEach(ev=>dz.addEventListener(ev,e=>{
  e.preventDefault(); dz.classList.add('hover'); }));
['dragleave','dragend'].forEach(ev=>dz.addEventListener(ev,()=>dz.classList.remove('hover')));
dz.addEventListener('drop', e=>{
  e.preventDefault(); dz.classList.remove('hover');
  const files=Array.from(e.dataTransfer.files||[]);
  if(!files.length) return;
  let done=0, results=[];
  $('import-status').innerHTML='<span class="spin"></span>staging '+files.length+' file(s)…';
  files.forEach(file=>{
    if(file.size > 8*1024*1024){ results.push(file.name+': too large (8MB cap)');
      if(++done===files.length) finishDrop(results); return; }
    const isDocx=/\.docx$/i.test(file.name);
    const reader=new FileReader();
    reader.onload=()=>{
      const payload = isDocx ? String(reader.result).split(',')[1] : reader.result;
      pywebview.api.ingest_file(file.name, payload,
          parseInt($('drop-year').value,10)||new Date().getFullYear(),
          isDocx?'base64':'text')
        .then(r=>{ results.push(r.ok
            ? r.file+': '+r.entries+' entries ('+r.dated+' dated'+(r.from?', '+r.from+' → '+r.to:'')+')'
            : file.name+': '+(r.message||'failed'));
          if(++done===files.length) finishDrop(results); })
        .catch(err=>{ results.push(file.name+': '+err);
          if(++done===files.length) finishDrop(results); });
    };
    reader.onerror=()=>{ results.push(file.name+': could not read');
      if(++done===files.length) finishDrop(results); };
    if(isDocx) reader.readAsDataURL(file); else reader.readAsText(file);
  });
});
function finishDrop(results){
  toast(results.length===1 ? results[0] : results.length+' file(s) staged.');
  loadStaged();
}

function runImport(){
  if(!api()) return;
  const btn=$('btn-import');
  btn.disabled=true;
  $('import-status').innerHTML='<span class="spin"></span>importing… (calls the model; may take a minute)';
  pywebview.api.run_journal_import(false, needsReset, deepOn).then(r=>{
    $('btn-import').disabled=false;
    $('import-status').textContent='';
    if(!r || r.ok===false){ toast((r&&r.message)||'Import failed.', true); return; }
    const lines=['IMPORTED · '+r.batches+' batch(es), '+r.entries+' entrie(s)'];
    if(r.filter) lines.push('filter kept '+r.filter.kept+'/'+r.filter["in"]+
      ' ('+r.filter.dropped_short+' short, '+r.filter.dropped_duplicate+' dup, '+
      r.filter.dropped_low_signal+' low-signal)');
    (r.months||[]).forEach(m=>lines.push(m.month+': +'+m.added+' added, '+
      m.superseded+' superseded, '+m.duplicate+' dup, '+m.stale+' stale, '+
      m.low_confidence+' low-conf'));
    if(!(r.months||[]).length) lines.push('nothing to do — all months behind the watermark (toggle reset).');
    const box=$('import-result'); box.style.display='block';
    box.innerHTML='<pre>'+esc(lines.join('\n'))+'</pre>';
    toast('Imported — check the Timeline.'); loadStaged();
  }).catch(e=>{ $('btn-import').disabled=false;
    $('import-status').textContent=''; toast('Import failed: '+e, true); });
}
$('btn-import').onclick=runImport;
document.addEventListener('dragover', e=>e.preventDefault());
document.addEventListener('drop', e=>e.preventDefault());

$('consolidate-btn').onclick=()=>{
  if(!api()) return;
  const btn=$('consolidate-btn'); btn.disabled=true;
  $('consolidate-status').innerHTML='<span class="spin"></span>Tidying up…';
  pywebview.api.consolidate_now().then(r=>{
    btn.disabled=false; $('consolidate-status').textContent='';
    if(!r || r.ok===false){ toast((r&&r.message)||'Consolidate failed.', true); return; }
    toast(r.merged
      ? 'Merged '+r.merged+' duplicate(s) in '+r.groups+' group(s).'
      : 'Nothing to merge — memory is already tidy.');
  }).catch(e=>{ btn.disabled=false; $('consolidate-status').textContent='';
    toast('Consolidate failed: '+e, true); });
};

/* ---------- timeline ---------- */
const MONTHS=['January','February','March','April','May','June','July',
  'August','September','October','November','December'];
function loadTimeline(){
  if(!api()) return;
  pywebview.api.memory(true).then(groups=>{
    const facts=[];
    (groups||[]).forEach(g=>g.facts.forEach(f=>{
      if(f.valid_from) facts.push({...f, category:g.category});
    }));
    facts.sort((a,b)=> a.valid_from<b.valid_from?1 : a.valid_from>b.valid_from?-1
      : (a.status==='active') - (b.status==='active'));
    const box=$('tl-groups'); let month='', html='';
    facts.forEach(f=>{
      const m=f.valid_from.slice(0,7);
      if(m!==month){ month=m;
        const label=MONTHS[parseInt(m.slice(5,7),10)-1]+' '+m.slice(0,4);
        html+='<div class="tl-month">'+esc(label)+'</div>'; }
      const sup=f.status && f.status!=='active';
      html+='<div class="tl-row'+(sup?' superseded':'')+'">' +
        '<span class="tl-date">'+esc(f.valid_from)+'</span>' +
        '<span class="tl-cat">'+esc(f.category)+'</span>' +
        '<span class="tl-body"><span class="tl-attr">'+esc(f.attribute)+' — </span>' +
        '<span class="tl-val">'+esc(f.value)+'</span>' +
        (sup && f.valid_to ? ' <span class="tl-until">→ revised '+esc(f.valid_to)+'</span>' : '') +
        '</span></div>';
    });
    box.innerHTML = html ||
      '<div class="card"><div class="empty">No dated facts yet — run capture, triage, or a journal import.</div></div>';
  }).catch(()=>{});
}

/* ---------- inferences ---------- */
function renderState(s){
  GATE = s.gate || 0.8;
  if($('backend')) $('backend').textContent = 'backend: ' + (s.backend||'?');
  $('gate-label').textContent = 'needs ' + pct(GATE);
  $('gate-hint').textContent =
    'Claims above ' + pct(GATE) + ' appear as hypotheses. Address opens a focused conversation ' +
    'where you can test and rewrite the idea before accepting it. Approval—not the model\'s ' +
    'percentage—turns it into a settled belief.';

  const resume=$('inquiry-resume');
  const open=s.inquiries||[];
  resume.innerHTML=open.length
    ? '<span class="hint" style="margin:5px 2px 0 0">Continue:</span>' + open.map(q=>
        '<button class="inquiry-open" data-id="'+q.id+'">'+
        esc((q.kind==='address'?'Address: ':'Investigate: ')+q.prompt.slice(0,55))+ '</button>').join('')
    : '';
  resume.querySelectorAll('.inquiry-open').forEach(btn=>btn.onclick=()=>openInquiryById(btn.dataset.id));

  const stack=$('stack');
  if(!s.stack || !s.stack.length){
    stack.innerHTML = '<div class="card"><div class="empty">Nothing has reached ' + pct(GATE) +
      ' yet — I\'m still gathering evidence (see "Still forming" below).<br>' +
      '"Regenerate inferences" does another bounded pass.</div></div>';
  } else {
    stack.innerHTML = s.stack.map(cardHtml).join('');
    s.stack.forEach(c=>bindCard(c.id));
  }

  const f=$('forming');
  if(!s.forming || !s.forming.length){
    f.innerHTML='<div class="empty" style="padding:14px">Nothing forming yet — evidence accumulates as you use your PC.</div>';
  } else {
    f.innerHTML = s.forming.map(r=>{
      const conf=r.confidence||0, w=Math.min(100, GATE?Math.round(conf/GATE*100):0);
      return '<div class="forming-row"><span class="theme-name">'+esc(r.theme)+'</span>' +
        '<div class="track"><div class="fill" style="width:'+w+'%"></div></div>' +
        '<span class="pct">'+pct(conf)+'</span>' +
        '<span class="ev">'+(r.evidence_count||0)+' evidence</span></div>';
    }).join('');
  }

  const b=$('beliefs');
  if(!s.beliefs || !s.beliefs.length){
    b.innerHTML='<div class="empty" style="padding:14px">Nothing confirmed yet — answer the cards above and beliefs land here.</div>';
  } else {
    b.innerHTML = s.beliefs.map(x=>
      '<div class="belief'+(x.is_core_belief?' core':'')+'">' +
      '<span class="star">'+(x.is_core_belief?'★':'')+'</span>' +
      '<span class="text">'+esc(x.statement)+'</span>' +
      '<span class="conf">'+(x.resolution_status==='accepted'?'approved':
        x.resolution_status==='tentative'?'tentative':pct(x.confidence))+'</span></div>').join('');
  }
}

function cardHtml(c){
  const ev=c.evidence||{}; const bits=[];
  if(ev.evidence_count) bits.push(ev.evidence_count+' pieces of evidence');
  if(ev.model_confidence) bits.push('model '+pct(ev.model_confidence));
  const confW = Math.min(100, Math.round((c.confidence||0)*100));
  return '<div class="card" id="card-'+c.id+'">' +
    '<div class="theme">'+esc(c.theme||'')+'</div>' +
    '<div class="statement">'+esc(c.statement)+'</div>' +
    '<div class="meta">' +
      '<div class="confbar"><i style="width:'+confW+'%"></i></div>' +
      '<span>'+pct(c.confidence)+' confident</span>' +
      bits.map(x=>'<span class="chip">'+esc(x)+'</span>').join('') +
    '</div>' +
    '<div class="actions">' +
      '<button class="yes address">Address</button>' +
      '<button class="skip later">Not now</button>' +
      '<button class="no wrong">Clearly wrong</button>' +
    '</div>' +
  '</div>';
}

function bindCard(id){
  const card=$('card-'+id);
  card.querySelector('.address').onclick=()=>startAddress(id);
  card.querySelector('.later').onclick=()=>answer('skip', id, null);
  card.querySelector('.wrong').onclick=()=>answer('no', id, null);
}

let ACTIVE_INQUIRY=null;

function startAddress(id){
  if(!api()) return;
  toast('Opening a focused investigation…');
  pywebview.api.inference_inquiry_start(null,id).then(handleInquiryResult)
    .catch(e=>toast('Could not start: '+e,true));
}

function startDirectedInvestigation(){
  const input=$('investigate-prompt'), prompt=input.value.trim();
  if(!prompt){ toast('Give Faerie something to investigate first.',true); return; }
  const btn=$('investigate-btn'); btn.disabled=true;
  pywebview.api.inference_inquiry_start(prompt,null).then(r=>{
    btn.disabled=false; if(r&&r.ok) input.value=''; handleInquiryResult(r);
  }).catch(e=>{ btn.disabled=false; toast('Could not start: '+e,true); });
}

function openInquiryById(id){
  if(!api()) return;
  pywebview.api.inference_inquiry_get(id).then(handleInquiryResult)
    .catch(e=>toast('Could not open investigation: '+e,true));
}

function handleInquiryResult(r){
  if(!r||r.ok===false){ toast((r&&r.message)||'Investigation failed.',true); return; }
  launchAgentWindow('inference',r.inquiry.id); loadState();
}

function launchAgentWindow(mode,id){
  if(!api()) return;
  pywebview.api.open_agent_window(mode,id).then(r=>{
    if(!r||r.ok===false) toast((r&&r.message)||'Could not open agent window.',true);
  }).catch(e=>toast('Could not open agent window: '+e,true));
}

function renderInquiry(q){
  ACTIVE_INQUIRY=q; const drawer=$('inquiry-drawer');
  drawer.classList.add('open');
  const conf=q.model_confidence==null?'not estimated':pct(q.model_confidence)+' evidential confidence';
  drawer.innerHTML=
    '<div class="inquiry-head"><div><div class="inquiry-kind">'+
      (q.kind==='address'?'Address inference':'Directed investigation')+'</div>'+
      '<div class="inquiry-prompt">'+esc(q.prompt)+'</div></div><button class="close-inquiry">Close</button></div>'+
    '<div class="inquiry-messages">'+(q.messages||[]).map(m=>
      '<div class="inquiry-msg '+m.role+'">'+esc(m.content)+'</div>').join('')+'</div>'+
    '<textarea class="inquiry-reply" placeholder="Answer Faerie’s question, add an example, or challenge its reasoning…"></textarea>'+
    '<div class="inquiry-send"><button class="accent send-inquiry">Reply</button></div>'+
    '<div class="inquiry-draft"><label>Current proposed belief</label>'+
      '<textarea class="draft-text">'+esc(q.draft_claim||'')+'</textarea>'+
      '<div class="inquiry-confidence">'+esc(conf)+' · this percentage does not approve the belief</div></div>'+
    '<div class="inquiry-decisions">'+
      '<button class="no resolve-reject">Reject</button>'+
      '<button class="skip resolve-wait">Needs more evidence</button>'+
      '<button class="kind resolve-tentative">Accept as tentative</button>'+
      '<button class="yes resolve-accept">Accept belief</button></div>';
  drawer.querySelector('.close-inquiry').onclick=()=>drawer.classList.remove('open');
  const reply=drawer.querySelector('.inquiry-reply');
  const send=()=>{
    const text=reply.value.trim(); if(!text){ toast('Write a reply first.',true); return; }
    drawer.querySelector('.send-inquiry').disabled=true;
    pywebview.api.inference_inquiry_reply(q.id,text).then(handleInquiryResult)
      .catch(e=>toast('Could not reply: '+e,true));
  };
  drawer.querySelector('.send-inquiry').onclick=send; bindShiftEnterSubmit(reply,send);
  drawer.querySelector('.resolve-accept').onclick=()=>resolveInquiry('accepted');
  drawer.querySelector('.resolve-tentative').onclick=()=>resolveInquiry('tentative');
  drawer.querySelector('.resolve-reject').onclick=()=>resolveInquiry('rejected');
  drawer.querySelector('.resolve-wait').onclick=()=>resolveInquiry('awaiting_evidence');
  drawer.scrollTop=drawer.scrollHeight;
}

function resolveInquiry(outcome){
  if(!ACTIVE_INQUIRY||!api()) return;
  const draft=$('inquiry-drawer').querySelector('.draft-text').value.trim();
  if((outcome==='accepted'||outcome==='tentative')&&!draft){
    toast('Write the belief you want to save first.',true); return;
  }
  pywebview.api.inference_inquiry_resolve(ACTIVE_INQUIRY.id,outcome,draft).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not resolve.',true); return; }
    $('inquiry-drawer').classList.remove('open'); ACTIVE_INQUIRY=null;
    toast(outcome==='accepted'?'Belief approved and similar repeats absorbed.':
      outcome==='tentative'?'Saved as tentative; similar repeats absorbed.':
      outcome==='rejected'?'Inference rejected.':'Parked until there is better evidence.');
    loadState();
  }).catch(e=>toast('Could not resolve: '+e,true));
}

const DONE_MSG={yes:'Confirmed.', no:'Rejected — the next guess will differ.',
  kind_of:'Marked partial.', skip:'Skipped.', refine:'Saved your wording as truth.'};

function answer(action, id, text){
  if(!api()) return;
  pywebview.api.answer(action, id, text).then(r=>{
    if(r && r.ok===false){ toast(r.message||'Could not apply.', true); return; }
    toast(DONE_MSG[action]||'Done.');
    loadState();
  }).catch(e=>toast('Could not apply: '+e, true));
}

function loadState(){
  if(!api()) return;
  pywebview.api.state().then(renderState).catch(()=>{});
}

$('refresh-inf').onclick=loadState;
$('investigate-btn').onclick=startDirectedInvestigation;
bindShiftEnterSubmit($('investigate-prompt'),startDirectedInvestigation);
$('run-btn').onclick=()=>{
  if(!api()) return;
  const btn=$('run-btn'); btn.disabled=true;
  $('inf-status').innerHTML='<span class="spin"></span>Thinking…';
  pywebview.api.run_inference().then(r=>{
    btn.disabled=false; $('inf-status').textContent='';
    if(r && r.error){ toast('Inference failed: '+r.error, true); return; }
    const created=(r&&r.created)||0, added=(r&&r.evidence_added)||0;
    toast(created ? created+' claim(s) reached the gate — ready below.'
      : added ? 'Filed '+added+' new piece(s) of evidence; still building confidence.'
      : 'No fresh activity to learn from this pass.');
    loadState();
  }).catch(e=>{ btn.disabled=false; $('inf-status').textContent='';
    toast('Inference failed: '+e, true); });
};

/* ---------- clarify ---------- */
let clarSelected = new Set();

function clarCardHtml(c){
  const hedgeChips=(c.hedges||[]).map(h=>'<span class="chip hedge-chip">'+esc(h)+'</span>').join('');
  return '<div class="card" id="clar-'+c.id+'">' +
    '<div class="theme"><label style="display:flex;align-items:center;gap:8px;cursor:pointer">' +
      '<input type="checkbox" class="clar-select" data-id="'+c.id+'">' +
      '<span>'+esc(c.category||'')+' · '+esc(c.attribute||'')+'</span></label></div>' +
    '<div class="clar-value">'+esc(c.currentValue||'')+'</div>' +
    (hedgeChips ? '<div class="meta">'+hedgeChips+'</div>' : '') +
    '<div class="clar-question">'+esc(c.question)+'</div>' +
    '<div class="editor open"><textarea spellcheck="false" ' +
      'placeholder="Answer in your own words…"></textarea>' +
      '<div class="row">' +
        '<button class="skip not-now">Not now</button>' +
        '<button class="accent save">Answer</button>' +
      '</div></div>' +
  '</div>';
}

function bindClarCard(c){
  const card=$('clar-'+c.id);
  card.querySelector('.clar-select').onchange=(e)=>{
    if(e.target.checked) clarSelected.add(c.id); else clarSelected.delete(c.id);
    updateClarBulkStatus();
  };
  card.querySelector('.not-now').onclick=()=>{
    if(!api()) return;
    pywebview.api.clarify_dismiss(c.id).then(r=>{
      if(r && r.ok===false){ toast(r.message||'Could not dismiss.', true); return; }
      toast('Dismissed — won\'t ask again.'); loadClarify();
    }).catch(e=>toast('Could not dismiss: '+e, true));
  };
  const answerTextarea = card.querySelector('textarea');
  const submitAnswer = ()=>{
    const text=answerTextarea.value.trim();
    if(!text){ toast('Write an answer first — or use "Not now".', true); return; }
    if(!api()) return;
    const btn=card.querySelector('.save'); btn.disabled=true;
    pywebview.api.clarify_answer(c.id, text).then(r=>{
      btn.disabled=false;
      if(r && r.ok===false){ toast(r.message||'Could not save answer.', true); return; }
      toast(r.resulting_memory_id ? 'Memory updated.' : 'Answer recorded.');
      loadClarify();
    }).catch(e=>{ btn.disabled=false; toast('Could not save answer: '+e, true); });
  };
  card.querySelector('.save').onclick=submitAnswer;
  bindShiftEnterSubmit(answerTextarea, submitAnswer);
}

function updateClarBulkStatus(){
  const n=clarSelected.size;
  $('clar-bulk-status').textContent = n ? n+' selected' : '';
}

function renderClarify(s){
  if(document.activeElement !== $('birth-date')) $('birth-date').value = s.birth_date || '';
  if(document.activeElement !== $('grade-chart-status')){
    const n = s.grade_chart_count || 0;
    $('grade-chart-status').textContent = n ? n+' grade(s) on file — used for exact date checks.' : '';
  }

  const box=$('clar-open');
  const open=s.open||[];
  clarSelected = new Set();
  $('clar-select-all').classList.remove('on');
  $('clar-bulk-bar').style.display = open.length ? 'flex' : 'none';
  updateClarBulkStatus();
  if(!open.length){
    box.innerHTML='<div class="card"><div class="empty">Nothing ambiguous waiting on you right now.<br>' +
      '"Scan for ambiguity" checks active memory for hedged wording, anachronisms, and implausible ages.</div></div>';
  } else {
    box.innerHTML = open.map(c=>clarCardHtml({...c, currentValue: c.value})).join('');
    open.forEach(c=>bindClarCard(c));
  }

  const r=$('clar-resolved');
  const resolved=s.resolved||[];
  if(!resolved.length){
    r.innerHTML='<div class="empty" style="padding:14px">Nothing resolved yet.</div>';
  } else {
    r.innerHTML = resolved.map(x=>{
      const isAuto = x.status==='answered' && (x.question||'').startsWith('[auto]');
      const question = isAuto ? x.question.replace(/^\[auto\]\s*/, '') : x.question;
      const tag = isAuto ? 'auto-fixed' : (x.status==='answered' ? 'updated' : 'dismissed');
      const tagClass = isAuto ? 'auto' : (x.status==='answered' ? 'answered' : 'dismissed');
      return '<div class="resolved-row"><div class="rr-body">' +
        '<div class="rr-q">'+esc(question)+'</div>' +
        (x.answer ? '<div class="rr-a">'+esc(x.answer)+'</div>' : '') +
        '</div><span class="rr-tag '+tagClass+'">'+tag+'</span></div>';
    }).join('');
  }
}

function loadClarify(){
  if(!api()) return;
  pywebview.api.clarify_state().then(renderClarify).catch(()=>{});
}

$('refresh-clar').onclick=loadClarify;
$('clar-scan-btn').onclick=()=>{
  if(!api()) return;
  const btn=$('clar-scan-btn'); btn.disabled=true;
  $('clar-status').innerHTML='<span class="spin"></span>Scanning…';
  pywebview.api.clarify_scan().then(r=>{
    btn.disabled=false; $('clar-status').textContent='';
    if(!r || r.ok===false){ toast((r&&r.message)||'Scan failed.', true); return; }
    toast(r.created ? r.created+' item(s) processed — check open questions and Recently resolved.' : 'Nothing new to check.');
    loadClarify();
  }).catch(e=>{ btn.disabled=false; $('clar-status').textContent='';
    toast('Scan failed: '+e, true); });
};
$('birth-date-save').onclick=()=>{
  if(!api()) return;
  pywebview.api.clarify_set_birth_date($('birth-date').value).then(r=>{
    if(!r || r.ok===false){ toast((r&&r.message)||'Could not save.', true); return; }
    let msg = $('birth-date').value ? 'Birth date saved — age checks are on.' : 'Birth date cleared.';
    if(r.resolved) msg += ' ' + r.resolved + ' open question(s) resolved.';
    toast(msg);
    loadClarify();
  }).catch(e=>toast('Could not save: '+e, true));
};
$('grade-chart-save').onclick=()=>{
  if(!api()) return;
  const btn=$('grade-chart-save'); btn.disabled=true;
  pywebview.api.clarify_set_grade_chart($('grade-chart-text').value).then(r=>{
    btn.disabled=false;
    if(!r || r.ok===false){ toast((r&&r.message)||'Could not save.', true); return; }
    let msg = r.grades ? r.grades+' grade(s) saved — used for exact date checks.' : 'Chart cleared.';
    if(r.resolved) msg += ' ' + r.resolved + ' open question(s) resolved.';
    toast(msg);
    $('grade-chart-text').value='';
    loadClarify();
  }).catch(e=>{ btn.disabled=false; toast('Could not save: '+e, true); });
};
$('clar-select-all').onclick=()=>{
  const on = !$('clar-select-all').classList.contains('on');
  $('clar-select-all').classList.toggle('on', on);
  document.querySelectorAll('#clar-open .clar-select').forEach(cb=>{
    cb.checked = on;
    const id = parseInt(cb.dataset.id, 10);
    if(on) clarSelected.add(id); else clarSelected.delete(id);
  });
  updateClarBulkStatus();
};
$('clar-bulk-dismiss').onclick=()=>{
  if(!api()) return;
  if(!clarSelected.size){ toast('Select at least one first.', true); return; }
  const ids=Array.from(clarSelected);
  if(!confirm('Dismiss '+ids.length+' selected question(s)? Won\'t ask about them again.')) return;
  const btn=$('clar-bulk-dismiss'); btn.disabled=true;
  pywebview.api.clarify_dismiss_many(ids).then(r=>{
    btn.disabled=false;
    if(!r || r.ok===false){ toast((r&&r.message)||'Bulk dismiss failed.', true); return; }
    toast(r.dismissed.length+' dismissed'+(r.errors.length ? ', '+r.errors.length+' failed' : '')+'.');
    loadClarify();
  }).catch(e=>{ btn.disabled=false; toast('Bulk dismiss failed: '+e, true); });
};
$('clar-bulk-answer').onclick=()=>{
  if(!api()) return;
  const text=$('clar-bulk-text').value.trim();
  if(!text){ toast('Write the shared answer first.', true); return; }
  if(!clarSelected.size){ toast('Select at least one first.', true); return; }
  const ids=Array.from(clarSelected);
  const btn=$('clar-bulk-answer'); btn.disabled=true;
  $('clar-bulk-status').innerHTML='<span class="spin"></span>Applying…';
  pywebview.api.clarify_answer_many(ids, text).then(r=>{
    btn.disabled=false;
    if(!r || r.ok===false){ toast((r&&r.message)||'Bulk answer failed.', true); return; }
    toast(r.answered.length+' updated'+(r.errors.length ? ', '+r.errors.length+' failed' : '')+'.');
    $('clar-bulk-text').value='';
    loadClarify();
  }).catch(e=>{ btn.disabled=false; toast('Bulk answer failed: '+e, true); });
};
$('clar-bulk-text').addEventListener('keydown', e=>{
  if(e.key==='Enter'){ e.preventDefault(); $('clar-bulk-answer').click(); }
});

/* ---------- goals ---------- */
let goalState=null, selectedGoalId=null, plannerSession=null, goalAgentView=null, goalAgentNodeId=null;
let goalFocusPending=null;
let growthViewMode='map';
let goalAIOverviewCache=null;
const constellationViewState={};
const GOAL_MAP_POS_KEY='ff-goal-map-positions-v1';
let goalMapPositions=(function(){
  try{ return JSON.parse(localStorage.getItem(GOAL_MAP_POS_KEY)||'{}')||{}; }
  catch(e){ return {}; }
})();
const descriptionDraftRequested=new Set();
const goalOverviewCursors={};
let goalOverviewFocus=null;
const goalCollapsed=new Set(JSON.parse(localStorage.getItem('goalCollapsed')||'[]'));

function saveGoalCollapsed(){
  localStorage.setItem('goalCollapsed', JSON.stringify(Array.from(goalCollapsed)));
}

function saveGoalMapPositions(){
  try{ localStorage.setItem(GOAL_MAP_POS_KEY, JSON.stringify(goalMapPositions)); }
  catch(e){}
}

function goalFind(node,id){
  if(!node) return null;
  if(node.id===id) return node;
  for(const child of (node.children||[])){ const found=goalFind(child,id); if(found) return found; }
  return null;
}

function goalContains(node,id){
  if(!node) return false;
  if(node.id===id) return true;
  return (node.children||[]).some(child=>goalContains(child,id));
}

function goalFlat(node,out){
  out=out||[]; if(!node) return out; out.push(node);
  (node.children||[]).forEach(child=>goalFlat(child,out)); return out;
}

function goalExpandPathTo(node,id){
  if(!node) return false;
  if(node.id===id) return true;
  for(const child of (node.children||[])){
    if(goalExpandPathTo(child,id)){
      goalCollapsed.delete(node.id);
      return true;
    }
  }
  return false;
}

function goalIcon(type){ return {umbrella:'✦',overgoal:'◆',subgoal:'◇',task:'✓'}[type]||'•'; }
function goalTypeLabel(type){ return {umbrella:'Soul',overgoal:'Root',subgoal:'Branch',task:'Leaf'}[type]||type; }

function goalTreeHtml(node,depth){
  if(!node) return '<div class="empty">No goal tree available.</div>';
  const children=(node.children||[]).filter(x=>x.status!=='archived');
  const collapsed=children.length&&goalCollapsed.has(node.id)&&!goalContains(node,selectedGoalId);
  if(selectedGoalId&&goalContains(node,selectedGoalId)) goalCollapsed.delete(node.id);
  const selected=node.id===selectedGoalId?' selected':'';
  const progress=node.completion&&node.completion.percent!=null?' · '+Math.round(node.completion.percent)+'%':'';
  return '<div class="goal-tree-row '+esc(node.status)+selected+(collapsed?' collapsed':'')+'" data-goal-id="'+node.id+'" '+
    'style="padding-left:'+(8+depth*17)+'px"><span class="twist '+(children.length?'has-children':'')+
    '" data-toggle-id="'+node.id+'">'+(children.length?(collapsed?'▸':'▾'):'')+'</span>'+
    '<span class="goal-icon">'+goalIcon(node.type)+'</span><span class="goal-title">'+esc(node.title)+
    '</span><span class="cur-conf">'+progress+'</span></div>'+
    (collapsed?'':children.map(c=>goalTreeHtml(c,depth+1)).join(''));
}

function renderGoalTree(){
  const tree=goalState&&goalState.tree;
  if(!selectedGoalId&&tree) selectedGoalId=tree.id;
  if(tree&&selectedGoalId) goalExpandPathTo(tree,selectedGoalId);
  $('goal-tree').innerHTML=goalTreeHtml(tree,0);
  $('goal-tree').querySelectorAll('[data-goal-id]').forEach(row=>row.onclick=()=>{
    selectGrowthNode(parseInt(row.dataset.goalId,10));
  });
  $('goal-tree').querySelectorAll('[data-toggle-id]').forEach(twist=>twist.onclick=e=>{
    e.stopPropagation();
    const id=parseInt(twist.dataset.toggleId,10);
    if(goalCollapsed.has(id)) goalCollapsed.delete(id); else goalCollapsed.add(id);
    saveGoalCollapsed(); renderGoalTree();
  });
  const selectedRow=$('goal-tree').querySelector('.goal-tree-row.selected');
  if(selectedRow&&growthViewMode==='list') selectedRow.scrollIntoView({block:'nearest'});
  renderGoalDetail();
}

function selectGrowthNode(nodeId,opts){
  opts=opts||{};
  selectedGoalId=parseInt(nodeId,10);
  if(goalState&&goalState.tree&&!goalFind(goalState.tree,selectedGoalId)) selectedGoalId=goalState.tree.id;
  if(growthViewMode==='list') renderGoalTree();
  else {
    renderMainGrowthMap();
    renderGoalFocusPanel();
    if(selectedGoalId) loadGoalAgent(selectedGoalId);
  }
  if($('growth-map-overlay')&&$('growth-map-overlay').classList.contains('open')) renderGrowthMap();
  if(opts.closeOverlay) closeGrowthMap();
}

function goalVisibleChildren(node){
  return (node&&node.children||[]).filter(x=>x.status!=='archived');
}

function goalSubtreeWeight(node){
  const children=goalVisibleChildren(node);
  if(!children.length) return 1;
  return Math.max(1, children.reduce((sum,child)=>sum+goalSubtreeWeight(child),0));
}

function goalPathTitles(node,id,path){
  if(!node) return null;
  path=(path||[]).concat(node.title);
  if(node.id===id) return path;
  for(const child of goalVisibleChildren(node)){
    const found=goalPathTitles(child,id,path);
    if(found) return found;
  }
  return null;
}

function goalLabelShort(title,max){
  title=String(title||'');
  max=max||28;
  return title.length>max ? title.slice(0,max-1).trim()+'…' : title;
}

function goalNeedsMapCare(node){
  if(!node) return false;
  if(node.status==='paused') return false;
  if(node.type==='task') return node.status==='active'&&node.priority==='high';
  const c=node.completion||{};
  return c.active_leaf_count>0 && (c.percent||0)<35;
}

function goalCompletionLabel(node){
  const c=node&&node.completion||{};
  if(c.percent==null) return 'not measured';
  const done=c.completed_leaf_count??0;
  return Math.round(c.percent)+'%'+(c.active_leaf_count!=null?' · '+done+'/'+c.active_leaf_count+' leaves':'');
}

function goalSortedActiveLeaves(node){
  const pr={high:0,normal:1,low:2};
  return goalActiveLeaves(node).sort((a,b)=>
    (pr[a.priority||'normal']??1)-(pr[b.priority||'normal']??1) ||
    String(a.due_date||'9999').localeCompare(String(b.due_date||'9999')) ||
    (a.position||0)-(b.position||0));
}

function goalUniqueQuestions(items){
  const seen=new Set(), out=[];
  items.forEach(item=>{
    if(!item||!item.question) return;
    const key=item.question.toLowerCase().replace(/\s+/g,' ').trim();
    if(seen.has(key)) return;
    seen.add(key); out.push(item);
  });
  return out.slice(0,4);
}

function goalQuestionKey(text){
  return String(text||'').toLowerCase().replace(/\s+/g,' ').trim();
}

function goalAnsweredQuestionKeys(node){
  const keys=new Set();
  (node&&node.evidence||[]).forEach(ev=>{
    if(ev.source_kind!=='focus_answer') return;
    const match=String(ev.label||'').match(/^Question:\s*([\s\S]*?)\nAnswer:/);
    if(match&&match[1]) keys.add(goalQuestionKey(match[1]));
  });
  if(goalFocusPending&&goalFocusPending.nodeId===node.id){
    (goalFocusPending.questions||[]).forEach(q=>keys.add(goalQuestionKey(q)));
  }
  return keys;
}

function goalExplicitQuestions(text){
  const out=[];
  String(text||'').replace(/([^?]{12,}\?)/g,(match,q)=>{
    const cleaned=q.replace(/\s+/g,' ').trim();
    if(cleaned.length<180) out.push(cleaned);
    return match;
  });
  return out;
}

function goalDistinctionOptions(text){
  const out=[];
  const re=/\(([a-z])\)\s*([^()]+?)(?=\s*\([a-z]\)|$)/gi;
  let match;
  while((match=re.exec(String(text||'')))&&out.length<5){
    const label=match[2].replace(/\s+/g,' ').replace(/[.?!;:]+$/,'').trim();
    if(label) out.push(label);
  }
  return out;
}

function goalSimpleQuestion(text, fallback){
  text=String(text||'').replace(/\s+/g,' ').trim();
  if(!text) return fallback;
  const first=(text.match(/[^?]{6,120}\?/)||[])[0];
  if(first) return first.trim();
  if(text.length<=115) return text.replace(/[.?!]+$/,'')+'?';
  return fallback;
}

function goalQuestionStyle(q){
  const kind=String(q.kind||'');
  if(kind.startsWith('goalai_')){
    return {
      ...q,
      question:goalSimpleQuestion(q.question,'What is the short, plain answer here?'),
      hint:'Use simple words. If the question feels wrong, say what it should ask instead.'
    };
  }
  return q;
}

function goalEvidenceQuestions(node,agentState,agentQuestions){
  const text=[node.title,node.description,agentState.next_focus].filter(Boolean).join(' ');
  const options=goalDistinctionOptions(text);
  const explicit=goalExplicitQuestions(text);
  const dynamic=(agentQuestions||[]).map((q,i)=>{
    const question=String(q.text||q.question||q||'').trim();
    return question?{kind:'goalai_'+i, question,
      hint:'GoalAI generated this from the current node context. Answer with one concrete observation first.'}:null;
  }).filter(Boolean);
  const title=node.title||'this node';
  const explicitCards=explicit.slice(0,2).map((q,i)=>({kind:'explicit_'+i, question:q,
    hint:'Answer in plain words. A short uncertain answer is okay.'}));
  const fallback=node.type==='task'?[
    {kind:'tried', question:'Did you try this yet?',
      hint:'Answer yes, no, or partly. If yes, what happened? If no, what stopped you?'},
    {kind:'hard_moment', question:'What was the first hard moment?',
      hint:'Name the exact moment it got harder, confusing, boring, scary, or draining.'},
    {kind:'next', question:'What should you try next?',
      hint:'One small action. Something you could do today or this week.'},
    {kind:'change', question:'Should this Leaf change?',
      hint:'Keep it, rewrite it, split it, pause it, or delete it — and why?'},
    ...explicitCards,
  ]:[
    {kind:'plain_problem', question:'What is the main problem here?',
      hint:'Say it in one plain sentence.'},
    {kind:'start', question:'Where does it usually start?',
      hint:'Before, during, after, or only in certain situations?'},
    {kind:'helps', question:'What seems to help?',
      hint:'Even a tiny thing counts.'},
    options.length
      ? {kind:'distinction', question:'Which option fits best?',
          hint:'Pick the closest fit, then say why in one sentence.', options}
      : {kind:'change', question:'What should change in this part of the map?',
          hint:'Add a Leaf, rewrite it, split it, pause it, or move it.'},
    ...explicitCards,
  ];
  const items=[
    ...(dynamic.length?dynamic:fallback),
    {kind:'update', question:'What should Faerie remember from this?',
      hint:'One sentence. The simplest useful takeaway.'},
  ];
  const answered=goalAnsweredQuestionKeys(node);
  return goalUniqueQuestions(items.map(goalQuestionStyle)).filter(q=>!answered.has(goalQuestionKey(q.question)));
}

function goalQuestionCards(node,agentState,agentQuestions){
  return goalEvidenceQuestions(node,agentState,agentQuestions).map((q,i)=>
    '<div class="goal-question-card" data-question-index="'+i+'"><b>'+esc(q.question)+'</b>'+
    '<div class="goal-question-hint">'+esc(q.hint||'')+'</div>'+
    (q.options&&q.options.length?'<div class="goal-question-options">'+q.options.map(x=>'<span>'+esc(x)+'</span>').join('')+'</div>':'')+
    '<textarea class="goal-focus-answer" data-question="'+esc(q.question)+'" placeholder="Answer with one concrete observation…"></textarea>'+
    '<div class="goal-answer-tools"><label>Confidence in your answer<select class="goal-focus-answer-confidence">'+
      '<option value="0.55">unsure</option><option value="0.7" selected>somewhat</option>'+
      '<option value="0.85">pretty confident</option><option value="0.95">very confident</option>'+
    '</select></label><label>Question fit<select class="goal-focus-question-fit">'+
      '<option value="useful" selected>useful</option><option value="too_broad">too broad</option>'+
      '<option value="not_relevant">not relevant</option><option value="ask_gently">ask more gently</option>'+
    '</select></label></div></div>'
  ).join('');
}

function goalFindParent(node,id,parent){
  if(!node) return null;
  if(node.id===id) return parent||null;
  for(const child of (node.children||[])){ const f=goalFindParent(child,id,node); if(f) return f; }
  return null;
}
function goalFocusMode(node){
  if(node.type==='task') return 'leaf';
  if(node.type==='subgoal') return goalActiveLeaves(node).length?'locked':'brainstorm';
  return 'rollup';
}
function goalChildStateText(child){
  if(child.status==='completed') return 'done';
  if(child.status==='paused') return 'paused';
  if(child.type==='task') return 'active Leaf';
  const leaves=goalSortedActiveLeaves(child);
  if(leaves.length) return 'waiting on “'+leaves[0].title+'”';
  return 'needs rethink';
}
function goalRollupHtml(node){
  const kids=(node.children||[]).filter(k=>k.status!=='archived');
  if(!kids.length) return '<p class="goal-focus-muted">Nothing underneath yet — add the first '+
    (node.type==='umbrella'?'Root':'Branch')+'.</p>';
  return '<div>'+kids.map(k=>'<span class="goal-chip goal-rollup-chip" data-open="'+k.id+'">'+
    esc(k.title)+' · '+esc(goalChildStateText(k))+'</span>').join('')+'</div>';
}
function goalBrainstormCards(node){
  const title=node.title||'this Branch';
  const kids=node.children||[];
  const archived=kids.filter(k=>k.type==='task'&&k.status==='archived');
  const completed=kids.filter(k=>k.type==='task'&&k.status==='completed');
  const lastRef=archived.length?archived[archived.length-1]
    :completed.length?completed[completed.length-1]:null;
  const qs=[
    {kind:'learned', question:lastRef?'What did that last Leaf teach you?'
      :'What do you already know here?',
     hint:'One real thing you have noticed. Short is fine.'},
    {kind:'diagnosis', question:'What is the simplest problem?',
     hint:'Is the action wrong, the framing wrong, or is this in the wrong place?'},
    {kind:'experiment', question:'What tiny experiment should happen next?',
     hint:'One action you could finish this week.'},
    {kind:'update', question:'Should this Branch change?',
     hint:'Keep it, rewrite it, split it, pause it, or move it — and why?'},
  ];
  return qs.map((q,i)=>
    '<div class="goal-question-card" data-question-index="'+i+'"><b>'+esc(q.question)+'</b>'+
    '<div class="goal-question-hint">'+esc(q.hint||'')+'</div>'+
    '<textarea class="goal-focus-answer" data-question="'+esc(q.question)+'" placeholder="Answer with one concrete observation…"></textarea>'+
    '<div class="goal-answer-tools"><label>Confidence in your answer<select class="goal-focus-answer-confidence">'+
      '<option value="0.55">unsure</option><option value="0.7" selected>somewhat</option>'+
      '<option value="0.85">pretty confident</option><option value="0.95">very confident</option>'+
    '</select></label><label>Question fit<select class="goal-focus-question-fit">'+
      '<option value="useful" selected>useful</option><option value="too_broad">too broad</option>'+
      '<option value="not_relevant">not relevant</option><option value="ask_gently">ask more gently</option>'+
    '</select></label></div></div>').join('');
}

function goalLeafSteps(node){
  const out=[];
  String(node.description||'').split(/\r?\n/).forEach(line=>{
    const m=line.match(/^\s*(?:[-*•]|\d+[.)]|step\s*\d*[:.])\s+(.*)$/i);
    if(m&&m[1].trim()) out.push(m[1].trim());
  });
  return out.slice(0,8);
}
function goalStepKey(nodeId,step){
  return 'ff-step:'+nodeId+':'+step.toLowerCase().replace(/\s+/g,' ').slice(0,80);
}
function goalLeafStepsHtml(node){
  const steps=goalLeafSteps(node);
  if(!steps.length)
    return '<div class="cur-sub">How to do this</div>'+
      '<p class="goal-focus-muted">No explicit steps yet. Draft concrete, in-the-moment actions for this Leaf.</p>'+
      '<div class="actions"><button id="goal-focus-draft-steps">Draft steps with GoalAI</button></div>'+
      '<div id="goal-steps-draft"></div>';
  let done=0;
  const rows=steps.map((s,i)=>{
    const checked=(function(){ try{ return localStorage.getItem(goalStepKey(node.id,s))==='1'; }catch(e){ return false; } })();
    if(checked) done++;
    return '<label class="goal-focus-leaf"><input type="checkbox" class="goal-step-check" data-si="'+i+'" '+
      (checked?'checked':'')+'><span>'+esc(s)+'</span></label>';
  }).join('');
  return '<div class="cur-sub" id="goal-steps-head">How to do this ('+done+'/'+steps.length+')</div>'+
    '<div class="goal-focus-mini">'+rows+'</div>';
}

function goalShortText(text,limit=260){
  text=String(text||'').replace(/\s+/g,' ').trim();
  return text.length>limit?text.slice(0,limit-1).trim()+'…':text;
}

function goalSplitBullets(text,maxItems=4){
  text=String(text||'').replace(/\r/g,'').trim();
  if(!text) return [];
  const explicit=text.split(/\n+|(?:^|\s)[•]\s+|(?:^|\s)-\s+/).map(s=>s.trim()).filter(Boolean);
  const parts=(explicit.length>1?explicit:text.split(/(?<=[.!?])\s+(?=[A-Z0-9“"])/))
    .map(s=>goalShortText(s.replace(/^[•\-\s]+/,''),170))
    .filter(Boolean);
  return parts.slice(0,maxItems);
}

function goalReadableBlock(text,maxItems=4){
  const bullets=goalSplitBullets(text,maxItems);
  if(bullets.length>=2) return '<ul>'+bullets.map(x=>'<li>'+esc(x)+'</li>').join('')+'</ul>';
  return '<span>'+esc(goalShortText(text,420))+'</span>';
}

function goalRecapHtml(node,agentState,curiosities,evidence){
  const pieces=[];
  const description=goalShortText(node.description||'',360);
  const agentBrief=goalShortText(agentState.brief||'',420);
  const nextFocus=goalShortText(agentState.next_focus||'',300);
  const storedOrigin=node.origin||{};
  const originSummary=goalShortText(storedOrigin.summary||'',520);
  const directCur=(curiosities||[]).filter(x=>!x.inherited_from_id);
  const inheritedCur=(curiosities||[]).filter(x=>x.inherited_from_id);
  const curLabels=[...directCur,...inheritedCur].map(x=>x.label).filter(Boolean);

  if(node.type==='umbrella'){
    const purpose=description||originSummary||agentBrief||
      'This Soul is the overall direction: the kind of life, self, and growth the map is meant to support.';
    pieces.push({label:'Soul purpose', text:purpose});
    if(nextFocus) pieces.push({label:'Current reminder', text:nextFocus});
  } else if(node.type==='overgoal'){
    pieces.push({label:'What this Root means', text:description||originSummary||
      'This Root needs a clearer description. Use Soul Calibration or Edit details to define it.'});
    if(originSummary) pieces.push({label:'Why Faerie created it', text:originSummary});
    if(agentBrief||nextFocus) pieces.push({label:'Current assessment', text:agentBrief||nextFocus});
  } else if(node.type==='subgoal'){
    pieces.push({label:'Problem this Branch is tracking', text:description||originSummary||
      'This Branch needs a clearer problem statement.'});
    if(originSummary) pieces.push({label:'Where it came from', text:originSummary});
    if(agentBrief||nextFocus) pieces.push({label:'Current assessment', text:agentBrief||nextFocus});
  } else {
    pieces.push({label:'What this Leaf asks you to do', text:description||node.title||
      'This Leaf needs one concrete action.'});
    if(originSummary) pieces.push({label:'What it helps test', text:originSummary});
  }
  if(!pieces.length){
    pieces.push({label:'Context missing', text:'No origin recap is stored yet. Add a description or attach the investigation that created this node.'});
  }
  const sourceChips=node.type==='umbrella'?[]:[
    ...(storedOrigin.source_label?['Origin: '+storedOrigin.source_label]:[]),
    ...(curLabels.slice(0,3).map(x=>'Investigation: '+x)),
  ].slice(0,4);
  return '<div class="goal-recap-card"><div class="cur-sub">Why this exists</div>'+
    '<div class="goal-recap-grid">'+pieces.slice(0,4).map(p=>
      '<div class="goal-recap-item"><b>'+esc(p.label)+'</b>'+goalReadableBlock(p.text)+'</div>').join('')+'</div>'+
    (sourceChips.length?'<div class="goal-recap-sources">'+sourceChips.map(x=>
      '<span class="goal-chip">'+esc(x)+'</span>').join('')+'</div>':'')+
    (node.description&&node.description.length>360
      ? '<details><summary>Show full stored description</summary><div class="goal-focus-desc">'+esc(node.description)+'</div></details>'
      : '')+'</div>';
}

function draftLeafSteps(node){
  const btn=$('goal-focus-draft-steps'), out=$('goal-steps-draft');
  if(!btn||!out) return;
  btn.disabled=true;
  out.innerHTML='<p class="goal-focus-muted"><span class="spin"></span> Asking GoalAI for explicit steps…</p>';
  const ask='Draft 3-5 explicit, physical steps for the Leaf "'+node.title+'". '+
    'Each step must be one concrete action I can execute in the moment: what to do, when to do it, and for how long. '+
    'No advice, no theory. Reply with a numbered list only, no preamble.';
  pywebview.api.goal_ai_chat(node.id,ask).then(r=>{
    btn.disabled=false;
    if(!r||r.ok===false){ out.innerHTML=''; toast((r&&r.message)||'GoalAI could not draft steps.',true); return; }
    goalAgentView=r.view||goalAgentView;
    const msgs=(r.view&&r.view.messages)||[];
    const reply=[...msgs].reverse().find(m=>m.role!=='user');
    const text=(reply&&reply.content||'').trim();
    if(!text){ out.innerHTML=''; toast('GoalAI returned no reply.',true); return; }
    out.innerHTML='<div class="goal-question-card"><b>Suggested steps</b>'+
      '<div class="goal-question-hint">Saving appends these to the Leaf description, so they show here as a checklist.</div>'+
      '<div style="white-space:pre-wrap;font-size:12.5px">'+esc(text)+'</div>'+
      '<div class="actions"><button class="accent" id="goal-steps-save">Save to this Leaf</button></div></div>';
    $('goal-steps-save').onclick=()=>{
      const lines=text.split(/\r?\n/).map(s=>s.trim()).filter(s=>/^(?:[-*•]|\d+[.)])\s+/.test(s));
      const block=(lines.length?lines:text.split(/\r?\n/).filter(Boolean).map((s,i)=>(i+1)+'. '+s)).join('\n');
      const desc=(node.description?node.description.replace(/\s+$/,'')+'\n\n':'')+'Steps:\n'+block;
      pywebview.api.goal_update(node.id,{description:desc}).then(r2=>{
        if(!r2||r2.ok===false){ toast((r2&&r2.message)||'Could not save steps.',true); return; }
        applyGoalTreeUpdate(r2); toast('Steps saved to this Leaf.');
      }).catch(e=>toast('Could not save steps: '+e,true));
    };
  }).catch(e=>{ btn.disabled=false; out.innerHTML=''; toast('GoalAI could not draft steps: '+e,true); });
}

function renderGoalFocusPanel(){
  const panel=$('goal-focus-panel');
  if(!panel||!goalState||!goalState.tree) return;
  const node=goalFind(goalState.tree,selectedGoalId)||goalState.tree;
  selectedGoalId=node.id;
  const path=goalPathTitles(goalState.tree,node.id,[])||[node.title];
  const leaves=goalSortedActiveLeaves(node);
  const childType=node.type==='umbrella'?'overgoal':node.type==='task'?null:'subgoal';
  const agent=(goalAgentNodeId===node.id&&goalAgentView)?goalAgentView:null;
  const agentState=agent&&agent.state||{};
  const agentQuestions=(agent&&agent.questions||[]).slice(0,3);
  const proposals=(agent&&agent.proposals||[]).slice(0,3);
  const curiosities=(node.curiosities||[]).slice(0,6);
  const evidence=(node.evidence||[]).slice(0,4);
  const recap=goalRecapHtml(node,agentState,curiosities,evidence);
  const originalNote=node.description||agentState.next_focus||'';
  const mode=goalFocusMode(node);
  const launchReadOnly=appProfile==='launch';
  const pending=goalFocusPending&&goalFocusPending.nodeId===node.id?goalFocusPending:null;
  const questionCards=(launchReadOnly||pending)?'':(mode==='leaf'?goalQuestionCards(node,agentState,agentQuestions)
    :mode==='brainstorm'?goalBrainstormCards(node):'');
  const pendingCard=pending
    ? '<div class="goal-question-card goal-focus-pending"><b><span class="spin"></span> '+esc(pending.title||'Generating follow-up questions…')+'</b>'+
      '<div class="goal-question-hint">'+esc(pending.message||'Your submitted answers are saved locally. GoalAI is reviewing the node and will replace this with the next useful questions if it has any.')+'</div></div>'
    : '';
  const leafRows=launchReadOnly
    ? (node.type==='task'
      ? '<div class="goal-focus-leaf"><span>'+esc(node.status==='completed'?'Completed Leaf':'Leaf action')+'</span></div>'
      : (leaves.length?leaves.slice(0,6).map(leaf=>
        '<div class="goal-focus-leaf"><span data-open="'+leaf.id+'" title="Open this Leaf"><b>'+esc(leaf.title)+'</b>'+
        (leaf.due_date?' · due '+esc(leaf.due_date):'')+
        (leaf.priority&&leaf.priority!=='normal'?' · '+esc(leaf.priority):'')+'</span></div>').join(''):
        '<p class="goal-focus-muted">No active Leaves under this node yet.</p>'))
    : node.type==='task'
    ? '<label class="goal-focus-leaf"><input type="checkbox" class="goal-focus-complete" data-leaf-id="'+node.id+'" '+(node.status==='completed'?'checked':'')+'><span>'+esc(node.status==='completed'?'Completed':'Mark this Leaf complete when it is actually done')+'</span></label>'
    : (leaves.length?leaves.slice(0,6).map(leaf=>
        '<label class="goal-focus-leaf"><input type="checkbox" class="goal-focus-complete" data-leaf-id="'+leaf.id+'"><span data-open="'+leaf.id+'" title="Open this Leaf">'+
        '<b>'+esc(leaf.title)+'</b>'+(leaf.due_date?' · due '+esc(leaf.due_date):'')+
        (leaf.priority&&leaf.priority!=='normal'?' · '+esc(leaf.priority):'')+'</span></label>').join(''):
        '<p class="goal-focus-muted">No active Leaves under this node yet.</p>');
  const goalAiHtml=agent
    ? '<div class="agent-brief">'+esc(agentState.brief||'No assessment yet.')+'</div>'+
      '<div class="goal-focus-muted">'+esc(agentState.health||'unknown')+
      ' · '+Math.round((agentState.confidence||0)*100)+'% confidence'+
      (agentState.dirty?' · queued for tonight':'')+'</div>'
    : '<div class="goal-focus-muted" id="goal-focus-agent"><span class="spin"></span> Loading GoalAI context…</div>';
  const actionHtml=launchReadOnly
    ? '<div class="actions"><button class="accent" id="goal-focus-ask-command">Ask Faerie about this node</button></div>'
    : '<div class="actions">'+(questionCards?'<button class="accent" id="goal-focus-submit">Submit answers & review node</button>':'')+
      (mode==='leaf'?'<button id="goal-focus-dismiss">Dismiss & rethink</button>':'')+
      '<button id="goal-focus-edit">Edit details</button>'+
      '<button id="goal-focus-ask">Ask Agent</button><button id="goal-focus-review">Review node</button>'+
      ((childType||(node.type!=='task'&&node.type!=='umbrella'))
        ? '<span class="goal-add-wrap"><button id="goal-focus-add" title="Add to this node">+</button>'+
          '<div class="goal-add-menu" id="goal-focus-add-menu">'+
          (childType?'<button data-add="'+childType+'">Add '+esc(goalTypeLabel(childType))+'</button>':'')+
          (node.type!=='task'&&node.type!=='umbrella'?'<button data-add="task">Add Leaf</button>':'')+
          '</div></span>'
        : '')+
      '</div>';
  panel.innerHTML='<div class="cur-head"><div><div class="goal-focus-title">'+esc(node.title)+'</div>'+
    '<div class="goal-focus-path">'+esc(path.join(' › '))+'</div></div></div>'+
    '<div><span class="goal-chip">'+esc(goalTypeLabel(node.type))+'</span><span class="goal-chip">'+
    esc(node.status||'active')+'</span><span class="goal-chip">'+esc(node.priority||'normal')+'</span></div>'+
    recap+
    '<div class="goal-progress"><div class="goal-progress-head"><span>Completion</span><span>'+
    esc(goalCompletionLabel(node))+'</span></div><div class="metric-progress"><i style="width:'+
    ((node.completion&&node.completion.percent)||0)+'%"></i></div></div>'+
    (node.type==='task'?goalLeafStepsHtml(node):'')+
    (mode==='rollup'?'<div class="cur-sub">Where each area stands</div>'+goalRollupHtml(node):'')+
    (mode==='brainstorm'
      ? '<div class="goal-next-action"><b>Brainstorm unlocked</b><span>No active Leaves here. Answer the rethink questions below, then Add Leaf to commit the next experiment.</span></div>'
      : '<div class="cur-sub">'+(mode==='leaf'?'Which Leaf actions are active?':'Address these Leaves next')+'</div><div class="goal-focus-mini">'+leafRows+'</div>')+
    (mode==='locked'
      ? '<p class="goal-focus-muted">Questions are asked on each Leaf, not here. Open a Leaf to answer them or mark it complete — dismissing one unlocks this Branch for a rethink.</p>'
      : '')+
    pendingCard+
    (questionCards
      ? '<div class="cur-sub">'+(mode==='brainstorm'?'Rethink this Branch':'What are we trying to answer?')+'</div><div id="goal-evidence-questions">'+questionCards+'</div>'
      : '')+
    (originalNote?'<details class="goal-full-note"><summary>Show full original note</summary><div>'+
      esc(originalNote)+'</div></details>':'')+
    actionHtml+
    '<div class="cur-sub">What does GoalAI think right now?</div>'+goalAiHtml+
    (agentQuestions.length?'<div class="cur-sub">What is GoalAI still asking?</div>'+agentQuestions.map(q=>
      '<div class="resolved-row"><div class="rr-body">'+esc(q.text||q.question||q)+'</div><span class="rr-tag">question</span></div>').join(''):'')+
    (proposals.length?'<div class="cur-sub">What changes is GoalAI proposing?</div>'+proposals.map(p=>
      '<div class="resolved-row"><div class="rr-body">'+goalProposalSummaryHtml(p)+
      '</div><span class="rr-tag">proposal</span></div>').join(''):'');
  bindGoalFocusPanel(node,childType);
}

function bindGoalFocusPanel(node,childType){
  if($('goal-focus-ask-command')) $('goal-focus-ask-command').onclick=()=>{
    switchView('self');
    setTimeout(()=>{
      const input=$('cc-input');
      if(input){
        input.value='I want to talk about this Growth node: '+node.title+
          '\nPath: '+((goalPathTitles(goalState.tree,node.id,[])||[node.title]).join(' > '))+
          '\nWhat should I understand or do next?';
        autoGrow(input);
        input.focus();
      }
    },100);
  };
  if($('goal-focus-submit')) $('goal-focus-submit').onclick=()=>submitGoalFocusAnswers(node);
  if($('goal-focus-edit')) $('goal-focus-edit').onclick=()=>setGrowthViewMode('list');
  if($('goal-focus-ask')) $('goal-focus-ask').onclick=()=>openGoalAgentChat(node.id,node.title);
  if($('goal-focus-review')) $('goal-focus-review').onclick=()=>reviewGoalAgent(node.id,false);
  const createChild=(type)=>{
    if(type==='task'){
      const active=goalActiveLeaves(node).length;
      if(active>=3&&!confirm('This Branch already has '+active+' active Leaves. Focus works best at 3 or fewer — add another anyway?')) return;
    }
    const title=prompt('Title for this '+goalTypeLabel(type)+':'); if(!title) return;
    pywebview.api.goal_create(type,title,node.id).then(handleGoalMutation);
  };
  const addBtn=$('goal-focus-add'), addMenu=$('goal-focus-add-menu');
  if(addBtn&&addMenu){
    const options=addMenu.querySelectorAll('button[data-add]');
    addBtn.onclick=e=>{
      e.stopPropagation();
      if(options.length===1){ createChild(options[0].dataset.add); return; }
      addMenu.classList.toggle('open');
    };
    options.forEach(b=>b.onclick=e=>{ e.stopPropagation();
      addMenu.classList.remove('open'); createChild(b.dataset.add); });
    document.addEventListener('click',()=>{ if(addMenu.isConnected) addMenu.classList.remove('open'); },{once:true});
  }
  if($('goal-focus-draft-steps')) $('goal-focus-draft-steps').onclick=()=>draftLeafSteps(node);
  const stepList=goalLeafSteps(node);
  document.querySelectorAll('#goal-focus-panel .goal-step-check').forEach(box=>{
    box.onchange=()=>{
      const step=stepList[parseInt(box.dataset.si,10)]||'';
      try{ localStorage.setItem(goalStepKey(node.id,step), box.checked?'1':'0'); }catch(e){}
      const head=$('goal-steps-head');
      if(head){
        const done=[...document.querySelectorAll('#goal-focus-panel .goal-step-check')].filter(b=>b.checked).length;
        head.textContent='How to do this ('+done+'/'+stepList.length+')';
      }
    };
  });
  if($('goal-focus-dismiss')) $('goal-focus-dismiss').onclick=()=>{
    const reason=prompt('Why didn’t this Leaf work? One line — it feeds the Branch rethink.');
    if(reason===null) return;
    const parent=goalFindParent(goalState.tree,node.id);
    pywebview.api.goal_update(node.id,{status:'archived'}).then(r=>{
      if(!r||r.ok===false){ toast((r&&r.message)||'Could not dismiss Leaf.',true); return; }
      const finish=()=>{
        applyGoalTreeUpdate(r);
        if(parent) selectGrowthNode(parent.id);
        loadGoals();
        toast('Leaf dismissed — Branch unlocked. Running GoalAI review with your reason…');
        if(parent) reviewGoalAgent(parent.id,false);
      };
      if(parent&&reason.trim())
        pywebview.api.goal_add_evidence(parent.id,'dismissal',String(node.id),
          'Dismissed “'+node.title+'”: '+reason.trim()).then(finish).catch(finish);
      else finish();
    }).catch(e=>toast('Could not dismiss Leaf: '+e,true));
  };
  document.querySelectorAll('#goal-focus-panel [data-open]').forEach(el=>{
    el.onclick=e=>{ e.preventDefault(); e.stopPropagation(); selectGrowthNode(el.dataset.open); };
  });
  document.querySelectorAll('#goal-focus-panel .goal-focus-complete').forEach(box=>{
    box.onchange=()=>{
      const id=parseInt(box.dataset.leafId,10);
      const next=box.checked?'completed':'active';
      const prev=box.checked?'active':'completed';
      box.disabled=true;
      updateGoalStatusWithUndo(id,next,prev,(r)=>{
        box.disabled=false;
        applyGoalTreeUpdate(r);
      },()=>{
        box.checked=!box.checked;
        box.disabled=false;
      });
    };
  });
}

function submitGoalFocusAnswers(node){
  const answers=Array.from(document.querySelectorAll('#goal-focus-panel .goal-question-card'))
    .map((card,i)=>{
      const box=card.querySelector('.goal-focus-answer');
      const confidence=card.querySelector('.goal-focus-answer-confidence');
      const fit=card.querySelector('.goal-focus-question-fit');
      let answer=(box&&box.value||'').trim();
      const meta=[];
      if(confidence) meta.push('answer_confidence='+confidence.value);
      if(fit) meta.push('question_fit='+fit.value);
      if(answer&&meta.length) answer += '\n\n[reflection_gate: '+meta.join('; ')+']';
      return {question:(box&&box.dataset.question)||('Question '+(i+1)), answer};
    })
    .filter(x=>x.answer);
  if(!answers.length){ toast('Answer at least one question first.', true); return; }
  goalFocusPending={
    nodeId:node.id,
    questions:answers.map(x=>x.question),
    title:'Saving answers…',
    message:'The answered boxes are cleared from view now. Next, GoalAI will review this node and generate sharper follow-up questions if it has any.'
  };
  renderGoalFocusPanel();
  const btn=$('goal-focus-submit');
  if(btn){ btn.disabled=true; btn.innerHTML='<span class="spin"></span> Saving answers…'; }
  let saved=0, latestTree=null;
  const stamp=Date.now();
  const chain=answers.reduce((p,item,i)=>p.then(()=>pywebview.api.goal_add_evidence(
    node.id,
    'focus_answer',
    stamp+':'+i+':'+Math.random().toString(36).slice(2,8),
    'Question: '+item.question+'\nAnswer: '+item.answer
  )).then(r=>{
    if(!r||r.ok===false) throw new Error((r&&r.message)||'Could not save answer.');
    saved += 1;
    if(r.tree) latestTree=r.tree;
  }), Promise.resolve());
  chain.then(()=>{
    if(latestTree&&goalState) goalState.tree=latestTree;
    goalFocusPending={
      nodeId:node.id,
      questions:answers.map(x=>x.question),
      title:'Generating follow-up questions…',
      message:'Answers saved. GoalAI is reviewing the node now; this will update the next questions/proposals instead of showing the answered boxes again.'
    };
    renderGoalFocusPanel();
    return pywebview.api.goal_ai_review(node.id,false);
  }).then(r=>{
    if(!r||r.ok===false) throw new Error((r&&r.message)||'GoalAI review failed.');
    if(latestTree&&goalState) goalState.tree=latestTree;
    goalFocusPending={
      nodeId:node.id,
      questions:answers.map(x=>x.question),
      title:'Loading follow-up questions…',
      message:'Review complete. Refreshing the map and GoalAI context.'
    };
    renderGoalFocusPanel();
    return pywebview.api.goal_state();
  }).then(r=>{
    if(!r||r.ok===false) throw new Error((r&&r.message)||'Could not reload goals.');
    goalState=r;
    return pywebview.api.goal_ai_state(node.id);
  }).then(r=>{
    if(!r||r.ok===false) throw new Error((r&&r.message)||'Could not reload GoalAI.');
    goalAgentView=r.agent; goalAgentNodeId=node.id; renderGoalAIOverview(r.overview);
    goalFocusPending=null;
    toast('Answers saved. Follow-up questions refreshed.');
    renderGrowthViewMode();
  }).catch(e=>{
    if(saved){
      goalFocusPending=null;
      toast('Answers saved, but GoalAI review failed: '+e.message, true);
      loadGoals(); loadGoalAgent(node.id);
    } else {
      goalFocusPending=null;
      toast('Could not save answers: '+e.message, true);
      renderGoalFocusPanel();
    }
  });
}

function buildGoalConstellation(tree){
  const width=1100, height=720, cx=width/2, cy=height/2;
  const nodes=[], edges=[];
  const depthRadiusX=[0,170,310,430,500,530,545];
  const depthRadiusY=[0,105,205,285,325,340,350];
  const place=(node,depth,start,end,parentId)=>{
    if(!node) return;
    const children=goalVisibleChildren(node);
    const angle=(start+end)/2;
    const ring=Math.min(depth,depthRadiusX.length-1);
    const radiusX=depthRadiusX[ring];
    const radiusY=depthRadiusY[ring];
    const wobble=((Number(node.id)||0)%17-8)*1.7;
    const x=depth===0?cx:cx+Math.cos(angle)*(radiusX+wobble);
    const y=depth===0?cy:cy+Math.sin(angle)*(radiusY+wobble*.55);
    nodes.push({node,depth,x,y,angle});
    if(parentId!=null) edges.push({sourceId:parentId,targetId:node.id});
    if(!children.length) return;
    const total=children.reduce((sum,child)=>sum+goalSubtreeWeight(child),0) || children.length;
    let cursor=start;
    children.forEach((child,index)=>{
      const share=(end-start)*(goalSubtreeWeight(child)/total);
      const pad=Math.min(0.08, Math.max(0,(share*.18)));
      const childStart=cursor+pad;
      const childEnd=cursor+share-pad;
      const fallback=(start+end)/2 + (index-(children.length-1)/2)*0.36;
      place(child,depth+1,
        childEnd>childStart?childStart:fallback-.12,
        childEnd>childStart?childEnd:fallback+.12,
        node.id);
      cursor+=share;
    });
  };
  place(tree,0,-Math.PI/2,Math.PI*1.5,null);
  nodes.forEach(item=>{
    const saved=goalMapPositions[item.node.id];
    if(saved&&Number.isFinite(saved.x)&&Number.isFinite(saved.y)){
      item.x=Math.max(-1200,Math.min(width+1200,Number(saved.x)));
      item.y=Math.max(-900,Math.min(height+900,Number(saved.y)));
    }
  });
  return {width,height,nodes,edges};
}

function renderGoalConstellation(summaryId,treeId,opts){
  opts=opts||{};
  const tree=goalState&&goalState.tree;
  const box=$(treeId);
  const summary=summaryId?$(summaryId):null;
  if(!box) return;
  if(!tree){
    box.innerHTML='<div class="empty">No Soul tree available yet.</div>';
    if(summary) summary.innerHTML='';
    return;
  }
  if(!selectedGoalId) selectedGoalId=tree.id;
  const selected=goalFind(tree,selectedGoalId)||tree;
  const map=buildGoalConstellation(tree);
  const nodeById=Object.fromEntries(map.nodes.map(x=>[x.node.id,x]));
  const selectedAncestors=new Set();
  const markAncestors=(node,target)=>{
    if(!node) return false;
    if(node.id===target) return true;
    for(const child of goalVisibleChildren(node)){
      if(markAncestors(child,target)){ selectedAncestors.add(node.id); return true; }
    }
    return false;
  };
  markAncestors(tree,selected.id);
  const edges=map.edges.map(edge=>{
    const a=nodeById[edge.sourceId], b=nodeById[edge.targetId];
    if(!a||!b) return '';
    const hot=edge.sourceId===selected.id||edge.targetId===selected.id||
      (selectedAncestors.has(edge.sourceId)&&selectedAncestors.has(edge.targetId));
    return '<line class="constellation-edge '+(hot?'selected':'')+'" data-from="'+edge.sourceId+
      '" data-to="'+edge.targetId+'" x1="'+a.x.toFixed(1)+
      '" y1="'+a.y.toFixed(1)+'" x2="'+b.x.toFixed(1)+'" y2="'+b.y.toFixed(1)+'"></line>';
  }).join('');
  const nodes=map.nodes.map(item=>{
    const node=item.node;
    const selectedClass=node.id===selected.id?' selected':'';
    const care=goalNeedsMapCare(node)?' needs-care':'';
    const status=node.status?(' '+node.status):'';
    const radius={umbrella:15,overgoal:11,subgoal:8,task:5}[node.type]||7;
    const glow=radius*(node.id===selected.id?5.7:4.5);
    const label=goalLabelShort(node.title,node.type==='task'?24:30);
    const labelDy=item.depth===0?-25:(node.type==='task'?18:22);
    return '<g class="constellation-node '+esc(node.type)+status+selectedClass+care+
      '" tabindex="0" role="button" data-map-goal-id="'+node.id+'" transform="translate('+
      item.x.toFixed(1)+' '+item.y.toFixed(1)+')">'+
      '<title>'+esc(goalTypeLabel(node.type)+' · '+node.title+' · '+goalCompletionLabel(node))+'</title>'+
      '<circle class="glow" r="'+glow+'"></circle>'+
      (care?'<circle class="halo" r="'+(glow+5)+'"></circle>':'')+
      '<circle class="core" r="'+radius+'"></circle>'+
      '<text text-anchor="middle" y="'+labelDy+'">'+esc(label)+'</text></g>';
  }).join('');
  const view=constellationViewState[treeId]||{scale:1,panX:0,panY:0};
  constellationViewState[treeId]=view;
  box.innerHTML='<svg class="growth-constellation-svg" viewBox="0 0 '+map.width+' '+map.height+
    '" preserveAspectRatio="xMidYMid meet">'+
    '<defs><filter id="starSoftGlow" x="-80%" y="-80%" width="260%" height="260%">'+
    '<feGaussianBlur stdDeviation="5" result="blur"></feGaussianBlur>'+
    '<feMerge><feMergeNode in="blur"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge></filter></defs>'+
    '<g class="constellation-viewport" transform="translate('+view.panX+' '+view.panY+') scale('+view.scale+
    ')" filter="url(#starSoftGlow)">'+edges+nodes+'</g></svg>';
  const path=goalPathTitles(tree,selected.id,[])||[selected.title];
  if(summary){
    const nextAction=goalNextActionText(selected);
    summary.innerHTML='<div class="growth-map-summary-card"><b>'+esc(selected.title)+'</b>'+
      '<span>'+esc(goalTypeLabel(selected.type))+' · '+esc(selected.status||'active')+
      ' · '+esc(goalCompletionLabel(selected))+'<br>'+esc(path.join(' › '))+'</span></div>'+
      (nextAction?'<div class="growth-map-summary-card"><b>TO DO</b><span>'+
      esc(nextAction)+'</span></div>':'');
  }
  box.querySelectorAll('[data-map-goal-id]').forEach(row=>{
    const choose=()=>{
      if(row.dataset.dragged==='1'){ row.dataset.dragged='0'; return; }
      selectGrowthNode(parseInt(row.dataset.mapGoalId,10),{closeOverlay:opts.closeOnSelect});
    };
    row.onclick=choose;
    row.onkeydown=e=>{ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); choose(); } };
  });
  bindConstellationPanZoom(box,treeId,map);
}

function bindConstellationPanZoom(box,treeId,map){
  const state=constellationViewState[treeId]||(constellationViewState[treeId]={scale:1,panX:0,panY:0});
  const svg=box.querySelector('svg');
  const viewport=box.querySelector('.constellation-viewport');
  if(!svg||!viewport) return;
  const nodeById=Object.fromEntries(map.nodes.map(item=>[String(item.node.id),item]));
  const apply=()=>viewport.setAttribute('transform','translate('+state.panX+' '+state.panY+') scale('+state.scale+')');
  const screenToMap=(clientX,clientY)=>{
    const rect=svg.getBoundingClientRect();
    const px=(clientX-rect.left)/Math.max(1,rect.width)*map.width;
    const py=(clientY-rect.top)/Math.max(1,rect.height)*map.height;
    return {x:(px-state.panX)/Math.max(.0001,state.scale),
      y:(py-state.panY)/Math.max(.0001,state.scale)};
  };
  const updateNodeDom=(nodeId)=>{
    const item=nodeById[String(nodeId)];
    if(!item) return;
    const group=box.querySelector('[data-map-goal-id="'+nodeId+'"]');
    if(group) group.setAttribute('transform','translate('+item.x.toFixed(1)+' '+item.y.toFixed(1)+')');
    box.querySelectorAll('.constellation-edge[data-from="'+nodeId+'"], .constellation-edge[data-to="'+nodeId+'"]').forEach(line=>{
      const a=nodeById[String(line.dataset.from)], b=nodeById[String(line.dataset.to)];
      if(!a||!b) return;
      line.setAttribute('x1',a.x.toFixed(1));
      line.setAttribute('y1',a.y.toFixed(1));
      line.setAttribute('x2',b.x.toFixed(1));
      line.setAttribute('y2',b.y.toFixed(1));
    });
  };
  box.onwheel=e=>{
    e.preventDefault();
    const rect=svg.getBoundingClientRect();
    const px=(e.clientX-rect.left)/Math.max(1,rect.width)*map.width;
    const py=(e.clientY-rect.top)/Math.max(1,rect.height)*map.height;
    const beforeX=(px-state.panX)/state.scale;
    const beforeY=(py-state.panY)/state.scale;
    const next=Math.max(.15,Math.min(8,state.scale*(e.deltaY<0?1.14:.86)));
    state.panX=px-beforeX*next;
    state.panY=py-beforeY*next;
    state.scale=next;
    apply();
  };
  let drag=null, nodeDrag=null;
  box.querySelectorAll('.constellation-node[data-map-goal-id]').forEach(group=>{
    group.onpointerdown=e=>{
      e.preventDefault();
      e.stopPropagation();
      const nodeId=group.dataset.mapGoalId;
      const item=nodeById[String(nodeId)];
      if(!item) return;
      const start=screenToMap(e.clientX,e.clientY);
      nodeDrag={nodeId,startX:start.x,startY:start.y,origX:item.x,origY:item.y,moved:false,group};
      group.classList.add('dragging-node');
      group.setPointerCapture&&group.setPointerCapture(e.pointerId);
    };
  });
  box.onpointerdown=e=>{
    if(e.target.closest&&e.target.closest('.constellation-node')) return;
    const rect=svg.getBoundingClientRect();
    drag={x:e.clientX,y:e.clientY,panX:state.panX,panY:state.panY,rect};
    box.classList.add('dragging');
    box.setPointerCapture&&box.setPointerCapture(e.pointerId);
  };
  box.onpointermove=e=>{
    if(nodeDrag){
      const item=nodeById[String(nodeDrag.nodeId)];
      if(!item) return;
      const now=screenToMap(e.clientX,e.clientY);
      const dx=now.x-nodeDrag.startX, dy=now.y-nodeDrag.startY;
      if(Math.abs(dx)+Math.abs(dy)>2) nodeDrag.moved=true;
      item.x=Math.max(-1200,Math.min(map.width+1200,nodeDrag.origX+dx));
      item.y=Math.max(-900,Math.min(map.height+900,nodeDrag.origY+dy));
      goalMapPositions[nodeDrag.nodeId]={x:item.x,y:item.y};
      updateNodeDom(nodeDrag.nodeId);
      return;
    }
    if(!drag) return;
    const dx=(e.clientX-drag.x)/Math.max(1,drag.rect.width)*map.width;
    const dy=(e.clientY-drag.y)/Math.max(1,drag.rect.height)*map.height;
    state.panX=drag.panX+dx;
    state.panY=drag.panY+dy;
    apply();
  };
  const end=e=>{
    if(nodeDrag){
      if(nodeDrag.moved){
        saveGoalMapPositions();
        const draggedGroup=nodeDrag.group;
        if(draggedGroup) draggedGroup.dataset.dragged='1';
        setTimeout(()=>{ if(draggedGroup) draggedGroup.dataset.dragged='0'; },0);
      }
      if(nodeDrag.group){
        nodeDrag.group.classList.remove('dragging-node');
        try{ nodeDrag.group.releasePointerCapture&&nodeDrag.group.releasePointerCapture(e.pointerId); }catch(_){}
      }
      nodeDrag=null;
    }
    drag=null;
    box.classList.remove('dragging');
    try{ box.releasePointerCapture&&box.releasePointerCapture(e.pointerId); }catch(_){}
  };
  box.onpointerup=end;
  box.onpointercancel=end;
  box.ondblclick=e=>{
    if(e.target.closest&&e.target.closest('.constellation-node')) return;
    state.scale=1; state.panX=0; state.panY=0; apply();
  };
}

function renderMainGrowthMap(){ renderGoalConstellation(null,'goal-map-tree'); }

function renderGrowthMap(){ renderGoalConstellation('growth-map-summary','growth-map-tree',{closeOnSelect:true}); }

function renderGrowthViewMode(){
  const map=$('goal-map-main'), list=$('goal-list-view');
  const mapBtn=$('goal-view-map'), listBtn=$('goal-view-list');
  if(map) map.hidden=growthViewMode!=='map';
  if(list) list.hidden=growthViewMode!=='list';
  if(mapBtn) mapBtn.classList.toggle('active',growthViewMode==='map');
  if(listBtn) listBtn.classList.toggle('active',growthViewMode==='list');
  if(growthViewMode==='map') {
    renderMainGrowthMap();
    renderGoalFocusPanel();
    if(selectedGoalId) loadGoalAgent(selectedGoalId);
  }
  else renderGoalTree();
}

function setGrowthViewMode(mode){
  growthViewMode=mode==='list'?'list':'map';
  renderGrowthViewMode();
}

function openGrowthMap(){
  const overlay=$('growth-map-overlay');
  if(!overlay) return;
  overlay.classList.add('open');
  overlay.setAttribute('aria-hidden','false');
  renderGrowthMap();
}

function closeGrowthMap(){
  const overlay=$('growth-map-overlay');
  if(!overlay) return;
  overlay.classList.remove('open');
  overlay.setAttribute('aria-hidden','true');
}

function goalActiveLeaves(node,out){
  out=out||[];
  if(!node) return out;
  if(node.type==='task'&&node.status==='active') out.push(node);
  (node.children||[]).forEach(child=>goalActiveLeaves(child,out));
  return out;
}

function goalNextActionText(node){
  const leaves=goalActiveLeaves(node).sort((a,b)=>{
    const pr={high:0,normal:1,low:2};
    return (pr[a.priority||'normal']??1)-(pr[b.priority||'normal']??1) ||
      String(a.due_date||'9999').localeCompare(String(b.due_date||'9999')) ||
      (a.position||0)-(b.position||0);
  });
  if(node.status==='paused') return 'This node is paused — unpause it when it becomes active again.';
  if(node.status==='completed') return 'This node is complete. Add evidence if there is something worth preserving.';
  if(leaves.length) return leaves[0].title;
  if(node.type==='task') return node.title;
  return '';
}

function masteryHtml(node){
  const m=node.mastery;
  if(!m && !['overgoal','subgoal'].includes(node.type)) return '';
  if(!m) return '<div class="cur-sub">Mastery</div><p class="hint">Not measured. Completion does not imply mastery.</p>'+
    '<input id="goal-mastery-dims" placeholder="Dimensions, comma separated (e.g. recall, application)">'+
    '<button id="goal-mastery-enable">Enable mastery</button>';
  const rows=(m.dimensions||[]).map(d=>{
    const s=(m.scores||{})[d.slug]||{};
    return '<div class="metric-bar-row"><div class="metric-bar-head"><span>'+esc(d.label)+'</span><span>'+
      (s.mastery==null?'unknown':Math.round(s.mastery)+'% · '+Math.round((s.confidence||0)*100)+'% confidence')+
      '</span></div><div class="metric-progress"><i style="width:'+(s.mastery||0)+'%"></i></div>'+
      '<div class="actions"><button class="goal-record-mastery" data-slug="'+esc(d.slug)+'">Add evidence</button></div></div>';
  }).join('');
  return '<div class="cur-sub">Evidence-backed mastery</div><div class="metric-bars">'+rows+'</div>';
}

function renderGoalDetail(){
  if(!goalState||!goalState.tree) return;
  const node=goalFind(goalState.tree,selectedGoalId)||goalState.tree;
  selectedGoalId=node.id;
  const c=node.completion||{};
  const pctText=c.percent==null?'Not measured':Math.round(c.percent)+'% ('+c.done+'/'+c.total+' leaves)';
  const childType=node.type==='umbrella'?'overgoal':node.type==='task'?null:'subgoal';
  const attachedCuriosityIds=new Set((node.curiosities||[]).map(x=>x.id));
  const curiosityOptions=(goalState.curiosities||[]).filter(x=>
    x.status!=='archived'&&!attachedCuriosityIds.has(x.id)).map(x=>
    '<option value="'+x.id+'">'+esc(x.label)+'</option>').join('');
  const parentCandidates=node.type==='umbrella'?[]:goalFlat(goalState.tree).filter(x=>
    node.type==='overgoal'?x.type==='umbrella':['overgoal','subgoal'].includes(x.type));
  const parentOptions=parentCandidates.map(x=>'<option value="'+x.id+'"'+
      (x.id===node.parent_id?' selected':'')+'>'+esc(x.title)+' ('+esc(goalTypeLabel(x.type))+')</option>').join('');
  $('goal-detail').innerHTML='<div class="cur-head"><span class="cur-label">'+esc(node.title)+'</span>'+
    '<span class="goal-chip">'+esc(goalTypeLabel(node.type))+'</span><span class="goal-chip">'+esc(node.status)+'</span></div>'+
    '<div class="goal-progress"><div class="goal-progress-head"><span>Task completion</span><span>'+pctText+'</span></div>'+
    '<div class="metric-progress"><i style="width:'+(c.percent||0)+'%"></i></div></div>'+
    '<label class="goal-field">Title<input id="goal-title" value="'+esc(node.title)+'"></label>'+
    '<label class="goal-field">Description <span class="hint" id="goal-description-status" style="margin:0"></span><textarea id="goal-description" rows="3">'+esc(node.description||'')+'</textarea></label>'+
    '<label class="goal-field">Notes<textarea id="goal-notes" rows="3">'+esc(node.notes||'')+'</textarea></label>'+
    '<div class="goal-grid"><label class="goal-field">Status<select id="goal-node-status">'+
      ['active','paused','completed','archived'].filter(x=>node.type!=='umbrella'||!['completed','archived'].includes(x)).map(x=>
        '<option'+(x===node.status?' selected':'')+'>'+x+'</option>').join('')+'</select></label>'+
      '<label class="goal-field">Priority<select id="goal-priority">'+['low','normal','high'].map(x=>
        '<option'+(x===node.priority?' selected':'')+'>'+x+'</option>').join('')+'</select></label></div>'+
    '<label class="goal-field">Due date<input id="goal-due" type="date" value="'+esc(node.due_date||'')+'"></label>'+
    (node.type!=='umbrella'?'<div class="goal-grid"><label class="goal-field">Parent<select id="goal-parent">'+
      parentOptions+'</select></label><label class="goal-field" title="Where this node appears among the other children of the same parent.">Position among siblings<input id="goal-position" type="number" min="1" value="'+
      ((node.position||0)+1)+'"></label></div><div class="actions"><button id="goal-move">Move / reorder</button></div>':'')+
    '<div class="actions"><button class="accent" id="goal-save">Save changes</button>'+
      '<button id="goal-edit-open">Edit Details</button>'+
      '<button id="goal-rename">Rename</button>'+
      (childType?'<button id="goal-add-child">Add '+goalTypeLabel(childType)+'</button>':'')+
      (node.type!=='task'&&node.type!=='umbrella'?'<button id="goal-add-task">Add Leaf</button>':'')+
      '<button id="goal-export-notion">Export to Notion</button></div>'+
    '<div class="cur-sub">Curiosity context</div><div>'+((node.curiosities||[]).map(x=>
      '<span class="goal-chip">'+esc(x.label)+
      (x.inherited_from_id?' · inherited from '+esc(x.inherited_from_title):
        ' <button class="goal-unlink-cur" data-id="'+x.id+'">×</button>')+'</span>').join('')||
      '<span class="hint">None attached or inherited.</span>')+'</div>'+
    (curiosityOptions?'<div class="actions"><select id="goal-curiosity-select" style="width:auto">'+curiosityOptions+'</select>'+
      '<button id="goal-link-curiosity">Attach</button></div>':'')+
    '<div class="cur-sub">Evidence</div>'+((node.evidence||[]).map(x=>
      '<div class="resolved-row"><div class="rr-body">'+esc(x.label||x.source_kind)+'</div><span class="rr-tag">'+
      esc(x.source_kind)+'</span></div>').join('')||'<p class="hint">No linked evidence yet.</p>')+
    '<div class="actions"><button id="goal-add-evidence" title="Attach something you directly observed. This informs GoalAI but does not complete a Leaf or change mastery.">Add firsthand evidence</button></div>'+masteryHtml(node)+
    '<div class="agent-panel" id="goal-ai-panel"><span class="spin"></span>Loading GoalAI…</div>';

  $('goal-save').onclick=()=>{
    const changes={title:$('goal-title').value,description:$('goal-description').value,
      notes:$('goal-notes').value,status:$('goal-node-status').value,
      priority:$('goal-priority').value,due_date:$('goal-due').value};
    pywebview.api.goal_update(node.id,changes).then(handleGoalMutation);
  };
  if($('goal-edit-open')) $('goal-edit-open').onclick=()=>{
    $('goal-edit-drawer').classList.add('open');
    $('goal-edit-form').innerHTML='<p>Detailed controls are shown in the main panel for now while the recovered Growth view is stabilized.</p>';
  };
  $('goal-rename').onclick=()=>{
    const title=prompt('Rename this '+goalTypeLabel(node.type)+':',node.title); if(!title||title.trim()===node.title) return;
    pywebview.api.goal_update(node.id,{title:title.trim()}).then(handleGoalMutation);
  };
  const createChild=(type)=>{
    const title=prompt('Title for this '+goalTypeLabel(type)+':'); if(!title) return;
    pywebview.api.goal_create(type,title,node.id).then(handleGoalMutation);
  };
  if($('goal-add-child')) $('goal-add-child').onclick=()=>createChild(childType);
  if($('goal-add-task')) $('goal-add-task').onclick=()=>createChild('task');
  if($('goal-move')) $('goal-move').onclick=()=>
    pywebview.api.goal_move(node.id,parseInt($('goal-parent').value,10),
      Math.max(0,(parseInt($('goal-position').value,10)||1)-1)).then(handleGoalMutation);
  $('goal-export-notion').onclick=()=>{
    if(!confirm('Export this goal subtree to Notion now? Notes and evidence labels stay local.')) return;
    pywebview.api.goal_export_notion(node.id).then(r=>{
      if(!r||r.ok===false){ toast((r&&r.message)||'Could not export.',true); return; }
      toast('Goal subtree exported to Notion.');
    });
  };
  if($('goal-link-curiosity')) $('goal-link-curiosity').onclick=()=>
    pywebview.api.goal_link_curiosity(node.id,parseInt($('goal-curiosity-select').value,10),true).then(handleGoalMutation);
  document.querySelectorAll('.goal-unlink-cur').forEach(btn=>btn.onclick=()=>
    pywebview.api.goal_link_curiosity(node.id,parseInt(btn.dataset.id,10),false).then(handleGoalMutation));
  $('goal-add-evidence').onclick=()=>{
    const label=prompt('What did you directly observe? This informs GoalAI but does not complete the Leaf or change mastery.'); if(!label) return;
    pywebview.api.goal_add_evidence(node.id,'manual_note',null,label).then(handleGoalMutation);
  };
  if($('goal-mastery-enable')) $('goal-mastery-enable').onclick=()=>{
    const dims=$('goal-mastery-dims').value.split(',').map(x=>x.trim()).filter(Boolean);
    pywebview.api.goal_mastery_enable(node.id,dims).then(handleGoalMutation);
  };
  document.querySelectorAll('.goal-record-mastery').forEach(btn=>btn.onclick=()=>{
    const raw=prompt('Evidence score from 0 to 100:'); if(raw===null) return;
    const score=parseFloat(raw); if(!Number.isFinite(score)){ toast('Enter a number.',true); return; }
    const source=prompt('Briefly describe the evidence:')||'Manual assessment';
    pywebview.api.goal_mastery_record(node.id,btn.dataset.slug,score,.8,'manual',Date.now()+':'+source)
      .then(handleGoalMutation);
  });
  autoGrowWithin($('goal-detail'));
  if(!node.description && !descriptionDraftRequested.has(node.id)){
    descriptionDraftRequested.add(node.id);
    $('goal-description-status').textContent='· GoalAI drafting…';
    pywebview.api.goal_ai_description(node.id).then(r=>{
      if(node.id!==selectedGoalId) return;
      $('goal-description-status').textContent='';
      if(!r||r.ok===false){ descriptionDraftRequested.delete(node.id); return; }
      const box=$('goal-description');
      if(box&&!box.value.trim()){
        box.value=r.description||'';
        autoGrow(box);
        toast('GoalAI drafted a description. Review it, then Save changes.');
      }
    }).catch(()=>{
      descriptionDraftRequested.delete(node.id);
      if(node.id===selectedGoalId&&$('goal-description-status'))
        $('goal-description-status').textContent='';
    });
  }
  loadGoalAgent(node.id);
}

function renderGoalAIStatusStrip(o){
  const strip=$('goal-ai-strip');
  if(!strip) return;
  o=o||{};
  const need=(o.blocked||0)+(o.needs_attention||0);
  const questions=o.open_questions||0;
  const proposals=o.open_proposals||0;
  const next=o.schedule&&o.schedule.next_run_at
    ? new Date(o.schedule.next_run_at).toLocaleTimeString([], {hour:'numeric',minute:'2-digit'})
    : '8:00 PM';
  strip.innerHTML='<div class="strip-copy"><b>To do:</b> '+need+
    ' need care · '+questions+' questions · '+proposals+' proposals · next '+esc(next)+'</div>'+
    '<button id="goal-strip-review">Review next</button>'+
    '<button id="goal-strip-questions">Answer questions</button>';
  const queues=o.queues||{};
  $('goal-strip-review').onclick=()=>{
    const kind=['blocked','needs_attention','proposals','dirty','stale','deferred']
      .find(k=>(queues[k]||[]).length);
    if(!kind){ toast('Nothing needs review right now.'); return; }
    navigateGoalAIQueue(kind,queues[kind]);
  };
  $('goal-strip-questions').onclick=()=>navigateGoalAIQueue('questions',queues.questions||[]);
}

function renderGoalAIOverview(o){
  o=o||{};
  goalAIOverviewCache=o;
  renderGoalAIStatusStrip(o);
  const queues=o.queues||{};
  const items=[['blocked','Blocked',o.blocked||0],['needs_attention','Needs attention',o.needs_attention||0],
    ['dirty','Changed for tonight',o.dirty||0],['deferred','Deferred',o.deferred||0],
    ['stale','Stale reports',o.stale||0],['questions','Open questions',o.open_questions||0],
    ['proposals','Proposals',o.open_proposals||0]];
  $('goal-ai-overview').innerHTML=items.map(x=>'<div class="goal-ai-stat '+(x[2]?'actionable':'')+'" '+
    (x[2]?'role="button" tabindex="0" data-queue="'+x[0]+'"':'')+'><b>'+x[2]+
    '</b><span>'+esc(x[1])+'</span></div>').join('')+
    (o.schedule?'<div class="goal-ai-stat"><b>'+esc(new Date(o.schedule.next_run_at).toLocaleTimeString([], {hour:'numeric',minute:'2-digit'}))+
      '</b><span>Next changed-only run</span></div>':'')+
    (o.usage?'<div class="goal-ai-stat" title="'+esc((o.usage.categories||[]).map(x=>
      x.category+': '+x.calls+' calls · $'+Number(x.estimated_usd||0).toFixed(4)).join('\n')
      +(o.usage.cache_hit_rate!=null?'\ncache hit rate: '+Math.round(o.usage.cache_hit_rate*100)+'%':''))+'"><b>$'+
      Number(o.usage.estimated_usd||0).toFixed(3)+'</b><span>AI today · '+(o.usage.calls||0)+' calls</span></div>':'');
  $('goal-ai-overview').querySelectorAll('[data-queue]').forEach(card=>{
    const open=()=>navigateGoalAIQueue(card.dataset.queue,queues[card.dataset.queue]||[]);
    card.onclick=open;
    card.onkeydown=e=>{ if(e.key==='Enter'||e.key===' '){e.preventDefault();open();} };
  });
}

function navigateGoalAIQueue(kind,queue){
  if(!queue.length){ toast('Nothing in this queue.'); return; }
  const index=(goalOverviewCursors[kind]||0)%queue.length;
  goalOverviewCursors[kind]=index+1;
  const item=queue[index];
  goalOverviewFocus={kind,id:item.id||null};
  selectGrowthNode(item.node_id);
}

function focusGoalAIQueueItem(){
  if(!goalOverviewFocus) return;
  const focus=goalOverviewFocus; goalOverviewFocus=null;
  let target=$('goal-ai-panel');
  if(focus.kind==='questions'&&focus.id) target=document.querySelector('[data-qid="'+focus.id+'"]');
  if(focus.kind==='proposals'&&focus.id) target=document.querySelector('[data-pid="'+focus.id+'"]');
  if(!target) target=$('goal-ai-panel');
  if(target){ target.scrollIntoView({behavior:'smooth',block:'center'}); target.classList.add('goal-focus');
    setTimeout(()=>target.classList.remove('goal-focus'),1600); }
}

function goalProposalSummaryHtml(p){
  const payload=p.payload||{};
  if(p.type==='promote_insight'){
    const target=goalState&&goalState.tree?goalFind(goalState.tree,p.target_node_id):null;
    const confidence=Math.round((payload.confidence||0)*100);
    return '<div class="cur-text"><b>Promote insight upward</b> · '+confidence+'% confidence</div>'+
      '<div class="hint">'+esc(p.rationale||'Faerie thinks this may matter beyond the current node.')+'</div>'+
      '<div class="goal-recap-item" style="margin-top:8px"><b>Move toward</b><span>'+
      esc((target&&target.title)||('node #'+p.target_node_id))+'</span></div>'+
      '<div class="goal-recap-item" style="margin-top:8px"><b>'+esc(payload.title||'Insight')+
      '</b><span>'+esc(payload.detail||payload.summary||'')+'</span></div>';
  }
  return '<div class="cur-text"><b>'+esc(p.type.replaceAll('_',' '))+
    '</b> · target #'+p.target_node_id+'</div><div class="hint">'+
    esc(p.rationale||'')+'</div><pre>'+esc(JSON.stringify(payload,null,2))+'</pre>';
}

function goalAgentHtml(view,node){
  const s=view.state||{}, qs=view.questions||[], ps=view.proposals||[], mc=view.memory_candidates||[];
  const evidence=(s.evidence||[]).map(x=>'<li>'+esc(x)+'</li>').join('');
  const blockers=(s.blockers||[]).map(x=>'<li>'+esc(x)+'</li>').join('');
  const questions=qs.map(q=>'<div class="cur-item agent-question" data-qid="'+q.id+'">'+
    '<div class="cur-text">'+esc(q.text)+'</div><textarea rows="2" placeholder="Answer locally for this goal…"></textarea>'+
    '<div class="actions"><button class="agent-q-dismiss skip">Dismiss</button>'+
    '<button class="agent-q-answer accent">Answer</button></div></div>').join('');
  const proposals=ps.map(p=>'<div class="agent-proposal" data-pid="'+p.id+'">'+
    goalProposalSummaryHtml(p)+'<div class="actions">'+
    '<button class="agent-p-dismiss skip">Dismiss</button><button class="agent-p-refine">Refine</button>'+
    '<button class="agent-p-approve accent">Approve</button></div></div>').join('');
  const candidates=mc.map(c=>'<div class="agent-proposal" data-mid="'+c.id+'"><div class="cur-text"><b>'+
    esc(c.category)+' · '+esc(c.attribute)+'</b></div><div>'+esc(c.value)+'</div><div class="actions">'+
    '<button class="agent-m-dismiss skip">Dismiss</button><button class="agent-m-save accent">Save to Memory</button>'+
    '</div></div>').join('');
  const history=(view.assessments||[]).slice(0,4).map(a=>'<div class="resolved-row"><div class="rr-body">'+
    esc(a.report.brief||'')+'</div><span class="rr-tag">'+esc(a.health)+'</span></div>').join('');
  return '<div class="cur-head"><span class="cur-label">GoalAI</span><span class="health-chip '+
    esc(s.health||'unknown')+'">'+esc(s.health||'unknown')+'</span><span class="cur-conf">'+
    Math.round((s.confidence||0)*100)+'% confidence</span></div><div class="agent-brief">'+
    esc(s.brief||'No assessment yet.')+'</div><div class="hint">'+
    (s.dirty?'Queued for 8 PM'+(s.dirty_reason?' · '+esc(s.dirty_reason):''):
      'Up to date'+(s.last_run_at?' · last reviewed '+esc(new Date(s.last_run_at).toLocaleString()):''))+
    (s.deferred?' · deferred by the nightly batch limit':'')+'</div><div class="actions"><button id="agent-review-node" title="Ask this node’s agent to reassess only this Root, Branch, or Leaf using its current evidence, questions, proposals, and child reports.">Review node</button>'+
    (node.type!=='task'?'<button id="agent-review-subtree" title="Review this node and every active child below it, bottom-up, then refresh the parent summary.">Review subtree</button>':'')+
    '<button id="agent-harvest" title="Distill reusable learning from this part of the tree so it can flow upward through the Soul and later inform related branches.">Harvest '+esc(goalTypeLabel(node.type))+'</button>'+
    '<button class="accent" id="agent-open-chat" title="Talk to this node’s bounded agent when you want to clarify context, refine proposals, explore blockers, or stage changes before committing.">Ask Agent</button></div>'+
    (s.next_focus?'<div class="cur-sub">Next focus</div><p>'+esc(s.next_focus)+'</p>':'')+
    (evidence?'<div class="cur-sub">Evidence considered</div><ul>'+evidence+'</ul>':'')+
    (blockers?'<div class="cur-sub">Blockers</div><ul>'+blockers+'</ul>':'')+
    (questions?'<div class="cur-sub">Questions</div>'+questions:'')+
    (proposals?'<div class="cur-sub">Proposals awaiting approval</div>'+proposals:'')+
    (candidates?'<div class="cur-sub">Memory candidates</div>'+candidates:'')+
    (history?'<div class="cur-sub">Recent assessments</div>'+history:'');
}

function loadGoalAIOverview(){
  pywebview.api.goal_ai_state().then(r=>{
    if(r&&r.ok!==false) renderGoalAIOverview(r.overview);
  }).catch(()=>{});
}

function loadGoalAgent(nodeId){
  pywebview.api.goal_ai_state(nodeId).then(r=>{
    if(!r||r.ok===false){
      if(nodeId===selectedGoalId){
        const panel=$('goal-ai-panel'), focus=$('goal-focus-agent');
        if(panel) panel.textContent='GoalAI unavailable: '+((r&&r.message)||'unknown error');
        if(focus) focus.textContent='GoalAI unavailable: '+((r&&r.message)||'unknown error');
      }
      return;
    }
    if(nodeId!==selectedGoalId) return;
    goalAgentView=r.agent; goalAgentNodeId=nodeId; renderGoalAIOverview(r.overview);
    const node=goalFind(goalState.tree,nodeId);
    const panel=$('goal-ai-panel');
    if(panel){
      panel.innerHTML=goalAgentHtml(goalAgentView,node);
      bindGoalAgent(nodeId,node);
    }
    renderGoalFocusPanel();
    requestAnimationFrame(focusGoalAIQueueItem);
  }).catch(e=>{
    if(nodeId===selectedGoalId){
      const panel=$('goal-ai-panel'), focus=$('goal-focus-agent');
      if(panel) panel.textContent='GoalAI unavailable: '+e;
      if(focus) focus.textContent='GoalAI unavailable: '+e;
    }
  });
}

function bindGoalAgent(nodeId,node){
  $('agent-review-node').onclick=()=>reviewGoalAgent(nodeId,false);
  if($('agent-review-subtree')) $('agent-review-subtree').onclick=()=>reviewGoalAgent(nodeId,true);
  $('agent-open-chat').onclick=()=>openGoalAgentChat(nodeId,node.title);
  $('agent-harvest').onclick=()=>{
    $('agent-harvest').disabled=true;
    pywebview.api.goal_ai_harvest_start(nodeId).then(r=>{
      $('agent-harvest').disabled=false;
      if(!r||r.ok===false){toast((r&&r.message)||'Could not harvest this node.',true);return;}
      launchAgentWindow('goal-harvest',r.harvest.id);
    }).catch(e=>{ $('agent-harvest').disabled=false; toast('Could not harvest: '+e,true); });
  };
  document.querySelectorAll('.agent-question').forEach(box=>{
    box.querySelector('.agent-q-answer').onclick=()=>{
      const answer=box.querySelector('textarea').value.trim(); if(!answer){toast('Write an answer first.',true);return;}
      pywebview.api.goal_ai_question(parseInt(box.dataset.qid,10),'answer',answer).then(r=>{
        if(!r||r.ok===false){toast((r&&r.message)||'Could not save answer.',true);return;}
        loadGoals();
      });
    };
    box.querySelector('.agent-q-dismiss').onclick=()=>{
      const qid=parseInt(box.dataset.qid,10);
      pywebview.api.goal_ai_question(qid,'dismiss','').then(r=>{
        if(!r||r.ok===false){toast((r&&r.message)||'Could not dismiss.',true);return;}
        toast('Question dismissed.','', 'Undo', ()=>{
          pywebview.api.goal_ai_question(qid,'reopen','').then(u=>{
            if(!u||u.ok===false){toast((u&&u.message)||'Could not undo.',true);return;}
            toast('Question restored.'); loadGoalAgent(nodeId); loadGoalAIOverview();
          }).catch(e=>toast('Could not undo: '+e,true));
        }, 8500);
        loadGoalAgent(nodeId); loadGoalAIOverview();
      });
    };
  });
  document.querySelectorAll('.agent-proposal[data-pid]').forEach(box=>{
    const id=parseInt(box.dataset.pid,10);
    box.querySelector('.agent-p-dismiss').onclick=()=>goalProposalAction(id,'dismiss',nodeId);
    box.querySelector('.agent-p-approve').onclick=()=>goalProposalAction(id,'approve',nodeId);
    box.querySelector('.agent-p-refine').onclick=()=>{
      toast('Opening this node’s agent so you can refine the proposal conversationally.');
      openGoalAgentChat(nodeId,node.title);
    };
  });
  document.querySelectorAll('.agent-proposal[data-mid]').forEach(box=>{
    const id=parseInt(box.dataset.mid,10);
    box.querySelector('.agent-m-dismiss').onclick=()=>goalMemoryAction(id,'dismiss',nodeId);
    box.querySelector('.agent-m-save').onclick=()=>goalMemoryAction(id,'save',nodeId);
  });
}

function reviewGoalAgent(nodeId,subtree){
  const target=$('goal-ai-panel')||$('goal-focus-agent')||$('goal-focus-panel');
  if(target) target.innerHTML='<span class="spin"></span>GoalAI is reviewing '+(subtree?'this subtree':'this node')+'…';
  pywebview.api.goal_ai_review(nodeId,subtree).then(r=>{
    if(!r||r.ok===false){toast((r&&r.message)||'GoalAI review failed.',true);loadGoalAgent(nodeId);return;}
    toast(subtree?'Subtree reviewed.':'Node reviewed.'); loadGoalAgent(nodeId); loadGoalAIOverview();
  }).catch(e=>{toast('GoalAI review failed: '+e,true);loadGoalAgent(nodeId);});
}

function goalProposalAction(id,action,nodeId,payload){
  pywebview.api.goal_ai_proposal(id,action,payload||null,'').then(r=>{
    if(!r||r.ok===false){toast((r&&r.message)||'Could not update proposal.',true);return;}
    if(action==='dismiss'){
      toast('Proposal dismissed.','', 'Undo', ()=>{
        pywebview.api.goal_ai_proposal(id,'reopen',null,'').then(u=>{
          if(!u||u.ok===false){toast((u&&u.message)||'Could not undo.',true);return;}
          toast('Proposal restored.'); loadGoalAgent(nodeId); loadGoalAIOverview();
        }).catch(e=>toast('Could not undo: '+e,true));
      }, 8500);
    } else {
      toast(action==='approve'?'Proposal applied.':'Proposal updated.');
    }
    if(r.tree){ loadGoals(); if(currentCuriosityState) loadCuriosity(); }
    else loadGoalAgent(nodeId); loadGoalAIOverview();
  });
}

function goalMemoryAction(id,action,nodeId){
  pywebview.api.goal_ai_memory(id,action).then(r=>{
    if(!r||r.ok===false){toast((r&&r.message)||'Could not update memory candidate.',true);return;}
    if(action==='dismiss'){
      toast('Memory candidate dismissed.','', 'Undo', ()=>{
        pywebview.api.goal_ai_memory(id,'reopen').then(u=>{
          if(!u||u.ok===false){toast((u&&u.message)||'Could not undo.',true);return;}
          toast('Memory candidate restored.'); loadGoalAgent(nodeId);
        }).catch(e=>toast('Could not undo: '+e,true));
      }, 8500);
    } else {
      toast('Saved to Memory.');
    }
    loadGoalAgent(nodeId);
  });
}

function openGoalAgentChat(nodeId,title){
  selectedGoalId=nodeId; launchAgentWindow('goal-agent',nodeId);
}

function renderGoalAgentChat(){
  const messages=(goalAgentView&&goalAgentView.messages)||[];
  $('agent-chat-messages').innerHTML=messages.map(m=>'<div class="planner-msg '+esc(m.role)+'">'+
    esc(m.content)+'</div>').join('');
}

$('agent-chat-close').onclick=()=>$('goal-agent-chat').classList.remove('open');
$('agent-chat-send').onclick=()=>{
  const text=$('agent-chat-input').value.trim(); if(!text){toast('Write a message first.',true);return;}
  const btn=$('agent-chat-send');btn.disabled=true;
  pywebview.api.goal_ai_chat(selectedGoalId,text).then(r=>{
    btn.disabled=false;
    if(!r||r.ok===false){toast((r&&r.message)||'GoalAI could not reply.',true);return;}
    goalAgentView=r.view;$('agent-chat-input').value='';renderGoalAgentChat();loadGoalAgent(selectedGoalId);loadGoalAIOverview();
  }).catch(e=>{btn.disabled=false;toast('GoalAI could not reply: '+e,true);});
};

function handleGoalMutation(r){
  if(!r||r.ok===false){ toast((r&&r.message)||'Could not update goal.',true); return; }
  applyGoalTreeUpdate(r);
  toast('Goal tree updated.');
}

function applyGoalTreeUpdate(r){
  if(!r||r.ok===false) return;
  if(r.tree){
    goalState.tree=r.tree;
    renderGrowthViewMode();
    if($('growth-map-overlay')&&$('growth-map-overlay').classList.contains('open')) renderGrowthMap();
  } else loadGoals();
}

function loadGoals(){
  if(!api()) return;
  $('goal-status').innerHTML='<span class="spin"></span>Loading…';
  pywebview.api.goal_state().then(r=>{
    $('goal-status').textContent='';
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not load goals.',true); return; }
    goalState=r;
    if(goalState.tree&&selectedGoalId&&!goalFind(goalState.tree,selectedGoalId)) selectedGoalId=goalState.tree.id;
    if(goalState.tree&&!selectedGoalId) selectedGoalId=goalState.tree.id;
    renderGrowthViewMode();
    loadGoalAIOverview();
  }).catch(e=>{ $('goal-status').textContent=''; toast('Could not load goals: '+e,true); });
}

if($('refresh-goals')) $('refresh-goals').onclick=loadGoals;
if($('goal-view-map')) $('goal-view-map').onclick=()=>setGrowthViewMode('map');
if($('goal-view-list')) $('goal-view-list').onclick=()=>setGrowthViewMode('list');
if($('goal-open-map')) $('goal-open-map').onclick=openGrowthMap;
if($('goal-backfill-origin')) $('goal-backfill-origin').onclick=()=>{
  if(!api()) return;
  const btn=$('goal-backfill-origin');
  btn.disabled=true; btn.innerHTML='<span class="spin"></span> Backfilling…';
  pywebview.api.goal_origin_backfill().then(r=>{
    btn.disabled=false; btn.textContent='Backfill context';
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not backfill context.',true); return; }
    goalState=r;
    renderGrowthViewMode();
    toast(r.backfilled?'Backfilled '+r.backfilled+' node recap(s).':'Nothing needed backfill.');
  }).catch(e=>{ btn.disabled=false; btn.textContent='Backfill context'; toast('Could not backfill context: '+e,true); });
};
if($('growth-map-close')) $('growth-map-close').onclick=closeGrowthMap;
if($('growth-map-overlay')) $('growth-map-overlay').onclick=e=>{ if(e.target===$('growth-map-overlay')) closeGrowthMap(); };
if($('goal-edit-close')) $('goal-edit-close').onclick=()=>$('goal-edit-drawer').classList.remove('open');
if($('goal-add-overgoal')) $('goal-add-overgoal').onclick=()=>{
  const title=prompt('New Root:'); if(!title) return;
  const parent=goalState&&goalState.tree?goalState.tree.id:null;
  pywebview.api.goal_create('overgoal',title,parent).then(handleGoalMutation);
};

function renderPlanner(){
  if(!plannerSession) return;
  $('goal-planner').classList.add('open');
  $('planner-messages').innerHTML=(plannerSession.messages||[]).map(m=>
    '<div class="planner-msg '+esc(m.role)+'">'+esc(m.content)+'</div>').join('');
  const ready=plannerSession.status==='ready';
  $('planner-review').style.display=ready?'block':'none';
  if(ready) $('planner-draft').value=JSON.stringify(plannerSession.draft,null,2);
}

function openGoalPlanner(itemId){
  if(!api()) return;
  pywebview.api.goal_plan_start(itemId,null).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not start planning.',true); return; }
    plannerSession=r.session; launchAgentWindow('goal-planner',plannerSession.id);
  }).catch(e=>toast('Could not start planning: '+e,true));
}

$('planner-close').onclick=()=>$('goal-planner').classList.remove('open');
$('planner-send').onclick=()=>{
  const answer=$('planner-answer').value.trim(); if(!answer){ toast('Write an answer first.',true); return; }
  pywebview.api.goal_plan_reply(plannerSession.id,answer).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not continue.',true); return; }
    plannerSession=r.session; $('planner-answer').value=''; renderPlanner();
  });
};
$('planner-summary').onclick=()=>pywebview.api.goal_plan_summarize(plannerSession.id).then(r=>{
  if(!r||r.ok===false){ toast((r&&r.message)||'Could not summarize.',true); return; }
  plannerSession=r.session; renderPlanner();
});
$('planner-create').onclick=()=>{
  let draft; try{ draft=JSON.parse($('planner-draft').value); }
  catch(e){ toast('Draft JSON is invalid.',true); return; }
  pywebview.api.goal_plan_update_draft(plannerSession.id,draft).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not save draft.',true); return; }
    return pywebview.api.goal_plan_commit(plannerSession.id);
  }).then(r=>{
    if(!r) return;
    if(r.ok===false){ toast(r.message||'Could not create plan.',true); return; }
    $('goal-planner').classList.remove('open'); plannerSession=null;
    toast('Plan created.'); loadGoals(); loadCuriosity();
  });
};
$('planner-abandon').onclick=()=>{
  if(!plannerSession) return;
  pywebview.api.goal_plan_abandon(plannerSession.id).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not abandon.',true); return; }
    plannerSession=null; $('goal-planner').classList.remove('open'); toast('Draft abandoned.');
  });
};

/* ---------- curiosity ---------- */
let currentCuriosityState=null, activeCuriosityId=null;
let pendingCuriosityLoopId=null;
let pendingCuriosityClassifyId=null;
const CUR_BOARD_LIMIT=12;
let curBoardFilter='all';
let curBoardQuery='';
let curBoardExpanded=false;
const classifyingCuriosityIds=new Set();
const curLoopDismissed=new Set(JSON.parse(localStorage.getItem('curLoopDismissed')||'[]'));
const curLoopOutcomes=new Map(Object.entries(JSON.parse(localStorage.getItem('curLoopOutcomes')||'{}'))
  .map(([id,value])=>[parseInt(id,10),value]));

function saveCurLoopDismissed(){
  localStorage.setItem('curLoopDismissed', JSON.stringify(Array.from(curLoopDismissed)));
}
function saveCurLoopOutcomes(){
  const data={};
  curLoopOutcomes.forEach((value,key)=>{ data[key]=value; });
  localStorage.setItem('curLoopOutcomes', JSON.stringify(data));
}

function selectedCuriosity(curiosities){
  if(!curiosities.length){ activeCuriosityId=null; return null; }
  let selected=curiosities.find(c=>c.id===activeCuriosityId);
  if(!selected){
    selected=curiosities.find(c=>c.is_greatest) || curiosities[0];
    activeCuriosityId=selected.id;
  }
  return selected;
}

function curOpenCount(cur){
  const counts=cur.item_counts||{};
  return (counts.open_questions||0)+(counts.open_suggestions||0);
}

function curPlacementText(cur){
  const attach=(cur.attached_goals||[])[0];
  return (attach&&attach.path&&attach.path.length) ? attach.path.join(' > ') : 'Unplaced';
}

function curReadyToClassify(cur){
  return (cur.classification_proposals||[]).length>0 ||
    (cur.status==='active' && curOpenCount(cur)===0);
}

function curMatchesBoardFilter(cur){
  if(curBoardFilter==='waiting') return curOpenCount(cur)>0;
  if(curBoardFilter==='classify') return curReadyToClassify(cur);
  if(curBoardFilter==='active') return cur.status==='active';
  return true;
}

function curMatchesBoardQuery(cur){
  const q=curBoardQuery.trim().toLowerCase();
  if(!q) return true;
  return String([
    cur.label||'',
    cur.directive||'',
    cur.status||'',
    curPlacementText(cur)
  ].join(' ')).toLowerCase().includes(q);
}

function curFilteredBoardCuriosities(curiosities){
  return (curiosities||[]).filter(cur=>curMatchesBoardFilter(cur)&&curMatchesBoardQuery(cur));
}

function curBoardCounts(curiosities){
  return {
    all:curiosities.length,
    waiting:curiosities.filter(c=>curOpenCount(c)>0).length,
    classify:curiosities.filter(curReadyToClassify).length,
    active:curiosities.filter(c=>c.status==='active').length,
  };
}

function curBoardToolsHtml(curiosities, filtered){
  const counts=curBoardCounts(curiosities);
  const filters=[
    ['all','All',counts.all],
    ['waiting','Needs answer',counts.waiting],
    ['classify','Ready to classify',counts.classify],
    ['active','Active',counts.active],
  ];
  return '<div class="cur-board-tools">'+
    '<input id="cur-board-search" class="cur-board-search" type="text" placeholder="Search investigations..." value="'+esc(curBoardQuery)+'">'+
    '<div class="cur-board-filters">'+filters.map(([key,label,count])=>
      '<button type="button" class="cur-filter '+(curBoardFilter===key?'active':'')+
      '" data-cur-filter="'+key+'">'+esc(label)+' · '+count+'</button>').join('')+'</div>'+
    '<span class="cur-board-count">'+filtered.length+' shown</span>'+
  '</div>';
}

function curSwitcherCardHtml(cur, isSelected, index, images){
  const counts=cur.item_counts||{};
  const openCount=(counts.open_questions||0)+(counts.open_suggestions||0);
  const waiting=openCount ? openCount+' waiting on you' : 'Nothing waiting';
  const placement=curPlacementText(cur);
  return '<div class="cur-card-tile'+(isSelected?' active':'')+(cur.status==='paused'?' paused':'')+
    '" data-id="'+cur.id+'"'+selfCardBackgroundStyle(index,images)+'>'+
    '<div class="cur-card-tile-head">'+
      (cur.is_greatest?'<span class="cur-card-star">★</span>':'')+
      '<span class="cur-card-label">'+esc(cur.label)+'</span>'+
      (cur.status==='paused'?'<span class="cur-status-chip paused">paused</span>':'')+
    '</div>'+
    '<div class="cur-card-tile-meta">'+esc(waiting)+' · '+esc(placement)+'</div>'+
  '</div>';
}
function renderCuriositySwitcher(curiosities, filtered, selected, images){
  const box=$('cur-switcher');
  if(!box) return;
  if(!curiosities.length){ box.innerHTML=''; return; }
  const visible=curBoardExpanded?filtered:filtered.slice(0,CUR_BOARD_LIMIT);
  const hidden=Math.max(0,filtered.length-visible.length);
  box.innerHTML=curBoardToolsHtml(curiosities, filtered)+
    (filtered.length?'<div class="cur-card-grid">'+
      visible.map((c,i)=>curSwitcherCardHtml(c, selected&&c.id===selected.id, i, images)).join('')+
    '</div>':'<div class="self-empty">No investigations match this view.</div>')+
    (filtered.length>CUR_BOARD_LIMIT?'<button type="button" id="cur-board-more" class="cur-show-more">'+
      (curBoardExpanded?'Show fewer':'Show '+hidden+' more')+'</button>':'');
  const search=$('cur-board-search');
  if(search){
    search.oninput=()=>{
      curBoardQuery=search.value;
      curBoardExpanded=false;
      renderCuriosity(currentCuriosityState||{curiosities}, backgroundImagesCache||[]);
    };
  }
  box.querySelectorAll('.cur-filter').forEach(btn=>{
    btn.onclick=()=>{
      curBoardFilter=btn.dataset.curFilter||'all';
      curBoardExpanded=false;
      renderCuriosity(currentCuriosityState||{curiosities}, backgroundImagesCache||[]);
    };
  });
  if($('cur-board-more')) $('cur-board-more').onclick=()=>{
    curBoardExpanded=!curBoardExpanded;
    renderCuriosity(currentCuriosityState||{curiosities}, backgroundImagesCache||[]);
  };
  box.querySelectorAll('.cur-card-tile').forEach(tile=>{
    tile.onclick=()=>{
      activeCuriosityId=parseInt(tile.dataset.id,10);
      renderCuriosity(currentCuriosityState||{curiosities}, backgroundImagesCache||[]);
    };
  });
}

function curCounts(cur){
  return {
    questions:(cur.open_questions||[]).length,
    suggestions:(cur.open_suggestions||[]).length,
    answered:(cur.resolved||[]).filter(x=>x.status==='answered').length,
    resolved:(cur.resolved||[]).length,
    placements:(cur.classification_proposals||[]).length,
  };
}

function curAsciiTree(cur){
  const c=curCounts(cur);
  const attach=(cur.attached_goals||[])[0];
  const placement=attach && attach.path && attach.path.length ? attach.path.join(' > ') : 'Soul-level / unplaced';
  return [
    'Investigation: '+cur.label,
    '|',
    '+-- Placement: '+placement,
    '+-- Current framing: '+(cur.directive||'journal-seeded investigation'),
    '+-- Evidence gathered: '+c.answered+' answered / '+c.resolved+' resolved',
    '+-- Open loops: '+c.questions+' question(s), '+c.suggestions+' suggestion(s)',
    '+-- Next: '+(c.questions?'answer current questions':'generate sharper follow-up questions'),
  ].join('\n');
}

function curLoopHtml(cur){
  const dismissed=curLoopDismissed.has(cur.id);
  const outcome=curLoopOutcomes.get(cur.id);
  if(pendingCuriosityLoopId===cur.id){
    return '<div class="cur-loop-panel"><div class="cur-sub" style="margin-top:0">Synthesizing answers</div>'+
      '<div class="hint" style="margin:0">Building the next investigation map…</div>'+
      '<div class="cur-loop-load"><i></i></div></div>';
  }
  if(pendingCuriosityClassifyId===cur.id){
    return '<div class="cur-loop-panel"><div class="cur-sub" style="margin-top:0">Classifying placement</div>'+
      '<div class="hint" style="margin:0">No fresh follow-ups appeared, so Faerie is checking whether this belongs in the Goal tree.</div>'+
      '<div class="cur-loop-load"><i></i></div></div>';
  }
  if((cur.open_questions||[]).length) return '';
  if(outcome==='classified'){
    return '<div class="cur-loop-panel"><div class="cur-sub" style="margin-top:0">Ready for placement review</div>'+
      '<pre>'+esc(curAsciiTree(cur))+'</pre><p class="hint">No new follow-up questions appeared from the current context, so Faerie created placement proposal(s) for you to review.</p>'+
      '<div class="actions"><button class="accent cur-loop-continue">Continue investigation</button>'+
      '<button class="skip cur-loop-not-now">Not now</button></div></div>';
  }
  if(outcome==='caught_up'){
    return '<div class="cur-loop-panel"><div class="cur-sub" style="margin-top:0">Caught up for now</div>'+
      '<pre>'+esc(curAsciiTree(cur))+'</pre><p class="hint">Faerie could not find useful new follow-up questions or placement proposals from the current context. Add fresh journal context later, or retry/classify if something changed.</p>'+
      '<div class="actions"><button class="accent cur-loop-continue">Retry follow-ups</button>'+
      '<button class="cur-loop-classify">Classify / place…</button>'+
      '<button class="skip cur-loop-not-now">Not now</button></div></div>';
  }
  if(dismissed){
    return '<div class="cur-loop-panel"><pre>'+esc(curAsciiTree(cur))+'</pre>'+
      '<div class="actions"><button class="accent cur-loop-continue">Continue investigation</button></div></div>';
  }
  return '<div class="cur-loop-panel"><div class="cur-sub" style="margin-top:0">Question batch complete</div>'+
    '<pre>'+esc(curAsciiTree(cur))+'</pre><p class="hint">Want Faerie to generate the next follow-up questions now?</p>'+
    '<div class="actions"><button class="accent cur-loop-continue">Continue with more questions</button>'+
    '<button class="skip cur-loop-not-now">Not now</button></div></div>';
}

function showCuriosityLoop(curiosityId){
  activeCuriosityId=curiosityId;
  pendingCuriosityLoopId=curiosityId;
  curLoopDismissed.delete(curiosityId);
  saveCurLoopDismissed();
  curLoopOutcomes.delete(curiosityId);
  saveCurLoopOutcomes();
  const selected=(currentCuriosityState&&currentCuriosityState.curiosities||[])
    .find(c=>c.id===curiosityId);
  if(selected){
    selected.open_questions=[];
    renderCuriosity(currentCuriosityState);
  }
  setTimeout(()=>{
    continueCuriosity(curiosityId,null,{auto:true});
  },1050);
}

function continueCuriosity(curiosityId, button, options={}){
  if(!api()) return;
  const auto=!!options.auto;
  curLoopDismissed.delete(curiosityId);
  saveCurLoopDismissed();
  curLoopOutcomes.delete(curiosityId);
  saveCurLoopOutcomes();
  const selected=(currentCuriosityState&&currentCuriosityState.curiosities||[])
    .find(c=>c.id===curiosityId);
  const hadOpenItems=!!(selected && ((selected.open_questions||[]).length ||
    (selected.open_suggestions||[]).length));
  if(button) button.disabled=true;
  if(auto){
    pendingCuriosityLoopId=curiosityId;
    const selected=(currentCuriosityState&&currentCuriosityState.curiosities||[])
      .find(c=>c.id===curiosityId);
    if(selected) renderCuriosity(currentCuriosityState);
  }
  autoDatabaseRescue('before curiosity generate').then(()=>
    pywebview.api.curiosity_generate_more(curiosityId)).then(r=>{
    if(button) button.disabled=false;
    if(auto) pendingCuriosityLoopId=null;
    if(!r || r.ok===false){ toast((r&&r.message)||'Could not continue.', true); return; }
    if(r.created){
      toast(r.created+' new follow-up(s) ready.');
      loadCuriosity();
      return;
    }
    if(!hadOpenItems){
      toast('No new follow-ups — classifying where this belongs now.');
      classifyCuriosity(curiosityId, null, {auto:true});
      return;
    }
    curLoopOutcomes.set(curiosityId,'caught_up');
    saveCurLoopOutcomes();
    toast('No new follow-ups yet — answer or dismiss the existing open items first.');
    loadCuriosity();
  }).catch(e=>{
    if(button) button.disabled=false;
    if(auto) pendingCuriosityLoopId=null;
    toast('Could not continue investigation: '+e, true);
  });
}

function curQuestionHtml(cur, item){
  const conf = item.confidence!=null ? ' <span class="cur-conf">'+pct(item.confidence)+' confident</span>' : '';
  const isYesNo=item.response_type==='yes_no';
  const rating = item.response_type==='rating' ?
    '<label class="metric-field" style="margin:8px 0"><span>Assessment rating</span><select class="cur-rating">'+
    Array.from({length:21},(_,i)=>i/2).map(v=>'<option value="'+v+'"'+(v===5?' selected':'')+'>'+v.toFixed(1)+'</option>').join('')+
    '</select><span class="metric-rating">Average</span></label>' : '';
  return '<div class="cur-item" id="cur-item-'+item.id+'">' +
    '<div class="quick-type">'+(isYesNo?'Quick clarifier':'Reflection prompt')+'</div>'+
    '<div class="cur-text">'+esc(item.text)+conf+'</div>' +
    (isYesNo?'<div class="choice-pills">'+
      '<button type="button" class="cur-quick-answer" data-answer="Yes.">Yes</button>'+
      '<button type="button" class="cur-quick-answer" data-answer="No.">No</button>'+
      '<button type="button" class="cur-quick-answer" data-answer="Kind of / it depends: ">Kind of</button>'+
    '</div>':'')+
    rating+'<div class="editor open"><textarea spellcheck="false" placeholder="'+
    (isYesNo?'Add a sentence if useful…':'Answer in your own words…')+'"></textarea>' +
    '<div class="cur-answer-tools">'+
      '<label>Confidence in your answer<select class="cur-answer-confidence">'+
        '<option value="0.55">unsure</option><option value="0.7" selected>somewhat</option>'+
        '<option value="0.85">pretty confident</option><option value="0.95">very confident</option>'+
      '</select></label>'+
      '<label>Question fit<select class="cur-question-fit">'+
        '<option value="useful" selected>useful</option><option value="too_broad">too broad</option>'+
        '<option value="not_relevant">not relevant</option><option value="ask_gently">ask more gently</option>'+
      '</select></label></div>' +
    '<div class="row">' +
      '<button class="skip cur-dismiss">Dismiss</button>' +
      '<button class="accent cur-answer-save">Answer</button>' +
    '</div></div></div>';
}

function bindCurQuestion(cur, item){
  const el=$('cur-item-'+item.id);
  el.querySelector('.cur-dismiss').onclick=()=>{
    if(!api()) return;
    pywebview.api.curiosity_dismiss(item.id).then(r=>{
      if(r && r.ok===false){ toast(r.message||'Could not dismiss.', true); return; }
      toast('Dismissed.');
      if((cur.open_questions||[]).length<=1) showCuriosityLoop(cur.id);
      else loadCuriosity();
    }).catch(e=>toast('Could not dismiss: '+e, true));
  };
  const textarea=el.querySelector('textarea');
  const rating=el.querySelector('.cur-rating');
  el.querySelectorAll('.cur-quick-answer').forEach(btn=>{
    btn.onclick=()=>{
      el.querySelectorAll('.cur-quick-answer').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      textarea.value=btn.dataset.answer;
      textarea.focus();
      autoGrow(textarea);
    };
  });
  if(rating) rating.onchange=()=>{
    const v=parseFloat(rating.value), label=rating.nextElementSibling;
    label.textContent=v===0?'Unable / depleted':v<2?'Very depleted':v<3.5?'Low':
      v<5?'Below average':v<5.5?'Average':v<7?'Above average':v<8.5?'Good':
      v<9.5?'Very good':'Excellent';
  };
  const submit=()=>{
    let text=textarea.value.trim();
    if(!text){ toast('Write an answer first.', true); return; }
    const confidence=el.querySelector('.cur-answer-confidence');
    const fit=el.querySelector('.cur-question-fit');
    const meta=[];
    if(confidence) meta.push('answer_confidence='+confidence.value);
    if(fit) meta.push('question_fit='+fit.value);
    if(meta.length) text += '\n\n[reflection_gate: '+meta.join('; ')+']';
    if(!api()) return;
    const btn=el.querySelector('.cur-answer-save'); btn.disabled=true;
    autoDatabaseRescue('before curiosity answer').then(()=>
      pywebview.api.curiosity_answer(item.id, text, rating?parseFloat(rating.value):null)).then(r=>{
      btn.disabled=false;
      if(r && r.ok===false){ toast(r.message||'Could not save answer.', true); return; }
      toast('Saved to memory.');
      if((cur.open_questions||[]).length<=1) showCuriosityLoop(cur.id);
      else loadCuriosity();
    }).catch(e=>{ btn.disabled=false; toast('Could not save answer: '+e, true); });
  };
  el.querySelector('.cur-answer-save').onclick=submit;
  bindShiftEnterSubmit(textarea, submit);
}

function curSuggestionHtml(item){
  const conf = item.confidence!=null ? ' <span class="cur-conf">'+pct(item.confidence)+' confident</span>' : '';
  const outcome=item.metric_event_type==='practice'&&item.metric_dimension_slug ?
    '<label class="metric-field" style="margin:8px 0"><span>Measured outcome (optional)</span>'+
    '<select class="cur-outcome"><option value="">XP only</option>'+
    Array.from({length:21},(_,i)=>i/2).map(v=>'<option value="'+v+'">'+v.toFixed(1)+'</option>').join('')+
    '</select><span class="metric-rating">No mastery change</span></label>':'';
  return '<div class="cur-item" id="cur-item-'+item.id+'">' +
    '<div class="cur-text">'+esc(item.text)+conf+'</div>' +
    outcome+
    '<div class="actions">' +
      '<button class="accent cur-implement">Implement…</button>' +
      '<button class="yes cur-sugg" data-action="tried">Tried it</button>' +
      '<button class="kind cur-sugg" data-action="not_helpful_light">Not helpful (a little)</button>' +
      '<button class="no cur-sugg" data-action="not_helpful_heavy">Not helpful (a lot)</button>' +
      '<button class="skip cur-sugg" data-action="dismissed">Dismiss</button>' +
    '</div></div>';
}

function bindCurSuggestion(item){
  const el=$('cur-item-'+item.id);
  el.querySelector('.cur-implement').onclick=()=>openGoalPlanner(item.id);
  const outcome=el.querySelector('.cur-outcome');
  if(outcome) outcome.onchange=()=>{
    outcome.nextElementSibling.textContent=outcome.value?'Uses explicit outcome evidence':'No mastery change';
  };
  el.querySelectorAll('.cur-sugg').forEach(btn=>{
    btn.onclick=()=>{
      if(!api()) return;
      el.querySelectorAll('.cur-sugg').forEach(b=>b.disabled=true);
      const measured=(btn.dataset.action==='tried'&&outcome&&outcome.value)?parseFloat(outcome.value):null;
      pywebview.api.curiosity_respond_suggestion(item.id, btn.dataset.action, measured).then(r=>{
        if(r && r.ok===false){ el.querySelectorAll('.cur-sugg').forEach(b=>b.disabled=false);
          toast(r.message||'Could not save.', true); return; }
        toast('Noted.'); loadCuriosity();
      }).catch(e=>{ el.querySelectorAll('.cur-sugg').forEach(b=>b.disabled=false);
        toast('Could not save: '+e, true); });
    };
  });
}

const CUR_TAG_CLASS = {answered:'answered', dismissed:'dismissed', tried:'tried',
  not_helpful_light:'nh-light', not_helpful_heavy:'nh-heavy'};
const CUR_TAG_LABEL = {answered:'answered', dismissed:'dismissed', tried:'tried',
  not_helpful_light:'not helpful (a little)', not_helpful_heavy:'not helpful (a lot)'};

function curResolvedHtml(items){
  if(!items.length) return '<div class="empty" style="padding:10px">Nothing resolved yet.</div>';
  return items.map(x=>
    '<div class="resolved-row"><div class="rr-body">' +
      '<div class="rr-q">'+esc(x.text)+'</div>' +
      (x.answer ? '<div class="rr-a">'+esc(x.answer)+'</div>' : '') +
    '</div><span class="rr-tag '+(CUR_TAG_CLASS[x.status]||'')+'">'+
      esc(CUR_TAG_LABEL[x.status]||x.status)+'</span></div>').join('');
}

function curAttachmentHtml(cur){
  const goals=cur.attached_goals||[];
  if(!goals.length){
    return '<div class="cur-attachments"><span class="cur-attach-chip soul">Soul-level investigation</span></div>';
  }
  return '<div class="cur-attachments">'+goals.map(g=>{
    const path=(g.path&&g.path.length)?g.path.join(' › '):g.goal_title;
    return '<span class="cur-attach-chip">'+esc(goalTypeLabel(g.goal_type))+' · '+esc(path)+'</span>';
  }).join('')+'</div>';
}

function curClassificationTitle(p){
  const data=p.payload||{};
  if(p.type==='attach_existing') return 'Attach to existing node #'+data.goal_id;
  if(p.type==='create_branch') return 'Create Branch: '+(data.title||'New Branch');
  if(p.type==='create_root_branch') return 'Create Root skeleton: '+(data.root_title||'New Root');
  if(p.type==='create_leaf') return 'Create Leaf: '+(data.title||'New Leaf');
  if(p.type==='keep_soul') return 'Keep Soul-level';
  if(p.type==='keep_investigating') return 'Keep investigating';
  return p.type;
}

function curClassificationHtml(cur){
  const proposals=cur.classification_proposals||[];
  if(!proposals.length) return '';
  return '<div class="cur-sub">Classification proposals</div>'+proposals.map(p=>{
    const payload=p.payload||{};
    const summary=Object.entries(payload).slice(0,5).map(([k,v])=>
      '<div class="resolved-row"><div class="rr-body"><b>'+esc(k.replaceAll('_',' '))+
      '</b><br>'+esc(String(v))+'</div></div>').join('');
    return '<div class="agent-proposal cur-classification" data-cpid="'+p.id+'"><div class="cur-text"><b>'+
      esc(curClassificationTitle(p))+'</b></div><div class="hint">'+esc(p.rationale||'')+
      '</div><div class="cur-proposal-summary">'+summary+'</div>'+
      '<details class="goal-full-note"><summary>Show raw proposal</summary><div>'+
      esc(JSON.stringify(payload,null,2))+'</div></details><div class="actions">'+
      '<button class="cur-class-dismiss skip">Dismiss</button><button class="cur-class-approve accent">Approve</button>'+
      '</div></div>';
  }).join('');
}

function curMetricHtml(cur){
  const p=cur.metric_profile;
  if(!p) return '';
  if(p.status!=='approved'){
    const importanceLabel=v=>v<=0?'Excluded':v<3?'Low':v<7?'Average':v<9?'High':'Essential';
    const options=(selected)=>Array.from({length:21},(_,i)=>i/2).map(v=>
      '<option value="'+v+'"'+(Math.abs(v-selected)<.01?' selected':'')+'>'+v.toFixed(1)+'</option>').join('');
    const edit=(d,kind)=>'<div class="metric-edit" data-kind="'+kind+'" data-slug="'+esc(d.slug)+'">'+
      '<span>'+esc(d.label)+'</span>'+
      (kind==='growth'?'<span class="metric-importance-wrap"><select class="metric-weight" '+
        'aria-label="Importance">'+options(Math.max(0,Math.min(10,(d.weight??.2)*25)))+'</select>'+
        '<span class="metric-importance-label">'+importanceLabel((d.weight??.2)*25)+'</span></span>':'<span>state</span>')+
      '<input class="metric-prompt" value="" placeholder="'+esc(d.checkin_prompt)+'" '+
        'data-default="'+esc(d.checkin_prompt)+'"></div>';
    return '<div class="metric-panel"><div class="cur-sub" style="margin-top:0">Proposed mastery profile</div>'+
      '<p class="hint">For this investigation: <b>'+esc(cur.label||'')+'</b>. '+
        (p.domain==='mental_health'
          ?'These are the standard mental-health starter measures, keyword-matched to this investigation — not written specifically for it.'
          :p.domain==='exercise'
          ?'These are the standard exercise starter measures, keyword-matched to this investigation — not written specifically for it.'
          :'These are the standard general starter measures, keyword-matched to this investigation — not written specifically for it.')+
        ' Rename or reword anything, or set importance to 0 to drop a row, before approving.</p>'+
      '<p class="hint">Review these measures before scoring begins. Importance runs from 0 (exclude) to 10 (essential) in 0.5 steps. The check-in wording is a placeholder, so it disappears when you type. State describes today; it never affects mastery or level.</p>'+
      (p.domain==='mental_health'?'<p class="hint">These measures are reflective and non-diagnostic.</p>':'')+
      (p.dimensions||[]).map(d=>edit(d,'growth')).join('')+
      (p.state_metrics||[]).map(d=>edit(d,'state')).join('')+
      '<button class="accent metric-approve">Approve profile</button></div>';
  }
  const s=cur.metric_snapshot;
  const top=s?'<div class="metric-top">'+
    '<div class="metric-stat"><b>'+s.level+'</b><span>Level</span></div>'+
    '<div class="metric-stat"><b>'+s.total_xp+'</b><span>XP</span></div>'+
    '<div class="metric-stat"><b>'+(s.overall_mastery==null?'—':Math.round(s.overall_mastery)+'%')+'</b><span>Mastery</span></div>'+
    '<div class="metric-stat"><b>'+Math.round(s.overall_confidence*100)+'%</b><span>Confidence</span></div></div>':'';
  const scoreLabel=v=>v===0?'Unable / depleted':v<2?'Very depleted':v<3.5?'Low':
    v<5?'Below average':v<5.5?'Average':v<7?'Above average':v<8.5?'Good':
    v<9.5?'Very good':'Excellent';
  const scoreOptions=Array.from({length:21},(_,i)=>i/2).map(v=>
    '<option value="'+v+'"'+(v===5?' selected':'')+'>'+v.toFixed(1)+'</option>').join('');
  const score=(d,kind)=>'<label class="metric-field"><span>'+esc(d.label)+'</span>'+
    '<select class="metric-score" data-kind="'+kind+'" data-slug="'+esc(d.slug)+'">'+scoreOptions+'</select>'+
    '<span class="metric-rating">'+scoreLabel(5)+'</span></label>';
  const logs=(cur.metric_history||[]).slice(-7).map(x=>esc(x.snapshot_date)+' · '+esc(x.summary)).join('<br>');
  const bar=(label,value,confidence)=>'<div class="metric-bar-row"><div class="metric-bar-head"><span>'+esc(label)+
    '</span><span>'+(value==null?'unknown':Math.round(value)+'%')+
    (confidence==null?'':' · '+Math.round(confidence*100)+'% confidence')+'</span></div>'+
    '<div class="metric-progress"><i style="width:'+(value==null?0:Math.max(0,Math.min(100,value)))+'%"></i></div></div>';
  const stateBars=s?Object.entries(s.state||{}).map(([slug,value])=>{
    const d=(p.state_metrics||[]).find(x=>x.slug===slug); return bar(d?d.label:slug,value,null);}).join(''):'';
  const growthBars=s?(p.dimensions||[]).map(d=>{
    const m=(s.metrics||{})[d.slug]||{}; return bar(d.label,m.mastery,m.confidence);}).join(''):'';
  const populated=s?(p.dimensions||[]).map(d=>[d,(s.metrics||{})[d.slug]||{}])
    .filter(x=>x[1].mastery!=null).sort((a,b)=>a[1].mastery-b[1].mastery):[];
  const recommendation=populated.length?populated[0][0].checkin_prompt:
    'Complete a brief check-in when you have real evidence to add.';
  const publication=p.publication_status||'private';
  const publish = publication==='ready' ?
    '<button class="accent metric-publish-btn">Publish dashboard to Notion</button>' :
    publication==='published' ? '<button class="metric-unpublish-btn">Stop Notion updates</button>' : '';
  const publishText=publication==='private' ?
    Math.min(7,(s&&s.calibration_days)||0)+'/7 check-in days · private preview' :
    publication==='ready'?'Calibration complete · ready to publish':'Published to Notion';
  const summaryStats=s?[
    'Level '+s.level,
    s.total_xp+' XP',
    'Mastery '+(s.overall_mastery==null?'—':Math.round(s.overall_mastery)+'%'),
    'Confidence '+Math.round(s.overall_confidence*100)+'%',
    publishText
  ]:[publishText];
  return '<details class="metric-panel metric-collapsible"><summary class="metric-summary">'+
    '<span class="metric-summary-title">Check-in & mastery</span>'+
    '<span class="metric-summary-stats">'+summaryStats.map(x=>'<span>'+esc(x)+'</span>').join('')+
    '</span></summary><div class="metric-body">'+top+'<div class="cur-sub">Daily check-in</div>'+
    '<p class="hint">Choose in 0.5 steps: 0 means unable or depleted, 5 is average, and 10 is excellent.</p>'+
    '<div class="metric-grid">'+(p.state_metrics||[]).map(d=>score(d,'state')).join('')+
    (p.dimensions||[]).map(d=>score(d,'growth')).join('')+'</div>'+
    '<textarea class="metric-note" rows="2" style="width:100%;margin-top:10px" placeholder="Private note (stays on this computer)"></textarea>'+
    '<div class="actions" style="margin-top:8px"><button class="accent metric-checkin">Save check-in</button></div>'+
    (s?'<div class="cur-sub">Current state</div><div class="metric-bars">'+stateBars+'</div>'+
      '<div class="cur-sub">Growth dimensions</div><div class="metric-bars">'+growthBars+'</div>'+
      '<div class="cur-sub">Recommended next action</div><p class="hint">'+esc(recommendation)+'</p>':'')+
    (cur.metric_preview?'<img class="metric-preview" alt="Private mastery radar and trend preview" src="'+cur.metric_preview+'">':'')+
    '<div class="metric-publish"><span class="hint" style="margin:0">'+publishText+'</span>'+publish+'</div>'+
    (logs?'<div class="metric-log">'+logs+'</div>':'')+'</div></details>';
}

function curCardHtml(cur){
  const star = cur.is_greatest ? '★' : '☆';
  const starClass = cur.is_greatest ? 'cur-star on' : 'cur-star';
  const statusChip = cur.status==='paused'
    ? '<span class="cur-status-chip paused">paused</span>' : '';
  const openQ = cur.open_questions||[], openS = cur.open_suggestions||[], resolved = cur.resolved||[];
  return '<div class="card" id="cur-'+cur.id+'">' +
    '<div class="cur-head">' +
      '<span class="'+starClass+'" title="Make greatest">'+star+'</span>' +
      '<span class="cur-label">'+esc(cur.label)+'</span>' +
      statusChip +
      '<div class="actions" style="margin-left:auto">' +
        '<button class="cur-rename">Rename</button>' +
        '<button class="cur-chat">Continue in chat</button>' +
        '<button class="cur-classify">Classify / place…</button>' +
        '<button class="cur-generate">Continue investigation</button>' +
        (cur.status==='paused'
          ? '<button class="cur-reactivate">Resume</button>'
          : '<button class="cur-pause">Pause</button>') +
        '<button class="cur-archive">Archive</button>' +
      '</div>' +
    '</div>' +
    '<div class="cur-directive">'+esc(cur.directive)+'</div>' +
    curAttachmentHtml(cur) +
    curClassificationHtml(cur) +
    curLoopHtml(cur) +
    curMetricHtml(cur) +
    (openQ.length ? '<div class="cur-sub">Questions</div>' +
      openQ.map(item=>curQuestionHtml(cur, item)).join('') : '') +
    (openS.length ? '<div class="cur-sub">Suggestions</div>' +
      openS.map(curSuggestionHtml).join('') : '') +
    (!openQ.length && !openS.length
      ? '<div class="empty" style="padding:14px">Nothing waiting on you right now — ' +
        'continue the investigation, classify/place it, or add fresh journal context when something changes.</div>' : '') +
    (resolved.length ? '<div class="cur-sub">Recently resolved</div>' + curResolvedHtml(resolved) : '') +
  '</div>';
}

function bindCurCard(cur){
  const card=$('cur-'+cur.id);
  card.querySelector('.cur-rename').onclick=()=>renameCuriosity(cur.id,cur.label);
  card.querySelector('.cur-chat').onclick=()=>{
    switchView('self');
    const input=$('cc-input');
    if(input){
      input.value='Let\'s continue the "'+cur.label+'" investigation.';
      autoGrow(input);
      input.focus();
    }
  };
  card.querySelectorAll('.cur-loop-continue').forEach(btn=>{
    btn.onclick=()=>continueCuriosity(cur.id,btn);
  });
  card.querySelectorAll('.cur-loop-classify').forEach(btn=>{
    btn.onclick=()=>classifyCuriosity(cur.id,btn,{auto:false});
  });
  card.querySelectorAll('.cur-loop-not-now').forEach(btn=>{
    btn.onclick=()=>{
      curLoopDismissed.add(cur.id);
      saveCurLoopDismissed();
      curLoopOutcomes.delete(cur.id);
      saveCurLoopOutcomes();
      renderCuriosity(currentCuriosityState);
    };
  });
  card.querySelector('.cur-classify').onclick=e=>classifyCuriosity(cur.id,e.target,{auto:false});
  card.querySelectorAll('.cur-classification').forEach(box=>{
    const id=parseInt(box.dataset.cpid,10);
    box.querySelector('.cur-class-dismiss').onclick=()=>curClassificationAction(id,'dismiss');
    box.querySelector('.cur-class-approve').onclick=()=>curClassificationAction(id,'approve');
  });
  const approve=card.querySelector('.metric-approve');
  if(approve) approve.onclick=()=>{
    if(!api()) return;
    const dims=[], states=[];
    card.querySelectorAll('.metric-edit').forEach(row=>{
      const original=(row.dataset.kind==='growth'?cur.metric_profile.dimensions:cur.metric_profile.state_metrics)
        .find(x=>x.slug===row.dataset.slug);
      const prompt=row.querySelector('.metric-prompt');
      const item={...original,checkin_prompt:prompt.value.trim()||prompt.dataset.default};
      if(row.dataset.kind==='growth'){
        item.weight=parseFloat(row.querySelector('.metric-weight').value||'0'); dims.push(item);
      } else states.push(item);
    });
    approve.disabled=true;
    pywebview.api.curiosity_metric_approve(cur.id,dims,states).then(r=>{
      if(!r||r.ok===false){ approve.disabled=false; toast((r&&r.message)||'Could not approve.',true); return; }
      toast('Mastery profile approved.'); loadCuriosity();
    }).catch(e=>{approve.disabled=false;toast('Could not approve: '+e,true);});
  };
  card.querySelectorAll('.metric-weight').forEach(select=>{
    select.onchange=()=>{
      const v=parseFloat(select.value), label=select.nextElementSibling;
      label.textContent=v<=0?'Excluded':v<3?'Low':v<7?'Average':v<9?'High':'Essential';
    };
  });
  card.querySelectorAll('.metric-score').forEach(select=>{
    select.onchange=()=>{
      const v=parseFloat(select.value), label=select.nextElementSibling;
      label.textContent=v===0?'Unable / depleted':v<2?'Very depleted':v<3.5?'Low':
        v<5?'Below average':v<5.5?'Average':v<7?'Above average':v<8.5?'Good':
        v<9.5?'Very good':'Excellent';
    };
  });
  const checkin=card.querySelector('.metric-checkin');
  if(checkin) checkin.onclick=()=>{
    if(!api()) return;
    const state={}, growth={};
    card.querySelectorAll('.metric-score').forEach(el=>{
      (el.dataset.kind==='state'?state:growth)[el.dataset.slug]=parseFloat(el.value);
    });
    checkin.disabled=true;
    pywebview.api.curiosity_metric_checkin(cur.id,state,growth,
      card.querySelector('.metric-note').value).then(r=>{
      if(!r||r.ok===false){checkin.disabled=false;toast((r&&r.message)||'Could not save.',true);return;}
      toast('Check-in saved. +5 XP'); loadCuriosity();
    }).catch(e=>{checkin.disabled=false;toast('Could not save: '+e,true);});
  };
  const publish=card.querySelector('.metric-publish-btn');
  if(publish) publish.onclick=()=>{
    publish.disabled=true;
    pywebview.api.curiosity_metric_publish(cur.id).then(r=>{
      if(!r||r.ok===false){publish.disabled=false;toast((r&&r.message)||'Publish failed.',true);return;}
      toast('Dashboard published to Notion.');loadCuriosity();
    }).catch(e=>{publish.disabled=false;toast('Publish failed: '+e,true);});
  };
  const unpublish=card.querySelector('.metric-unpublish-btn');
  if(unpublish) unpublish.onclick=()=>{
    unpublish.disabled=true;
    pywebview.api.curiosity_metric_unpublish(cur.id).then(r=>{
      if(!r||r.ok===false){unpublish.disabled=false;toast((r&&r.message)||'Could not stop updates.',true);return;}
      toast('Future Notion updates stopped.');loadCuriosity();
    }).catch(e=>{unpublish.disabled=false;toast('Could not stop updates: '+e,true);});
  };
  card.querySelector('.cur-star').onclick=()=>{
    if(!api()) return;
    pywebview.api.curiosity_set_greatest(cur.id).then(r=>{
      if(r && r.ok===false){ toast(r.message||'Could not update.', true); return; }
      toast('"'+cur.label+'" is now the greatest curiosity.'); loadCuriosity();
    }).catch(e=>toast('Could not update: '+e, true));
  };
  card.querySelector('.cur-generate').onclick=(e)=>{
    continueCuriosity(cur.id,e.target);
  };
  const pauseBtn=card.querySelector('.cur-pause');
  if(pauseBtn) pauseBtn.onclick=()=>{
    if(!api()) return;
    pywebview.api.curiosity_pause(cur.id).then(r=>{
      if(r && r.ok===false){ toast(r.message||'Could not pause.', true); return; }
      toast('Paused.'); loadCuriosity();
    }).catch(e=>toast('Could not pause: '+e, true));
  };
  const resumeBtn=card.querySelector('.cur-reactivate');
  if(resumeBtn) resumeBtn.onclick=()=>{
    if(!api()) return;
    pywebview.api.curiosity_reactivate(cur.id).then(r=>{
      if(r && r.ok===false){ toast(r.message||'Could not resume.', true); return; }
      toast('Resumed.'); loadCuriosity();
    }).catch(e=>toast('Could not resume: '+e, true));
  };
  card.querySelector('.cur-archive').onclick=()=>{
    if(!api()) return;
    if(!confirm('Archive "'+cur.label+'"? Open items stay put but generation stops. ' +
      'You can find it under Archived and reactivate anytime.')) return;
    pywebview.api.curiosity_archive(cur.id).then(r=>{
      if(r && r.ok===false){ toast(r.message||'Could not archive.', true); return; }
      toast('Archived.'); loadCuriosity();
    }).catch(e=>toast('Could not archive: '+e, true));
  };
  (cur.open_questions||[]).forEach(item=>bindCurQuestion(cur, item));
  (cur.open_suggestions||[]).forEach(item=>bindCurSuggestion(item));
}

function classifyCuriosity(curiosityId, button, options={}){
  if(!api()) return Promise.resolve(null);
  if(classifyingCuriosityIds.has(curiosityId)){
    toast('Classification is already running for this investigation.');
    return Promise.resolve(null);
  }
  classifyingCuriosityIds.add(curiosityId);
  const auto=!!options.auto;
  if(button) button.disabled=true;
  if(auto){
    pendingCuriosityClassifyId=curiosityId;
    const selected=(currentCuriosityState&&currentCuriosityState.curiosities||[])
      .find(c=>c.id===curiosityId);
    if(selected) renderCuriosity(currentCuriosityState);
  }
  return autoDatabaseRescue('before curiosity classify').then(()=>
    pywebview.api.curiosity_classify(curiosityId)).then(r=>{
    if(button) button.disabled=false;
    classifyingCuriosityIds.delete(curiosityId);
    if(auto) pendingCuriosityClassifyId=null;
    if(!r||r.ok===false){
      if(auto){
        curLoopOutcomes.set(curiosityId,'caught_up');
        saveCurLoopOutcomes();
      }
      toast((r&&r.message)||'Could not classify investigation.',true);
      loadCuriosity();
      return r;
    }
    if(r.created){
      curLoopOutcomes.set(curiosityId,'classified');
      saveCurLoopOutcomes();
      toast(r.created+' placement proposal(s) ready.');
    } else {
      curLoopOutcomes.set(curiosityId,'caught_up');
      saveCurLoopOutcomes();
      toast(auto
        ? 'Caught up: no useful follow-ups or placement proposals from current context.'
        : 'No new placement proposals — existing ones may already cover this.');
    }
    loadCuriosity();
    return r;
  }).catch(err=>{
    if(button) button.disabled=false;
    classifyingCuriosityIds.delete(curiosityId);
    if(auto){
      pendingCuriosityClassifyId=null;
      curLoopOutcomes.set(curiosityId,'caught_up');
      saveCurLoopOutcomes();
    }
    toast('Could not classify investigation: '+err,true);
    loadCuriosity();
    return null;
  });
}

function curClassificationAction(id,action){
  if(!api()) return;
  const box=document.querySelector('.cur-classification[data-cpid="'+id+'"]');
  if(box){
    box.querySelectorAll('button').forEach(b=>b.disabled=true);
    box.insertAdjacentHTML('beforeend','<div class="cur-loop-panel"><div class="cur-sub" style="margin-top:0">Finalizing</div><div class="hint" style="margin:0">Applying this placement decision and refreshing the investigation…</div><div class="cur-loop-load"><i></i></div></div>');
  }
  withDbRetry(()=>pywebview.api.curiosity_classification_proposal(id,action)).then(r=>{
    if(!r||r.ok===false){toast((r&&r.message)||'Could not update placement proposal.',true);loadCuriosity();return;}
    toast(action==='approve'
      ? (r.created_question_id?'Follow-up question added.':'Placement applied.')
      : 'Placement dismissed.');
    loadCuriosity();
    if(r.tree&&goalState) loadGoals();
  }).catch(e=>{toast('Could not update placement proposal: '+e,true);loadCuriosity();});
}

function curArchivedHtml(rows){
  if(!rows.length) return '<div class="empty" style="padding:14px">Nothing archived.</div>';
  return rows.map(c=>
    '<div class="resolved-row"><div class="rr-body">' +
      '<div class="rr-q">'+esc(c.label)+'</div>' +
      '<div class="rr-a">'+esc(c.directive)+'</div>' +
    '</div><button class="cur-rename-archived" data-id="'+c.id+'" data-label="'+esc(c.label)+
      '">Rename</button><button class="cur-reactivate-archived" data-id="'+c.id+'">Reactivate</button></div>').join('');
}

function renameCuriosity(id,current){
  const label=prompt('Rename this curiosity:',current); if(!label||label.trim()===current) return;
  pywebview.api.curiosity_rename(id,label.trim()).then(r=>{
    if(!r||r.ok===false){ toast((r&&r.message)||'Could not rename curiosity.',true); return; }
    toast('Curiosity renamed.'); loadCuriosity();
  }).catch(e=>toast('Could not rename curiosity: '+e,true));
}

function renderCuriosity(s, images){
  images=images||backgroundImagesCache||[];
  currentCuriosityState=s;
  const list=$('cur-list');
  const curiosities=dedupeCuriositiesForDisplay(s.curiosities||[]);
  if(!curiosities.length){
    renderCuriositySwitcher([], [], null, images);
    list.innerHTML='<div class="card"><div class="empty">No open investigations.</div></div>';
  } else {
    const filtered=curFilteredBoardCuriosities(curiosities);
    const selected=selectedCuriosity(filtered);
    renderCuriositySwitcher(curiosities, filtered, selected, images);
    if(selected){
      list.innerHTML = curCardHtml(selected);
      bindCurCard(selected);
    } else {
      list.innerHTML='<div class="card"><div class="empty">No investigations match this view.</div></div>';
    }
  }
  const arch=$('cur-archived');
  if(!arch) return;
  arch.innerHTML = curArchivedHtml(s.archived||[]);
  arch.querySelectorAll('.cur-rename-archived').forEach(btn=>{
    btn.onclick=()=>renameCuriosity(parseInt(btn.dataset.id,10),btn.dataset.label);
  });
  arch.querySelectorAll('.cur-reactivate-archived').forEach(btn=>{
    btn.onclick=()=>{
      if(!api()) return;
      pywebview.api.curiosity_reactivate(parseInt(btn.dataset.id,10)).then(r=>{
        if(r && r.ok===false){ toast(r.message||'Could not reactivate.', true); return; }
        toast('Reactivated.'); loadCuriosity();
      }).catch(e=>toast('Could not reactivate: '+e, true));
    };
  });
}

function loadCuriosity(){
  if(!api()) return;
  Promise.all([
    pywebview.api.curiosity_state(),
    loadBackgroundImages()
  ]).then(([state,images])=>renderCuriosity(state,images)).catch(()=>{});
}

/* ---------- memory ---------- */
function loadMemory(){
  if(!api()) return;
  pywebview.api.memory(showHist).then(groups=>{
    memData=groups||[]; renderMemory();
  }).catch(()=>{});
}

function renderMemory(){
  const q=$('mem-search').value.trim().toLowerCase();
  const box=$('mem-groups'); let total=0, shown=0;
  const html=memData.map(g=>{
    const facts=g.facts.filter(f=>{
      total++;
      const hit=!q || (f.attribute||'').toLowerCase().includes(q) ||
        (f.value||'').toLowerCase().includes(q) || (g.category||'').toLowerCase().includes(q);
      if(hit) shown++;
      return hit;
    });
    if(!facts.length) return '';
    return '<div class="cat"><div class="head"><span>'+esc(g.category)+'</span>' +
      '<span class="n">'+facts.length+'</span><span class="arrow">▼</span></div>' +
      '<div class="facts">' + facts.map(f=>{
        const sup=f.status && f.status!=='active';
        const dates=sup && f.valid_from ? esc(f.valid_from)+' → '+esc(f.valid_to||'') : '';
        return '<div class="fact'+(sup?' superseded':'')+'">' +
          '<span class="attr">'+esc(f.attribute)+'</span>' +
          '<span class="val">'+esc(f.value)+'</span>' +
          (dates?'<span class="dates">'+dates+'</span>':'') +
          (sup?'<span class="status">'+esc(f.status)+'</span>':'') +
          (!sup?'<button class="forget" data-id="'+f.id+'">Forget</button>':'') +
        '</div>'; }).join('') +
      '</div></div>';
  }).join('');
  box.innerHTML = html || '<div class="card"><div class="empty">' +
    (q ? 'Nothing matches "'+esc(q)+'".' :
      'Memory is empty — it fills as capture runs and nightly triage distils your day.') +
    '</div></div>';
  $('mem-count').textContent = q ? shown+' of '+total+' facts' : total+' facts';
  box.querySelectorAll('.cat > .head').forEach(h=>{
    h.onclick=()=>h.parentElement.classList.toggle('closed');
  });
  box.querySelectorAll('.fact .forget').forEach(btn=>{
    btn.onclick=()=>{
      const message='Permanently forget this fact? This also clears linked answers, '+
        'source activity, stale memory backups, and configured mirrors.';
      if(!confirm(message)) return;
      btn.disabled=true;
      pywebview.api.memory_forget(parseInt(btn.dataset.id,10)).then(result=>{
        if(!result||!result.ok){ toast((result&&result.message)||'Forget failed',true); return; }
        const warning=result.warnings&&result.warnings.length ?
          ' Mirror warning: '+result.warnings.join(', ') : '';
        toast('Memory forgotten.'+warning); loadMemory();
      }).catch(()=>toast('Forget failed',true));
    };
  });
}

$('mem-search').addEventListener('input', renderMemory);
$('refresh-mem').onclick=loadMemory;
$('hist-toggle').onclick=()=>{
  showHist=!showHist;
  $('hist-toggle').classList.toggle('on', showHist);
  loadMemory();
};

/* ---------- boot ---------- */
function callBootstrap(attemptsLeft){
  // pywebview's `pywebviewready` event can fire before every js_api method is
  // actually attached to window.pywebview.api yet (confirmed: gui.py's own
  // log shows app_bootstrap was never even reached on the Python side when
  // this happened) — so a missing method is treated the same as a slow/failed
  // call: wait briefly and retry, rather than immediately declaring the
  // bridge broken.
  if(!pywebview.api.app_bootstrap){
    if(attemptsLeft>0){
      return new Promise(resolve=>setTimeout(resolve,400)).then(()=>callBootstrap(attemptsLeft-1));
    }
    return Promise.resolve({profile:'personal',initial_view:'self',backend:'bridge update needed',
      bootstrap_error:'app_bootstrap was never attached to pywebview.api'});
  }
  return bridgeTimeout(pywebview.api.app_bootstrap(),'App bootstrap',10000).catch(e=>{
    if(attemptsLeft>0){
      return new Promise(resolve=>setTimeout(resolve,400)).then(()=>callBootstrap(attemptsLeft-1));
    }
    return {profile:'personal',initial_view:'self',backend:'bridge update needed',bootstrap_error:String(e)};
  });
}
function boot(tries){
  if(api()){
    let ready;
    try{
      ready=callBootstrap(16); // up to ~8s of retries before giving up
    }catch(e){
      ready=Promise.resolve({profile:'personal',initial_view:'self',backend:'bridge update needed',bootstrap_error:String(e)});
    }
    ready.then(info=>{
      applyAppBootstrap(info);
      if(info&&info.bootstrap_error){
        toast('Faerie Fire bridge did not finish booting: '+info.bootstrap_error,true);
      }
      if(info&&info.needs_onboarding){ openOnboarding(); return; }
      activateView(initialView);
      if(appProfile==='personal' && initialView!=='inferences') loadState();
    });
  }
  else if(tries>0) setTimeout(()=>boot(tries-1), 250);
}
let booted=false;
function bootOnce(tries){ if(booted) return; booted=true; boot(tries); }
window.addEventListener('pywebviewready', ()=>bootOnce(40));
// WebView2 race: `pywebviewready` can fire BEFORE this listener is attached
// (the injected bridge script can run while this large file is still being
// parsed). When that happens boot() never runs and every "Loading..."
// placeholder sits forever. Poll as a safety net so boot always runs.
(function pollBridge(attempts){
  if(booted) return;
  if(window.pywebview && window.pywebview.api){ bootOnce(1); return; }
  if(attempts>0) setTimeout(()=>pollBridge(attempts-1), 250);
})(60);
window.addEventListener('focus', ()=>{
  if(!api()) return;
  if(appProfile==='personal') loadState();
  if(goalState) loadGoals();
  if(currentCuriosityState) loadCuriosity();
});
bootOnce(30);
</script>
</body></html>
